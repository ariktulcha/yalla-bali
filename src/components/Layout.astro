---
import Head from './Head.astro'
import SchemaOrg from './SchemaOrg.astro'
import WhatsAppButton from './WhatsAppButton.astro'
import VisaCTA from './VisaCTA.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  ogType?: string
  schema?: Record<string, any> | Record<string, any>[]
}

const { title, description, canonical, ogImage, ogType, schema } = Astro.props

const navLinks = [
  { label: 'ספארי', href: '/desert-safari' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מסעדות', href: '/restaurants' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: 'מדריכים', href: '/guides' },
]
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <Head title={title} description={description} canonical={canonical} ogImage={ogImage} ogType={ogType} />
  {schema && <SchemaOrg schema={schema} />}
  {import.meta.env.GA_MEASUREMENT_ID && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ gaId: import.meta.env.GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  )}
</head>
<body class="min-h-screen bg-[#0D0D0D] font-sans text-white antialiased">
  <!-- Visa CTA Banner -->
  <VisaCTA />

  <!-- Navigation -->
  <header class="sticky top-0 z-40 border-b border-teal-500/10 bg-[#0D0D0D]/90 backdrop-blur-md">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
      <!-- Logo -->
      <a href="/" class="text-2xl font-black text-white transition-colors hover:text-teal-400">
        יאללה <span class="text-teal-500">באלי</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden items-center gap-1 md:flex">
        {navLinks.map(link => {
          const isActive = Astro.url.pathname === link.href || Astro.url.pathname.startsWith(link.href + '/')
          return (
            <a
              href={link.href}
              class={`rounded-lg px-3 py-2 text-sm font-semibold transition-colors ${
                isActive
                  ? 'text-teal-400 bg-teal-500/10'
                  : 'text-white/80 hover:bg-teal-500/10 hover:text-teal-400'
              }`}
            >
              {link.label}
            </a>
          )
        })}
        <span class="mx-2 text-white/20">|</span>
        <a
          href="/desert-safari"
          class="rounded-lg bg-teal-500 px-4 py-2 text-sm font-bold text-black transition-all hover:bg-teal-400 hover:shadow-lg hover:shadow-teal-500/20"
        >
          הזמינו ספארי
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="פתח תפריט"
        aria-expanded="false"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-white/80 transition-colors hover:bg-teal-500/10 hover:text-teal-400 md:hidden"
      >
        <svg id="menu-icon-open" class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-icon-close" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden border-t border-teal-500/10 bg-[#0D0D0D]/95 backdrop-blur-md md:hidden">
      <div class="mx-auto max-w-7xl px-4 py-4">
        <!-- ספארי וטיולים -->
        <div class="mb-6">
          <h3 class="px-4 pb-3 text-xs font-bold uppercase tracking-wider text-teal-500">ספארי וטיולים</h3>
          <div class="space-y-1">
            <a href="/desert-safari" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">ספארי</a>
            <a href="/tours" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">טיולים</a>
            <a href="/guides" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">מדריכים</a>
            <a href="/areas" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">אזורים</a>
          </div>
        </div>

        <!-- גלו -->
        <div class="mb-6">
          <h3 class="px-4 pb-3 text-xs font-bold uppercase tracking-wider text-teal-500">גלו</h3>
          <div class="space-y-1">
            <a href="/attractions" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">אטרקציות</a>
            <a href="/hotels" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">מלונות</a>
            <a href="/restaurants" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">מסעדות</a>
            <a href="/nightlife" class="block border-r-2 border-transparent px-4 py-3 text-base font-medium text-white/80 transition-colors hover:border-teal-500 hover:bg-teal-500/10 hover:text-teal-400">חיי לילה</a>
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href="/desert-safari"
          class="mt-6 block rounded-lg bg-teal-500 px-4 py-3 text-center text-base font-bold text-black transition-all hover:bg-teal-400"
        >
          הזמינו ספארי
        </a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-20 border-t border-teal-500/10 bg-[#0D0D0D]">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <!-- Brand Column -->
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="text-2xl font-black text-white">
            יאללה <span class="text-teal-500">באלי</span>
          </a>
          <p class="mt-3 text-sm leading-relaxed text-white/60">
            המדריך המלא שלכם לבאלי — מסעדות, מלונות, אטרקציות וחוויות בלתי נשכחות.
          </p>
          <div class="mt-4 flex gap-3">
            <a href="https://instagram.com/yallabaliil" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-white/60 transition-all hover:bg-teal-500/20 hover:text-teal-400">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://facebook.com/yallabaliil" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-white/60 transition-all hover:bg-teal-500/20 hover:text-teal-400">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://tiktok.com/@yallabaliil" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-white/60 transition-all hover:bg-teal-500/20 hover:text-teal-400">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
          </div>
        </div>

        <!-- Safari Column -->
        <div>
          <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-teal-500">ספארי וטיולים</h3>
          <ul class="space-y-2">
            <li><a href="/desert-safari" class="text-sm text-white/60 transition-colors hover:text-teal-400">טיול ג׳יפים במדבר</a></li>
            <li><a href="/quad-rzr-bali" class="text-sm text-white/60 transition-colors hover:text-teal-400">טרקטרון ו-RZR</a></li>
            <li><a href="/tours" class="text-sm text-white/60 transition-colors hover:text-teal-400">כל הטיולים</a></li>
            <li><a href="/guides" class="text-sm text-white/60 transition-colors hover:text-teal-400">מדריכים</a></li>
            <li><a href="/areas" class="text-sm text-white/60 transition-colors hover:text-teal-400">אזורים בבאלי</a></li>
          </ul>
        </div>

        <!-- Discover Column -->
        <div>
          <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-teal-500">גלו</h3>
          <ul class="space-y-2">
            <li><a href="/attractions" class="text-sm text-white/60 transition-colors hover:text-teal-400">אטרקציות</a></li>
            <li><a href="/restaurants" class="text-sm text-white/60 transition-colors hover:text-teal-400">מסעדות</a></li>
            <li><a href="/hotels" class="text-sm text-white/60 transition-colors hover:text-teal-400">מלונות</a></li>
            <li><a href="/nightlife" class="text-sm text-white/60 transition-colors hover:text-teal-400">חיי לילה</a></li>
            <li><a href="/beaches" class="text-sm text-white/60 transition-colors hover:text-teal-400">חופים</a></li>
            <li><a href="/shopping" class="text-sm text-white/60 transition-colors hover:text-teal-400">שופינג</a></li>
            <li><a href="/markets" class="text-sm text-white/60 transition-colors hover:text-teal-400">שווקים</a></li>
          </ul>
        </div>

        <!-- Info Column -->
        <div>
          <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-teal-500">מידע</h3>
          <ul class="space-y-2">
            <li><a href="/plan" class="text-sm text-white/60 transition-colors hover:text-teal-400">תכנון טיול</a></li>
            <li><a href="/weather" class="text-sm text-white/60 transition-colors hover:text-teal-400">מזג אוויר</a></li>
            <li><a href="/kosher" class="text-sm text-white/60 transition-colors hover:text-teal-400">כשרות</a></li>
            <li><a href="/faq" class="text-sm text-white/60 transition-colors hover:text-teal-400">שאלות נפוצות</a></li>
            <li><a href="/about" class="text-sm text-white/60 transition-colors hover:text-teal-400">אודות</a></li>
            <li><a href="/contact" class="text-sm text-white/60 transition-colors hover:text-teal-400">צור קשר</a></li>
          </ul>
        </div>
      </div>

      <!-- Copyright -->
      <div class="mt-12 border-t border-teal-500/10 pt-8 text-center">
        <p class="text-sm text-white/40">
          &copy; {new Date().getFullYear()} Yalla Bali. כל הזכויות שמורות.
        </p>
      </div>
    </div>
  </footer>

  <!-- WhatsApp Button -->
  <WhatsAppButton />

  <!-- Mobile Menu Toggle Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      var iconOpen = document.getElementById('menu-icon-open');
      var iconClose = document.getElementById('menu-icon-close');

      if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener('click', function() {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          iconOpen.classList.toggle('hidden');
          iconClose.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!isOpen));
        });
      }
    });
  </script>
</body>
</html>

<style is:global>
  .card-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.4);
  }
</style>
