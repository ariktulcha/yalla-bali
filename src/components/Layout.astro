---
import Head from './Head.astro'
import SchemaOrg from './SchemaOrg.astro'
import { site } from '../config/site'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  ogType?: string
  schema?: Record<string, any> | Record<string, any>[]
}

const { title, description, canonical, ogImage, ogType, schema } = Astro.props
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-WHMPT38V');</script>
  <!-- End Google Tag Manager -->
  <Head title={title} description={description} canonical={canonical} ogImage={ogImage} ogType={ogType} />
  {schema && <SchemaOrg schema={schema} />}
  {import.meta.env.GA_MEASUREMENT_ID && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ gaId: import.meta.env.GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  )}
</head>
<body class="min-h-screen bg-[#0D0D0D] font-sans text-white antialiased">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHMPT38V" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- Navigation -->
  <header class="sticky top-0 z-40 border-b border-white/5 bg-[#0D0D0D]/80 backdrop-blur-xl backdrop-saturate-150">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
      <!-- Logo -->
      <a href="/" class="group text-2xl font-black text-white transition-all duration-300 hover:text-teal-400">
        {site.brandPrefix} <span class="text-teal-500 transition-colors duration-300 group-hover:text-teal-300">{site.brandAccent}</span>
        <span class="block text-[10px] font-medium tracking-widest text-white/30 transition-colors group-hover:text-white/50">{site.tagline}</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden items-center gap-1 md:flex">
        {site.nav.map(link => {
          const isActive = Astro.url.pathname === link.href || Astro.url.pathname.startsWith(link.href + '/')
          return (
            <a
              href={link.href}
              class={`group relative px-3 py-2 text-sm font-semibold transition-all duration-300 ${
                isActive
                  ? 'text-teal-400'
                  : 'text-white/70 hover:text-white'
              }`}
            >
              {link.label}
              <span class={`absolute bottom-0 right-0 h-0.5 rounded-full bg-gradient-to-l from-teal-400 to-teal-600 transition-all duration-300 ${
                isActive ? 'w-full' : 'w-0 group-hover:w-full'
              }`}></span>
            </a>
          )
        })}
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="פתח תפריט"
        aria-expanded="false"
        class="flex h-10 w-10 items-center justify-center rounded-xl text-white/80 transition-all duration-300 hover:bg-teal-500/10 hover:text-teal-400 hover:shadow-lg hover:shadow-teal-500/10 md:hidden"
      >
        <svg id="menu-icon-open" class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-icon-close" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="max-h-0 overflow-hidden border-t border-white/5 bg-[#0D0D0D]/98 backdrop-blur-xl transition-all duration-500 ease-in-out md:hidden">
      <div class="mx-auto max-w-7xl px-4 py-6">
        {site.mobileMenu.map(section => (
          <div class="mb-6">
            <h3 class="px-4 pb-3 text-xs font-bold uppercase tracking-wider text-teal-500">{section.title}</h3>
            <div class="space-y-1">
              {section.links.map(link => (
                <a href={link.href} class="block rounded-xl border-r-2 border-transparent px-4 py-3.5 text-base font-medium text-white/80 transition-all duration-200 hover:border-teal-500 hover:bg-teal-500/5 hover:text-teal-400 hover:pr-6">{link.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <div class="mt-20 h-px bg-gradient-to-l from-transparent via-teal-500/40 to-transparent"></div>
  <footer class="relative overflow-hidden bg-gradient-to-b from-[#0D0D0D] to-[#080808]">
    <!-- Decorative glow -->
    <div class="pointer-events-none absolute top-0 right-1/4 h-64 w-64 rounded-full bg-teal-500/5 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <!-- Footer Grid -->
      <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
        <!-- Brand Column -->
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="text-3xl font-black text-white transition-colors hover:text-teal-400">
            {site.brandPrefix} <span class="text-teal-500">{site.brandAccent}</span>
          </a>
          <p class="mt-1 text-xs font-medium tracking-wider text-teal-500/60">{site.taglineHe}</p>
          <p class="mt-4 text-sm leading-relaxed text-white/50">{site.footer.description}</p>
          <div class="mt-6 flex gap-3">
            {site.socials.instagram && (
              <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-white/50 transition-all duration-300 hover:scale-110 hover:bg-teal-500/20 hover:text-teal-400 hover:shadow-lg hover:shadow-teal-500/10">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            )}
            {site.socials.facebook && (
              <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-white/50 transition-all duration-300 hover:scale-110 hover:bg-teal-500/20 hover:text-teal-400 hover:shadow-lg hover:shadow-teal-500/10">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
            {site.socials.tiktok && (
              <a href={site.socials.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-white/50 transition-all duration-300 hover:scale-110 hover:bg-teal-500/20 hover:text-teal-400 hover:shadow-lg hover:shadow-teal-500/10">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Footer Columns from config -->
        {site.footer.columns.map(col => (
          <div>
            <h3 class="mb-5 text-sm font-bold uppercase tracking-wider text-teal-500">{col.title}</h3>
            <ul class="space-y-1">
              {col.links.map(link => (
                <li><a href={link.href} class="group flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm text-white/60 transition-all duration-200 hover:bg-white/5 hover:text-teal-400"><span class="h-1 w-1 rounded-full bg-teal-500/0 transition-all duration-200 group-hover:bg-teal-500"></span>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Copyright -->
      <div class="mt-12 border-t border-white/5 pt-8">
        <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
          <p class="text-xs text-white/30">
            &copy; {new Date().getFullYear()} {site.brand}. כל הזכויות שמורות.
          </p>
          <div class="flex items-center gap-4">
            <a href="/about" class="text-xs text-white/30 transition-colors hover:text-teal-400">אודות</a>
            <span class="text-white/10">|</span>
            <a href="/contact" class="text-xs text-white/30 transition-colors hover:text-teal-400">צור קשר</a>
            <span class="text-white/10">|</span>
            <a href="/faq" class="text-xs text-white/30 transition-colors hover:text-teal-400">שאלות נפוצות</a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Mobile Menu Toggle Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      var iconOpen = document.getElementById('menu-icon-open');
      var iconClose = document.getElementById('menu-icon-close');

      if (btn && menu && iconOpen && iconClose) {
        btn.addEventListener('click', function() {
          var isOpen = menu.style.maxHeight && menu.style.maxHeight !== '0px';
          if (isOpen) {
            menu.style.maxHeight = '0px';
            iconOpen.classList.remove('hidden');
            iconClose.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          } else {
            menu.style.maxHeight = menu.scrollHeight + 'px';
            iconOpen.classList.add('hidden');
            iconClose.classList.remove('hidden');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      }
    });
  </script>
</body>
</html>

<style is:global>
  .card-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.4);
  }
</style>
