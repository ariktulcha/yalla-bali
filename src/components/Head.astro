---
interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  ogType?: string
  heroImage?: string
}
const { title, description, canonical, ogImage: ogImageProp, ogType = 'website', heroImage } = Astro.props
const ogImage = ogImageProp || '/images/heroes/hero-bali.webp'
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString()
const safeOgImage = typeof ogImage === 'string' && ogImage ? ogImage : '/images/heroes/hero-bali.webp'
const absoluteOgImage = safeOgImage.startsWith('http') ? safeOgImage : new URL(safeOgImage, Astro.site).toString()
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={absoluteOgImage} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content="he_IL" />
<meta property="og:site_name" content="יאללה באלי" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteOgImage} />
<link rel="icon" href="/favicon.svg" />
{heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
<link rel="dns-prefetch" href="https://nsfmucsdxhcywisejxxq.supabase.co" />
<link rel="preconnect" href="https://images.unsplash.com" />
<link rel="alternate" hreflang="he" href={canonicalUrl} />
<link rel="alternate" hreflang="he-IL" href={canonicalUrl} />
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
