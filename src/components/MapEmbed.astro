---
interface Props {
  areaName: string
  areaNameEn?: string
  zoom?: number
  height?: string
}

const { areaName, areaNameEn = '', zoom = 14, height = '400px' } = Astro.props

const apiKey = import.meta.env.GOOGLE_MAPS_API_KEY
const query = areaNameEn ? `${areaNameEn},+Bali` : `${areaName},+Bali`

const mapUrl = `https://www.google.com/maps/embed/v1/place?key=${apiKey}&q=${encodeURIComponent(query)}&zoom=${zoom}`
---

{apiKey ? (
  <div class="rounded-2xl overflow-hidden border border-teal-500/20 mb-8">
    <iframe
      width="100%"
      height={height}
      style={`border: 0; border-radius: 1rem;`}
      loading="lazy"
      allowFullScreen=""
      referrerPolicy="no-referrer-when-downgrade"
      src={mapUrl}
      title={`Google Map of ${areaName}`}
    />
  </div>
) : (
  <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8 text-center text-white/60">
    <p>Google Maps עדיין לא מוגדרות. אנא הוסיפו GOOGLE_MAPS_API_KEY ל-.env</p>
  </div>
)}
