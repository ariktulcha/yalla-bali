---
interface Props {
  areaName: string
  areaNameEn?: string
  height?: string
  heading?: number
  pitch?: number
}

const {
  areaName,
  areaNameEn = '',
  height = '400px',
  heading = 0,
  pitch = 0
} = Astro.props

const apiKey = import.meta.env.GOOGLE_MAPS_API_KEY
const query = areaNameEn ? `${areaNameEn}, Bali` : `${areaName}, Bali`

// Use Street View Static API which doesn't require embedding
const svUrl = `https://maps.googleapis.com/maps/api/streetview?size=800x400&location=${encodeURIComponent(query)}&heading=${heading}&pitch=${pitch}&key=${apiKey}`
---

{apiKey ? (
  <div class="rounded-2xl overflow-hidden border border-teal-500/20 mb-8 bg-[#1A1208]">
    <div class="relative w-full" style={`padding-bottom: 50%; height: 0;`}>
      <img
        src={svUrl}
        alt={`Street view of ${areaName}`}
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="p-4 text-center text-white/60 text-sm">
      📸 Street View של {areaName}
    </div>
  </div>
) : (
  <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8 text-center text-white/60">
    <p>Google Street View עדיין לא מוגדרה. אנא הוסיפו GOOGLE_MAPS_API_KEY ל-.env</p>
  </div>
)}
