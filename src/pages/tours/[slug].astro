---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import Layout from '../../components/Layout.astro'
import PhotoGallery from '../../components/PhotoGallery.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: tours } = await supabaseAdmin
    .from('tours')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (tours ?? []).map((tour) => ({
    params: { slug: tour.slug },
    props: { tour },
  }))
}

const { tour } = Astro.props

const price = tour.base_price ?? tour.price ?? tour.metadata?.price
const duration = tour.duration ?? tour.metadata?.duration
const rating = tour.rating ?? tour.metadata?.rating
const reviewCount = tour.review_count ?? tour.metadata?.review_count ?? 10
const includes = tour.includes ?? tour.metadata?.includes ?? []
const meetingPoint = tour.meeting_point ?? tour.metadata?.meeting_point
const groupSize = tour.group_size ?? tour.metadata?.group_size

const contentHtml = tour.full_content ? await marked(tour.full_content) : ''

const pageTitle = `${tour.name_he}${tour.name_en ? ` — ${tour.name_en}` : ''} | טיולים בבאלי | Yalla Bali`
const pageDescription = tour.excerpt || tour.description || `${tour.name_he} — טיול מאורגן בבאלי`

const tourSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: tour.name_he,
  alternateName: tour.name_en || undefined,
  description: tour.description || tour.excerpt,
  image: tour.image ? (tour.image.startsWith('http') ? tour.image : new URL(tour.image, Astro.site).toString()) : undefined,
  url: new URL(`/tours/${tour.slug}`, Astro.site).toString(),
  ...(price ? {
    offers: {
      '@type': 'Offer',
      price: typeof price === 'number' ? price : undefined,
      priceCurrency: 'ILS',
      availability: 'https://schema.org/InStock',
    }
  } : {}),
  ...(rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: rating, ratingCount: reviewCount, bestRating: 5 } } : {}),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'טיולים', href: '/tours' },
  { label: tour.name_he },
]

// Distance & pricing estimates by area
const areaDistancePricing: Record<string, { distance: string; grabPrice: string }> = {
  'סמינייק': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'seminyak': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'קאנגו': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'canggu': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'אובוד': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ubud': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ג\'ימברן': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'jimbaran': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'אולוואטו': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'uluwatu': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'נוסה דואה': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'nusa-dua': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'סנור': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'sanur': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'קוטה': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
  'kuta': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
}

const areaKey = (tour.area || '').toLowerCase()
const distancePricing = areaDistancePricing[areaKey] || { distance: '20-25 ק"מ', grabPrice: '₪70-100' }

const faqItems = [
  {
    q: `כמה עולה ${tour.name_he}?`,
    a: `${typeof price === 'number' ? `המחיר הוא ₪${price} לאדם.` : `${price ? `המחיר הוא בערך ${price}.` : 'המחיר משתנה בהתאם לקבוצה וההעדפות שלכם.'}`} אנחנו מציעים הנחות לקבוצות גדולות. צרו איתנו קשר בווטסאפ לקבלת הצעה מותאמת.`,
  },
  {
    q: `כמה זמן ארוך ${tour.name_he}?`,
    a: `${duration ? `הטיול הוא בערך ${duration}.` : 'זה תלוי באפשרויות הזמינות.'} זמן הטיול כולל זמן לתחבורה, טיול, ו${includes.length > 0 ? 'כל מה שכלול בחבילה' : 'עצירות'}. אם אתם מעוניינים בטיול מורחב או קצר יותר, תוכלו להתאים זאת כשתזמינו.`,
  },
  {
    q: `האם ${tour.name_he} מחייבת הזמנה מראש?`,
    a: `כן, מומלץ מאוד להזמין מראש — לפחות 3-7 ימים. זה מאפשר לנו להתכין את כל הפרטים ולוודא שיש מקום לכם. אתם יכולים להזמין בווטסאפ ונחזור אליכם בתוך דקות.`,
  },
  {
    q: `מה כלול ב${tour.name_he}?`,
    a: `${includes.length > 0 ? `הטיול כולל: ${includes.slice(0, 3).join(', ')} ועוד.` : 'הטיול כולל הובלה, מדריך מקצועי, ופעילויות.'} לעוד פרטים על המדויק שכלול, צרו איתנו קשר בווטסאפ או בעיין בתיאור המלא.`,
  },
]

// Related tours in same area
const { data: areaTours } = await supabaseAdmin
  .from('tours')
  .select('slug, name_he, description, image')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', tour.area)
  .neq('slug', tour.slug)
  .limit(3)

const relatedTours = areaTours ?? []
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://yalla-bali.co.il/tours/${tour.slug}`}
  ogImage={tour.image}
  ogType="article"
  schema={tourSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mb-8">
      <PhotoGallery
        mainImage={tour.image}
        galleryUrls={tour.gallery_urls || []}
        name={tour.name_he}
      />
    </div>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{tour.name_he}</h1>
      {tour.name_en && (
        <p class="text-lg text-white/50">{tour.name_en}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
      {price && (
        <span class="inline-flex items-center gap-1.5 bg-teal-500/10 border border-teal-500/20 text-teal-400 font-bold px-4 py-2 rounded-full text-base">
          {typeof price === 'number' ? `₪${price}` : price}
        </span>
      )}
      {duration && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {duration}
        </span>
      )}
      {rating && (
        <span class="inline-flex items-center gap-1 text-teal-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {rating.toFixed?.(1) ?? rating}
        </span>
      )}
      {groupSize && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          {groupSize}
        </span>
      )}
    </div>

    {tour.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-white/80 leading-relaxed">{tour.description}</p>
      </div>
    )}

    {includes.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">מה כולל {tour.name_he}</h2>
        <ul class="space-y-2">
          {includes.map((item: string) => (
            <li class="flex items-start gap-2 text-white/70">
              <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    )}

    {meetingPoint && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">נקודת מפגש — {tour.name_he}</h2>
        <p class="text-white/70">{meetingPoint}</p>
      </div>
    )}

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">נקודת מפגש והסעה 🚕</h2>
      <div class="space-y-4 text-white/70">
        {meetingPoint && (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <div>
              <p class="font-medium text-white">נקודת מפגש</p>
              <p class="text-sm">{meetingPoint}</p>
            </div>
          </div>
        )}
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="font-medium text-white">הסעה מנמל התעופה</p>
            <p class="text-sm">משוער: <span class="text-white">{distancePricing.grabPrice}</span> עם Grab/Gojek</p>
            <p class="text-xs text-white/50 mt-1">* המחיר משוער בלבד. כלול בטיול או לא — בדקו את פרטי הטיול.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <FAQSection items={faqItems} />
    </div>

    {relatedTours.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-800" dir="rtl">
        <h2 class="text-2xl font-bold text-white mb-6">🎯 טיולים נוספים בבאלי</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedTours.map((item: any) => (
            <a
              href={`/tours/${item.slug}`}
              class="group bg-gray-900 rounded-xl overflow-hidden hover:bg-gray-800 transition-colors"
            >
              {item.image ? (
                <img
                  src={item.image}
                  alt={item.name_he}
                  class="w-full h-40 object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-40 bg-gray-800 flex items-center justify-center">
                  <span class="text-4xl">🎯</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-tight group-hover:text-teal-400 transition-colors">
                  {item.name_he}
                </h3>
                {item.description && (
                  <p class="text-gray-400 text-xs mt-1 line-clamp-2">{item.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center mt-16">
      <p class="text-white/80 mb-4">רוצים להזמין את {tour.name_he} או לשמוע על טיולים נוספים בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent(`היי, אני מעוניין בטיול ${tour.name_he} בבאלי 🎯`)}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl" class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        הזמינו עכשיו בווטסאפ
      </a>
    </div>
  </div>
</Layout>
