---
import Layout from '../../components/Layout.astro'
import TourCard from '../../components/Cards/TourCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('tours')
  .select('name_he, slug, image, base_price, duration_hours, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const tours = items || []

const title = 'טיולים ותורים בבאלי | Yalla Bali'
const description = 'טיולי טבע, טיולי הרים, טיולים תרבותיים, צלילה ועוד טיולים מומלצים בבאלי. הזמנה ישירה, מחירים ופרטים מלאים.'

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'טיולים וספארי בבאלי',
  description,
  numberOfItems: tours.length,
  itemListElement: tours.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.name_he,
    url: `https://ibalibali.com/tours/${t.slug}`,
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: 'https://ibalibali.com/' },
    { '@type': 'ListItem', position: 2, name: 'טיולים ותורים' },
  ],
}
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="relative py-20 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">טיולים ותורים</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black mb-4">טיולים ותורים בבאלי</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        טיולי הרים בעלות שקיעה, טיולי טבע דרך יערות קופים, טיולים תרבותיים לטמפלים קדומים, ודאי לא לשכוח — טיולי צלילה ושייט בדאו.
      </p>
      <p class="mt-4 text-teal-400 font-medium">{tours.length} טיולים</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-20">
    {tours.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {tours.map((tour) => (
          <TourCard {...tour} />
        ))}
      </div>
    ) : (
      <div>
        <p class="text-center text-white/40 py-12">לא נמצאו טיולים כרגע. חזרו בקרוב!</p>
      </div>
    )}
  </section>

  <!-- Upcoming Tours Section -->
  <section class="bg-gradient-to-br from-teal-900/20 to-teal-800/10 border-y border-teal-500/10 py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-2 rounded-full bg-teal-500/20 text-teal-400 text-sm font-bold mb-4">🔜 בקרוב</span>
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">טיולים שאנחנו בונים עבורכם</h2>
        <p class="text-white/70 max-w-2xl mx-auto leading-relaxed">
          בימים אלו אנחנו עובדים על מדריכי סיורים חדשים בבאלי — סיורים תרבותיים, קולינריים וטיולי טבע — שיתווספו לאתר בקרוב.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <!-- Upcoming Tour 1 -->
        <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-8">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-2xl font-bold text-teal-400 mb-2">סיור תרבות ובוודו בבאלי 🏛️</h3>
              <p class="text-white/60 text-sm mb-4">טיול תרבותי בטמפלים קדומים — היכרות עם התרבות הבלינזית-הינדואית והטמפלים היפים ביותר באי.</p>
            </div>
          </div>
          <div class="mb-2 space-y-2">
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">⏱️</span>
              <span class="text-white/70">כ-3 שעות</span>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">👥</span>
              <span class="text-white/70">עד 10 אנשים</span>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">💬</span>
              <span class="text-white/70">עברית ואנגלית</span>
            </div>
          </div>
        </div>

        <!-- Upcoming Tour 2 -->
        <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-8">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-2xl font-bold text-teal-400 mb-2">סיור קולינרי בשווקים של באלי 🍜</h3>
              <p class="text-white/60 text-sm mb-4">טיול טעימים דרך שווקי באלי — אוכל מקומי, תרבות וחוויה אמיתית בבאלי המקומית.</p>
            </div>
          </div>
          <div class="mb-2 space-y-2">
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">⏱️</span>
              <span class="text-white/70">כ-4 שעות</span>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">👥</span>
              <span class="text-white/70">עד 8 אנשים</span>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-teal-400">💬</span>
              <span class="text-white/70">עברית ואנגלית</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
