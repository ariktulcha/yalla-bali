---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import FAQSection from '../components/FAQSection.astro'

const faqItems = [
  {
    q: 'האם ישראלים צריכים ויזה לבאלי?',
    a: 'כן — אבל קל מאוד. ישראלים מקבלים ויזת תייר בהגעה (Visa on Arrival / VOA) בשדה התעופה נגוראה ראי. עלות: 500,000 רופיה אינדונזית (כ-35 דולר). מאפשרת שהייה של 30 יום, וניתן להאריך פעם אחת ב-30 יום נוספים (60 יום בסך הכול) בתשלום נוסף. דרישות: דרכון ישראלי בתוקף לפחות 6 חודשים, כרטיס חזרה, ומזומן או כרטיס אשראי לתשלום בשדה.'
  },
  {
    q: 'האם באלי בטוחה לישראלים?',
    a: 'כן, בהחלט. באלי היא אחת היעדים התיירותיים הפופולריים בעולם ומקבלת מיליוני תיירים מכל העולם, כולל אלפי ישראלים מדי חודש. שיעור הפשע נמוך, התושבים ידידותיים, ותיירות היא עמוד השדרה של הכלכלה המקומית — לכולם יש אינטרס לשמור על תיירים בטוחים. מומלץ: שמרו על תיק וטלפון בצד הגוף, הימנעו מעסקאות מריחואנה (ענישה אינדונזית חמורה מאוד), ושמרו על כבוד לתרבות ולמקדשים המקומיים.'
  },
  {
    q: 'מתי הזמן הכי טוב לטוס לבאלי?',
    a: 'עונת הקיץ הבאלינזית (אפריל–אוקטובר) היא הזמן הטוב ביותר — שמיים בהירים, לחות נמוכה יחסית, ים שקט לשחייה וגלישה. שיא העונה: יוני–אוגוסט. עונת הגשמים (נובמבר–מרץ) מביאה גשמים קצרים בצהריים-ערב, אבל מחירי מלונות נמוכים ב-30–50%, פחות תיירים, וצמחייה ירוקה מרהיבה. בפועל — באלי שווה כל עונה; הגשמים הטרופיים לא מקלקלים ביקור.'
  },
  {
    q: 'כמה ימים מומלץ לטייל בבאלי?',
    a: '7–10 ימים הם האידיאל לראות את עיקרי בבאלי: קוטה/סמינייק, אובוד (Rice terraces, Monkey Forest), קאנגו, אולוואטו, ואחד מהחופים הדרומיים. 14 ימים מאפשרים להוסיף נוסה פנידה, מקדשים בצפון, וטיול פנים-האי. אפילו 5 ימים שווים — תוכלו לכסות את הדרום ואובוד בקצב נחוץ.'
  },
  {
    q: 'איך מגיעים מישראל לבאלי?',
    a: 'אין טיסות ישירות מישראל לבאלי (שדה DPS — נגוראה ראי). הדרך הנפוצה: עצירה אחת בסינגפור (Singapore Airlines, Scoot), קואלה לומפור (AirAsia, Malaysia Airlines), בנגקוק (Thai Airways), הונג קונג (Cathay Pacific), או איסטנבול (Turkish Airlines). זמן טיסה כולל: 14–18 שעות. מחירים: 1,800–3,500 ש"ח הלוך-חזור תלוי בעונה. מומלץ להזמין 2–3 חודשים מראש בעונת השיא.'
  },
  {
    q: 'מה המטבע בבאלי וכמה עומד שקל מול רופיה?',
    a: 'המטבע הרשמי הוא הרופיה האינדונזית (IDR). שער משוער: 1 ש"ח ≈ 4,200–4,500 רופיה (בדקו שער עדכני). דוגמאות: ארוחה מקומית במסעדה פשוטה = 30,000–50,000 רופיה (~7–12 ש"ח). שתיית מיץ טרי = 20,000 רופיה. כרטיס Grab בתוך Canggu = 40,000 רופיה. מומלץ למשוך מזומן מכספומטות מקומיות (Bank BNI, BCA, Mandiri) — תמיד בדקו שיש לוגו Visa/Mastercard.'
  },
  {
    q: 'כמה עולה טיול לבאלי ביום?',
    a: 'Budget (גולשים חסכניים): 30–50 דולר ליום — Guesthouse, אוכל בוורונג (מסעדה מקומית), Grab לנסיעות. Mid-range (הממוצע): 80–130 דולר ליום — מלון 3 כוכבים עם בריכה, מסעדות נחמדות, טיולים מאורגנים. Luxury: 200–500+ דולר ליום — ויילות עם pool private, ספא, מסעדות פרמיום. באלי היא אחת היעדים הכי cost-effective לרמת חיים שמקבלים.'
  },
  {
    q: 'מה לעשות באובוד?',
    a: 'אובוד היא הלב התרבותי של באלי. חובה: Rice Terraces (שדות אורז) של Tegalalang, Monkey Forest (יער הקופים — עלות: 80,000 רופיה), Ubud Palace עם מופעי מחול Legong בערב, ו-Sacred Monkey Forest Sanctuary. ממליצים גם: מסלולי טרקינג בשדות, טיול אופניים בכפרים, שוק האמנויות, ועיסוי טרדיציוני בלוב (80,000–150,000 רופיה לשעה). אובוד ממוקמת ~1.5 שעות מ-Kuta.'
  },
  {
    q: 'מה לעשות בקאנגו?',
    a: 'קאנגו (Canggu) היא ה-vibe של הנוודים הדיגיטליים. חוף בראווה לגלישה, Old Man\'s (הבאר האיקוני), Canggu Club, co-working spaces, חנויות ויניל ואופנת וינטאג\', ספא מוזלים, ואוכל טבעוני/בריאות בכל פינה. היא פחות "תיירות" ויותר "חיים בבאלי" — מי שיגיע יבין למה כל כך הרבה אנשים החליטו להישאר.'
  },
  {
    q: 'מה לעשות באולוואטו?',
    a: 'אולוואטו (Uluwatu) יושבת על קצה קליפים מרהיבים מדרום לבאלי. אטרקציות עיקריות: מקדש Pura Luhur Uluwatu על שפת הצוק (כניסה: 50,000 רופיה + סרונג חובה), Kecak Fire Dance בשקיעה (150,000 רופיה — ממש מרגש), חוף פאדאנג פאדאנג הסמוי, ספוטים לגלישה לגולשים מנוסים (Uluwatu, Bingin, Dreamland), ומסעדות על הצוקים כמו Sundays Beach Club.'
  },
  {
    q: 'האם יש WiFi ו-4G טובים בבאלי?',
    a: 'כן. WiFi זמין בכמעט כל מלון, קפה, מסעדה ו-co-working space — במיוחד באזורי Kuta, Seminyak, Canggu ו-Ubud. 4G: קנו כרטיס SIM מקומי בשדה התעופה או בחנויות Telkomsel/XL/Indosat — עולה 100,000–150,000 רופיה לחבילה של 10–20GB לחודש. ה-coverage מצוין ברוב האי. באזורים מרוחקים (צפון, הרים) — ייתכן איתות חלש.'
  },
  {
    q: 'איזה תקע חשמל משתמשים בבאלי?',
    a: 'בבאלי (אינדונזיה) משתמשים בשקע מסוג Type C ו-Type F (2 פינים עגולים — אירופאי). מתח: 220V / 50Hz. ישראלים: התקע הישראלי (H-type) לרוב לא נכנס ישירות — דרוש מתאם. מתאם אוניברסלי עולה כמה שקלים וזמין בחנויות אלקטרוניקה. מרבית המלונות הנחמדים מספקים מתאמים בחינם.'
  },
  {
    q: 'האם המים ברז בטוחים לשתייה בבאלי?',
    a: 'לא. לא לשתות מים מהברז בבאלי בשום מצב — גם מקומיים לא שותים. קנו בקבוקי מים מינרליים (מינרלי Aqua — הכי נפוץ, 5,000–10,000 רופיה ל-600ml) ורוב המלונות מספקים בקבוקי מים בחינם. שימו לב גם לקרח — במסעדות טובות ו-cafes הקרח בדרך כלל מוגן, אך בדוכנים רחוב — שאלו.'
  },
  {
    q: 'מה ההבדל בין עונת הגשמים לעונה היבשה בבאלי?',
    a: 'עונה יבשה (Dry Season): אפריל–אוקטובר. שמיים כחולים, לחות נמוכה, ים שקט. שיא התיירות ביוני–אוגוסט. עונת גשמים (Wet Season): נובמבר–מרץ. גשמים מגיעים בד"כ אחה"צ/ערב ל-1–2 שעות, ואז עוצרים. הבוקרים לרוב בהירים. החיסרון: לחות גבוהה, לפעמים שיטפונות באזורים נמוכים. היתרון: מחירים נמוכים, פחות תיירים, ואינדונזיה ירוקה וציורית. רוב הישראלים שטסים מדצמבר–ינואר (חורף ישראלי) מגיעים לעונת גשמים — ונהנים מאוד.'
  },
  {
    q: 'האם יש אוכל טבעוני וצמחוני בבאלי?',
    a: 'בהחלט — באלי היא גן עדן לטבעונים וצמחונים. בעיקר בקאנגו, סמינייק ואובוד תמצאו עשרות מסעדות טבעוניות מלאות: Acai bowls, smoothie bowls, Buddha bowls, Nasi Goreng בגרסה טבעונית, warung (מסעדה מקומית) עם אפשרויות ירקות. רוב המסעדות מסמנות אפשרויות vegan/vegetarian בתפריט. מחירים נוחים: 40,000–80,000 רופיה לארוחה מלאה.'
  },
  {
    q: 'האם מותר לשתות אלכוהול בבאלי?',
    a: 'כן. אינדונזיה היא מדינה מוסלמית ברוב, אבל באלי (הינדואית ברובה) ליברלית מאוד בנושא. אלכוהול זמין בכל מסעדה, בר ו-beach club. Bintang — הבירה המקומית האיקונית — היא הסמל הבלתי רשמי של באלי. Arak (ליקר מקומי ממשקה דקל) זמין ואותנטי, אך שימו לב: Arak לא מוסדר עלול להיות מסוכן — שתו רק ממקומות מוכרים.'
  },
  {
    q: 'האם צריך חיסונים לפני טיסה לבאלי?',
    a: 'לא חובה מבחינה חוקית, אבל מומלץ: Hepatitis A ו-B (מסוכן דרך מזון/מים/קשר), Typhoid (קדחת טיפוס — דרך מזון/מים), ועדכון חיסון נגד טטנוס. מי שמתכנן טרקינג בג\'ונגל — חיסון כלבת. דבר עם הרופא שלכם לפחות חודש לפני הנסיעה.'
  },
  {
    q: 'האם צריך ביטוח נסיעות לבאלי?',
    a: 'מומלץ מאוד — ביטול טיסה, ביטוח רפואי (טיפול חירום בבאלי יכול לעלות אלפי דולרים), ואובדן כבודה. ספורט אתגרי (גלישה, צלילה, טרקינג) לא תמיד מכוסה — בדקו את הפוליסה. חברת Clal ו-Phoenix מישראל מציעות ביטוחי נסיעה לאינדונזיה, וכמובן חברות בינ"ל כמו World Nomads מצוינות לבאלי.'
  },
]

const topics = ['ויזה', 'בטיחות', 'מזג אוויר', 'כמה ימים', 'הגעה מישראל', 'מטבע ורופיה', 'עלויות', 'אובוד', 'קאנגו', 'אולוואטו', 'WiFi ו-SIM', 'חשמל', 'מים ובטיחות', 'עונות', 'טבעוני', 'אלכוהול', 'חיסונים', 'ביטוח']

const relatedPages = [
  { href: '/beaches', title: 'חופים בבאלי', desc: '7 החופים הכי שווים' },
  { href: '/attractions', title: 'אטרקציות', desc: 'מה לעשות בבאלי' },
  { href: '/plan', title: 'תכנון טיול', desc: 'כלי תכנון חכם' },
  { href: '/weather', title: 'מזג אוויר', desc: 'מדריך עונות' },
  { href: '/hotels', title: 'מלונות', desc: 'היכן לישון' },
  { href: '/contact', title: 'צור קשר', desc: 'נשמח לעזור!' },
]
---

<Layout
  title="שאלות ותשובות על טיול לבאלי | Yalla Bali"
  description="כל השאלות והתשובות על טיול לבאלי: ויזה, בטיחות, מזג אוויר, הגעה מישראל, מטבע רופיה, עלויות, אוכל טבעוני, WiFi, חשמל, עונות ועוד. המדריך המלא לתייר הישראלי."
  canonical="https://ibalibali.com/faq"
>

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#0F2420] to-[#0A1A18]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">שאלות <span class="text-teal-400">ותשובות</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">כל מה שרציתם לדעת על טיול לבאלי — ויזה, בטיחות, כסף, הגעה מישראל, אוכל ועוד. {faqItems.length} שאלות עם תשובות מפורטות.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 -mt-6 relative z-20 mb-8">
    <div class="bg-gradient-to-br from-[#0F2420] to-[#0A1A18] border border-teal-500/20 rounded-2xl p-4 md:p-6">
      <h2 class="text-white font-bold mb-3">נושאים מכוסים:</h2>
      <div class="flex flex-wrap gap-2">
        {topics.map((topic) => (
          <span class="text-xs bg-teal-500/10 text-teal-400 px-3 py-1 rounded-full border border-teal-500/20">{topic}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <FAQSection items={faqItems} />
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">עמודים <span class="text-teal-400">שימושיים</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {relatedPages.map((page) => (
        <a href={page.href} class="bg-gradient-to-br from-[#0F2420] to-[#0A1A18] border border-teal-500/10 hover:border-teal-500/30 rounded-xl p-4 text-center transition-all">
          <p class="text-white font-bold">{page.title}</p>
          <p class="text-white/50 text-sm">{page.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
