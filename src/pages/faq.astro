---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import FAQSection from '../components/FAQSection.astro'

const faqItems = [
  { q: 'האם ישראלים צריכים ויזה לבאלי?', a: 'לא! מאז הסכמי אברהם (2020), ישראלים מקבלים ויזת תייר ל-30 יום בהגעה לשדה התעופה (Visa on Arrival). צריך דרכון ישראלי בתוקף של לפחות 6 חודשים. אפשר להאריך ל-60 יום בתשלום. ויזה עסקית דורשת הסדרה מראש.' },
  { q: 'האם באלי בטוחה לישראלים?', a: 'בהחלט כן. באלי היא אחת הערים הבטוחות ביותר בעולם עם שיעור פשע נמוך מאוד. יש אלפי ישראלים שמבקרים כל חודש. אפשר לדבר עברית ברחוב, יש שילוט בעברית במקומות תיירותיים, והשלטונות ידידותיים לתיירים ישראלים. עם זאת, מומלץ להימנע מדיון פוליטי ולשמור על כבוד לתרבות המקומית.' },
  { q: 'מתי הזמן הכי טוב לטוס לבאלי?', a: 'העונה הטובה ביותר היא נובמבר עד מרץ, כשהטמפרטורות נעימות (20-30 מעלות). הקיץ (יוני-ספטמבר) חם מאוד (40-45 מעלות) אבל מחירי מלונות נמוכים ב-50-60%. אפריל ואוקטובר הם חודשי ביניים טובים עם פשרה בין מזג אוויר למחירים.' },
  { q: 'כמה ימים צריך לטיול בבאלי?', a: '4-5 ימים מספיקים לראות את רוב האטרקציות המרכזיות: בורג\' חליפה, באלי מול, ספארי במדבר, שווקים, וחוף. 7 ימים מאפשרים טיול רגוע יותר עם יום באבו דאבי, עוד ספארי, קניות ומסעדות. עם ילדים, 5-7 ימים אידיאלי.' },
  { q: 'איך מגיעים מישראל לבאלי?', a: 'טיסות לבאלי (DPS - נגוראה ראי) מישראל כוללות טיסת מעבר. חברות טיסה: Emirates, Etihad, Turkish Airlines וחברות נוספות. זמן טיסה: 12-16 שעות (עם עצירה). מחירים: החל מ-2,000-3,000 ש"ח לכיוון. מומלץ להזמין מוקדם בעונת השיא.' },
  { q: 'מה כללי הלבוש בבאלי?', a: 'באלי ליברלית יחסית אבל יש כללים: בקניונים, מסעדות ומקומות ציבוריים — לבוש מכובד (לא בגד ים או חולצת גופייה צרה). בחופים — בגד ים רגיל מותר. במסגדים — כתפיים וברכיים מכוסות (נשים — גם כיסוי ראש). בברים ומועדונים — dresscode מחמיר, אסור סנדלים וטריינינג.' },
  { q: 'האם מותר לשתות אלכוהול בבאלי?', a: 'כן, אבל רק במקומות מורשים — בתי מלון, מסעדות ובארים מורשים. אסור לשתות ברחוב, בחופים ציבוריים, או להיות שיכור במקום ציבורי (קנס כבד!). אפשר לקנות אלכוהול ב-Duty Free בשדה התעופה. הגיל המינימלי לשתייה: 21.' },
  { q: 'איזה מטבע משתמשים בבאלי?', a: 'דירהם של אמירויות (AED). שער: 1 AED = כ-1 ש"ח (בערך). כרטיסי אשראי מתקבלים בכל מקום. מומלץ: החליפו מעט מזומן בשדה התעופה (לטאקסי ושווקים), והשתמשו בכרטיס בקניונים ומסעדות.' },
  { q: 'איך מסתובבים בבאלי?', a: 'מטרו — מהיר, נקי וזול. Uber/Careem — נפוצים מאוד וזולים (נסיעה בעיר 20-50 AED). מונית — זמינות בכל מקום. השכרת רכב — אפשרי עם רישיון בינלאומי. המלצה: מטרו + Uber = שילוב מושלם.' },
  { q: 'האם יש אוכל כשר בבאלי?', a: 'כן! יש מסעדות כשרות בבאלי, בעיקר באזורי JBR, באלי מרינה ודאונטאון. בסופרמרקטים כמו Spinneys ו-Carrefour יש מדור מוצרים כשרים. רוב האוכל בבאלי הוא חלאל. לפרטים נוספים — עמוד הכשרות שלנו.' },
  { q: 'כמה עולה ספארי במדבר?', a: 'ספארי במדבר מתחיל מ-₪199 לאדם (ספארי בוקר). ספארי ערב כולל ארוחת ערב: ₪249. ספארי פרטי VIP: ₪499. המחירים כוללים איסוף והחזרה מהמלון ועשויים להשתנות — לפרטים מדויקים ועדכניים ראו את <a href="/tours" class="text-teal-400 underline">דף הטיולים</a> שלנו.' },
  { q: 'מה לגבי WiFi ותקשורת?', a: 'WiFi חינם זמין בכמעט כל מלון, קניון, מסעדה ובית קפה. אם צריכים אינטרנט בדרכים: קנו כרטיס SIM מקומי של du או Etisalat (50-100 AED לשבוע). שימו לב: שיחות WhatsApp ו-FaceTime חסומות — השתמשו ב-Botim או VPN.' },
  { q: 'מה לגבי חשמל ושקעים?', a: 'באלי משתמשת בשקע בריטי (Type G — 3 פינים). מתח: 220V. צריך מתאם שקע! קנו מתאם בריטי לפני הטיסה או בשדה התעופה. רוב המלונות מספקים מתאמים בחינם.' },
  { q: 'איך מזמינים ספארי במדבר?', a: 'הכי קל — דרך וואטסאפ. שלחו לנו הודעה עם התאריך, מספר אנשים, וסוג הספארי הרצוי. אנחנו נחזור עם אישור ומחיר תוך דקות. ההזמנה כוללת איסוף מהמלון, הספארי עצמו, והחזרה למלון.' },
  { q: 'האם צריך ביטוח נסיעות?', a: 'מומלץ מאוד! ביטוח רפואי חיוני — טיפול רפואי בבאלי יקר מאוד (ביקור מיון: 2,000+ AED). מומלץ ביטוח שכולל: רפואי, ביטול טיסה, אובדן מזוודה, וספורט אתגרי.' },
  { q: 'מה אסור להכניס לבאלי?', a: 'אסור: סמים מכל סוג (עונש חמור!), כולל CBD ומוצרי קנאביס. תרופות מרשם — חובה לקחת מרשם באנגלית. ספרים/חומרים פורנוגרפיים — אסורים. אלכוהול — מותר להכניס עד 4 ליטר מ-Duty Free.' },
  { q: 'כמה טיפ נותנים בבאלי?', a: 'טיפ לא חובה אבל מקובל. מסעדות: 10-15% (לפעמים כבר כלול). מונית: עיגול כלפי מעלה. ספארי/סיורים: 20-50 AED לנהג/מדריך. מלון: 5-10 AED לסבל.' },
  { q: 'מה השעון בבאלי?', a: 'באלי נמצאת ב-GMT+4. ההפרש מישראל: בחורף = +2 שעות. בקיץ = +1 שעה. לדוגמה: אם בישראל 12:00, בבאלי 14:00 (חורף) או 13:00 (קיץ).' },
]

const topics = ['ויזה', 'בטיחות', 'מזג אוויר', 'תחבורה', 'כסף ומטבע', 'לבוש', 'אלכוהול', 'כשרות', 'ספארי', 'WiFi', 'חשמל', 'ביטוח', 'טיפים', 'שעון']

const relatedPages = [
  { href: '/weather', title: 'מזג אוויר', desc: 'מדריך עונות ומזג אוויר' },
  { href: '/kosher', title: 'כשר בבאלי', desc: 'מסעדות כשרות ומידע' },
  { href: '/plan', title: 'תכנון טיול', desc: 'כלי תכנון חכם' },
  { href: '/desert-safari', title: 'ספארי במדבר', desc: 'חוויה בלתי נשכחת' },
  { href: '/attractions', title: 'אטרקציות', desc: 'אטרקציות מובילות' },
  { href: '/contact', title: 'צור קשר', desc: 'נשמח לעזור!' },
]
---

<Layout
  title="שאלות ותשובות על באלי"
  description="כל השאלות והתשובות על טיול לבאלי: ויזה, בטיחות, מזג אוויר, תחבורה, כסף, כללי לבוש, אלכוהול, כשרות, טיפים ועוד. מדריך מקיף לתייר הישראלי."
  canonical="https://yalla-bali.co.il/faq"
>

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">שאלות <span class="text-teal-400">ותשובות</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">כל מה שרציתם לדעת על טיול לבאלי — ויזה, בטיחות, כסף, תחבורה, לבוש ועוד. {faqItems.length} שאלות עם תשובות מפורטות.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 -mt-6 relative z-20 mb-8">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-4 md:p-6">
      <h2 class="text-white font-bold mb-3">נושאים מכוסים:</h2>
      <div class="flex flex-wrap gap-2">
        {topics.map((topic) => (
          <span class="text-xs bg-teal-500/10 text-teal-400 px-3 py-1 rounded-full border border-teal-500/20">{topic}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <FAQSection items={faqItems} />
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-6 md:p-8 text-center">
      <span class="text-4xl block mb-4">❓</span>
      <h2 class="text-2xl font-bold text-white mb-3">עדיין יש שאלות?</h2>
      <p class="text-white/60 mb-6 max-w-md mx-auto">לא מצאתם את התשובה? שלחו לנו הודעה בווטסאפ ונחזור אליכם תוך דקות</p>
      <a href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, יש לי שאלה על טיול לבאלי')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all">📱 שאלו אותנו בווטסאפ</a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">עמודים <span class="text-teal-400">שימושיים</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {relatedPages.map((page) => (
        <a href={page.href} class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 hover:border-teal-500/30 rounded-xl p-4 text-center transition-all">
          <p class="text-white font-bold">{page.title}</p>
          <p class="text-white/50 text-sm">{page.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
