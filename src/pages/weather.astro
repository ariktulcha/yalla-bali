---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const months = [
  { month: 'ינואר', temp_high: 31, temp_low: 24, humidity: 75, rain_days: 12, sea_temp: 28, sunshine_hours: 7, recommendation: 'טוב — עונת גשמים, מחירים נמוכים' },
  { month: 'פברואר', temp_high: 31, temp_low: 24, humidity: 75, rain_days: 11, sea_temp: 28, sunshine_hours: 7, recommendation: 'טוב — עונת גשמים, פחות תורים' },
  { month: 'מרץ', temp_high: 31, temp_low: 24, humidity: 73, rain_days: 9, sea_temp: 29, sunshine_hours: 8, recommendation: 'טוב — סוף עונת גשמים, מזג אוויר נעים' },
  { month: 'אפריל', temp_high: 32, temp_low: 24, humidity: 70, rain_days: 6, sea_temp: 29, sunshine_hours: 9, recommendation: 'מצוין — בין־עונה אידיאלית, מחירים סבירים' },
  { month: 'מאי', temp_high: 32, temp_low: 23, humidity: 65, rain_days: 3, sea_temp: 28, sunshine_hours: 10, recommendation: 'מצוין — תחילת עונה יבשה, מזג נעים' },
  { month: 'יוני', temp_high: 31, temp_low: 21, humidity: 60, rain_days: 1, sea_temp: 27, sunshine_hours: 10, recommendation: 'מצוין — עונה יבשה, טמפ׳ נוחה, מעט גשם' },
  { month: 'יולי', temp_high: 30, temp_low: 20, humidity: 60, rain_days: 0, sea_temp: 27, sunshine_hours: 10, recommendation: 'מצוין — הכי יבש והכי קר, מושלם' },
  { month: 'אוגוסט', temp_high: 31, temp_low: 20, humidity: 60, rain_days: 0, sea_temp: 27, sunshine_hours: 10, recommendation: 'מצוין — עונה יבשה, שמש קבועה' },
  { month: 'ספטמבר', temp_high: 32, temp_low: 22, humidity: 62, rain_days: 1, sea_temp: 28, sunshine_hours: 9, recommendation: 'מצוין — סוף עונה יבשה, טוב מאוד' },
  { month: 'אוקטובר', temp_high: 32, temp_low: 23, humidity: 68, rain_days: 4, sea_temp: 29, sunshine_hours: 8, recommendation: 'מצוין — בין־עונה, מעברים לגשומים' },
  { month: 'נובמבר', temp_high: 32, temp_low: 24, humidity: 72, rain_days: 8, sea_temp: 29, sunshine_hours: 7, recommendation: 'טוב — תחילת עונת גשמים, מחירים עולים' },
  { month: 'דצמבר', temp_high: 31, temp_low: 24, humidity: 75, rain_days: 11, sea_temp: 28, sunshine_hours: 7, recommendation: 'טוב — עונת גשמים, עונת השיא תיירים' },
]

function getTempColor(temp: number) {
  if (temp >= 40) return 'text-red-400'
  if (temp >= 35) return 'text-orange-400'
  if (temp >= 30) return 'text-teal-400'
  return 'text-green-400'
}

function getRecBadge(rec: string) {
  if (rec.startsWith('מצוין')) return 'bg-green-500/20 text-green-400 border-green-500/30'
  if (rec.startsWith('טוב')) return 'bg-teal-500/20 text-teal-400 border-teal-500/30'
  return 'bg-red-500/20 text-red-400 border-red-500/30'
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'מזג אוויר בבאלי - מדריך עונות ומזג אוויר',
  description: 'מדריך מפורט למזג האוויר בבאלי לפי חודשים. טמפרטורות, לחות, ימי גשם, והזמן הטוב ביותר לביקור.',
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali', url: 'https://yalla-bali.co.il' },
  mainEntityOfPage: 'https://yalla-bali.co.il/weather',
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-03-01',
}
---

<Layout
  title="מזג אוויר בבאלי - מדריך עונות ומזג אוויר"
  description="מדריך מפורט למזג האוויר בבאלי לפי חודשים. טמפרטורות, לחות, ימי גשם, והזמן הטוב ביותר לביקור. טיפים לאריזת מזוודה וביגוד מומלץ לכל עונה."
  canonical="https://yalla-bali.co.il/weather"
>
  <SchemaOrg schema={articleSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">מזג אוויר <span class="text-teal-400">בבאלי</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">מדריך מפורט למזג האוויר בבאלי לפי חודשים. דעו מה לצפות, מה ללבוש ומתי הזמן הכי טוב לטוס.</p>
    </div>
  </section>

  <!-- Best Time Overview -->
  <section class="max-w-6xl mx-auto px-4 -mt-8 relative z-20 mb-12">
    <div class="grid md:grid-cols-3 gap-4">
      <div class="bg-gradient-to-br from-green-900/30 to-[#1A1208] border border-green-500/20 rounded-2xl p-6 text-center">
        <span class="text-3xl block mb-3">☀️</span>
        <h3 class="text-lg font-bold text-white mb-1">עונה יבשה (הטובה ביותר)</h3>
        <p class="text-green-400 font-bold text-xl mb-2">מאי - ספטמבר</p>
        <p class="text-white/60 text-sm">מזג אוויר מושלם, 30-32 מעלות, אפס גשם כמעט. הזמן הכי פופולרי ומומלץ — מחירים גבוהים.</p>
      </div>
      <div class="bg-gradient-to-br from-teal-900/30 to-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
        <span class="text-3xl block mb-3">🌡️</span>
        <h3 class="text-lg font-bold text-white mb-1">עונות בין־ים (טובות)</h3>
        <p class="text-teal-400 font-bold text-xl mb-2">אפריל, אוקטובר</p>
        <p class="text-white/60 text-sm">מזג נעים, 32 מעלות, גשם מעט. פשרה בין מחירים למזג — אופציה מעולה.</p>
      </div>
      <div class="bg-gradient-to-br from-blue-900/30 to-[#1A1208] border border-blue-500/20 rounded-2xl p-6 text-center">
        <span class="text-3xl block mb-3">💧</span>
        <h3 class="text-lg font-bold text-white mb-1">עונה גשומה (ערעור)</h3>
        <p class="text-blue-400 font-bold text-xl mb-2">נובמבר - מרץ</p>
        <p class="text-white/60 text-sm">גשומה אבל לא קפואה. 31 מעלות, מחירים נמוכים ברור. פעילויות פנים קל.</p>
      </div>
    </div>
  </section>

  <!-- Monthly Data -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">מזג אוויר <span class="text-teal-400">לפי חודשים</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">טבלה מפורטת עם טמפרטורות, לחות, ימי גשם וטמפרטורת ים לכל חודש</p>

    <!-- Desktop Table -->
    <div class="hidden lg:block overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-teal-500/20">
            <th class="text-right py-4 px-4 text-teal-400 font-bold">חודש</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">מקסימום</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">מינימום</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">לחות</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">ימי גשם</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">טמפ' ים</th>
            <th class="text-center py-4 px-3 text-teal-400 font-bold">שעות שמש</th>
            <th class="text-right py-4 px-4 text-teal-400 font-bold">המלצה</th>
          </tr>
        </thead>
        <tbody>
          {months.map((m) => (
            <tr class="border-b border-white/5 hover:bg-[#1A1208]/30 transition-colors">
              <td class="py-4 px-4 font-bold text-white">{m.month}</td>
              <td class={`py-4 px-3 text-center font-bold ${getTempColor(m.temp_high)}`}>{m.temp_high}°C</td>
              <td class="py-4 px-3 text-center text-white/70">{m.temp_low}°C</td>
              <td class="py-4 px-3 text-center text-white/70">{m.humidity}%</td>
              <td class="py-4 px-3 text-center text-white/70">{m.rain_days}</td>
              <td class="py-4 px-3 text-center text-blue-400">{m.sea_temp}°C</td>
              <td class="py-4 px-3 text-center text-white/70">{m.sunshine_hours}</td>
              <td class="py-4 px-4">
                <span class={`text-xs font-medium px-3 py-1 rounded-full border ${getRecBadge(m.recommendation)}`}>
                  {m.recommendation.split(' — ')[0]}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile Cards -->
    <div class="lg:hidden grid sm:grid-cols-2 gap-4">
      {months.map((m) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-xl font-bold text-white">{m.month}</h3>
            <span class={`text-xs font-medium px-3 py-1 rounded-full border ${getRecBadge(m.recommendation)}`}>
              {m.recommendation.split(' — ')[0]}
            </span>
          </div>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="flex items-center gap-2"><span class="text-teal-400">🌡️</span><span class="text-white/60">מקסימום:</span><span class={`font-bold ${getTempColor(m.temp_high)}`}>{m.temp_high}°C</span></div>
            <div class="flex items-center gap-2"><span class="text-blue-400">🌡️</span><span class="text-white/60">מינימום:</span><span class="text-white font-bold">{m.temp_low}°C</span></div>
            <div class="flex items-center gap-2"><span>💧</span><span class="text-white/60">לחות:</span><span class="text-white">{m.humidity}%</span></div>
            <div class="flex items-center gap-2"><span>🌧️</span><span class="text-white/60">ימי גשם:</span><span class="text-white">{m.rain_days}</span></div>
            <div class="flex items-center gap-2"><span>🌊</span><span class="text-white/60">ים:</span><span class="text-blue-400">{m.sea_temp}°C</span></div>
            <div class="flex items-center gap-2"><span>☀️</span><span class="text-white/60">שמש:</span><span class="text-white">{m.sunshine_hours} שעות</span></div>
          </div>
          <p class="text-white/50 text-sm mt-3">{m.recommendation}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Best Time Detail -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">מתי הכי טוב <span class="text-teal-400">לטוס לבאלי?</span></h2>
    <div class="space-y-8">
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-green-500/20 rounded-2xl p-6 md:p-8">
        <h3 class="text-2xl font-bold text-green-400 mb-4">מאי עד ספטמבר — העונה המושלמת</h3>
        <p class="text-white/70 leading-relaxed mb-4">זו העונה הכי פופולרית בבאלי ובכל הסיבה. הטמפרטורות נעות בין 30-32 מעלות, מזג האוויר יבש לחלוטין (כמעט אפס גשם), ושמש תוך כל יום. זה הזמן המושלם לטיולים בהרים, טרקים לפסגות, טיולי טבע, סיורים בטמפלים וספארי, ופעילויות חוץ מכל סוג.</p>
        <p class="text-white/50 text-sm">שימו לב: זו עונת השיא ולכן מחירי מלונות וטיסות הם הגבוהים ביותר בבאלי. מומלץ להזמין טיולים ומלונות מראש.</p>
      </div>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-6 md:p-8">
        <h3 class="text-2xl font-bold text-teal-400 mb-4">אפריל ואוקטובר — עונות בין־ים (טובות)</h3>
        <p class="text-white/70 leading-relaxed mb-4">חודשים אלה מציעים פשרה טובה בין מזג אוויר נעים למחירים סבירים. הטמפרטורות סביב 32 מעלות — חם אבל מעולה. גשם מעט (3-6 ימים בחודש) אבל לא קובע.</p>
        <p class="text-white/70 leading-relaxed">באפריל ובאוקטובר תמצאו מחירי מלונות נמוכים ב-25-35% בהשוואה לעונת היובשה, פחות תורים בטיולים, אבל עדיין מזג אוויר מעולה לטיולים, טרקים בהרים, וטיולי טבע.</p>
      </div>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-green-500/20 rounded-2xl p-6 md:p-8">
        <h3 class="text-2xl font-bold text-green-400 mb-4">יוני עד ספטמבר — עונה יבשה עם פחות תיירים</h3>
        <p class="text-white/70 leading-relaxed mb-4">יולי-אוגוסט הם החודשים היבשים והנוחים ביותר בבאלי — טמפ׳ 30-31°C, אפס גשם כמעט, אבל תיירים רבים. יוני וספטמבר הם קצת יותר יבשים מאפריל אוקטובר, עם מעט גשם (0-1 יום בחודש). טוב לטיולים, טרקים בהרים, וטיולי טבע.</p>
        <p class="text-white/70 leading-relaxed">יוני וספטמבר מציעים את הפשרה הטובה ביותר — עדיין יבש (טוב לטיולים), פחות תיירים, ומחירים נמוכים יותר מיולי-אוגוסט. מומלץ לטיול טבע וטרקים בחודשים אלה.</p>
      </div>
    </div>
  </section>

  <!-- Packing Tips -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">טיפים <span class="text-teal-400">לאריזת מזוודה</span></h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">👕 ביגוד</h3>
        <ul class="space-y-3 text-white/70">
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>בגדים קלים ונוחים מבדים נושמים — חובה בכל עונה</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>שכבה חמה לערבים (נובמבר-מרץ) — מיזוג בקניונים חזק</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>ביגוד צנוע לביקור במסגדים — כתפיים וברכיים מכוסים</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>בגד ים — בהחלט כן, גם בחורף</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>בגדים אלגנטיים למסעדות יוקרתיות וברים</span></li>
        </ul>
      </div>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">🧳 ציוד חיוני</h3>
        <ul class="space-y-3 text-white/70">
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>קרם הגנה SPF50+ — השמש בבאלי חזקה מאוד גם בחורף</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>משקפי שמש איכותיות</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>כובע רחב שוליים — חובה לפעילויות חוץ</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>נעליים נוחות להליכה — הקניונים ענקיים</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>בקבוק מים רב-פעמי</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span>מטען נייד (Power Bank)</span></li>
        </ul>
      </div>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">⛱️ טיפים לעונות ספציפיות</h3>
        <ul class="space-y-3 text-white/70">
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span><strong class="text-white">עונה גשומה (נוב-מרץ):</strong> קחו גשם בחום — טשרט קל, לא ז'קט. 24 מעלות בלילה</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span><strong class="text-white">עונה יבשה (מאי-ספט):</strong> בגדים קלים מאוד, כובע, משקפיים, וקרם שמש חזק</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span><strong class="text-white">קיץ (יוני-ספט):</strong> הימנעו מפעילויות חוץ בשעות 11:00-16:00</span></li>
          <li class="flex items-start gap-2"><span class="text-teal-400 mt-1">&#8226;</span><span><strong class="text-white">רמדאן:</strong> בתקופת הרמדאן אין לאכול, לשתות או לעשן ברחוב בשעות היום</span></li>
        </ul>
      </div>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6">
        <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">☀️ טיפ חשוב מאיתנו</h3>
        <p class="text-white/70 leading-relaxed mb-4">לא משנה מתי תטוסו — באלי תמיד מרהיבה. בעונה יבשה תיהנו ממזג אוויר מושלם לטיולים ופעילויות חוץ. בעונה גשומה תיהנו ממחירים מצוינים וטבע רטוב יותר.</p>
        <p class="text-white/70 leading-relaxed">בכל עונה יש טיולים בהרים, טרקים לפסגות (בטוב בעונה יבשה), וסיורים בטמפלים (פעילויות מקורות טובות גם בגשום). מומלץ להזמין טיולים ומלונות מראש בעיקר בעונה יבשה (מאי-ספטמבר).</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
