---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import FAQSection from '../components/FAQSection.astro'

const planSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'תכנון טיול לבאלי — מסלולים מומלצים לישראלים',
  description: 'מדריך תכנון מלא לבאלי עם מסלולים מומלצים לפי מספר ימים וסגנון טיול, תקציב, עצות מקצועיות וכל מה שצריך לדעת לפני הטיסה',
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali', url: 'https://ibalibali.com' },
  datePublished: '2025-01-01',
  dateModified: '2026-04-06',
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'תכנון טיול לבאלי' },
]

const faqItems = [
  {
    q: 'מתי הכי כדאי לטוס לבאלי?',
    a: 'העונה היבשה בבאלי (מאי–ספטמבר) היא הזמן הכי טוב — שמש, ים שקט, גלים מושלמים וטמפרטורות של 27–30 מעלות. העונה הגשומה (נובמבר–מרץ) זולה יותר אבל צפויים גשמים יומיים של שעה-שעתיים. אפריל ואוקטובר הם חודשי מעבר מצוינים: פחות תיירים, מחירים נמוכים, ומזג אוויר סביר.',
  },
  {
    q: 'כמה ימים כדאי לתכנן לטיול בבאלי?',
    a: 'לטיול ראשון בבאלי, 7 ימים זה אידיאלי — מספיק לקאנגו, אובוד, נוסה פניידה ואולוואטו. אם יש לכם 10 ימים, תוכלו להוסיף טרק להר בטור וצלילה באמד. ל-5 ימים תתמקדו בנקודות השיא בלבד. מעל 14 יום — תספיקו גם את צפון באלי, לומבוק וחיי nomad.',
  },
  {
    q: 'כמה עולה טיול לבאלי לזוג ישראלי?',
    a: 'תקציב יומי לזוג בבאלי נע בין 200-300 שקלים (תרמיל) ל-900+ שקלים (יוקרה). שבוע מאוזן לזוג — כ-3,500–5,000 שקלים לא כולל טיסות. טיסות מישראל עולות בדרך כלל 2,500–4,500 שקלים לאדם (עם עצירה). ויזה eVOA עולה כ-185 שקלים.',
  },
  {
    q: 'כמה זמן לוקח להגיע מנמל התעופה בבאלי לקאנגו?',
    a: 'מנמל התעופה נגוראה ראי לקאנגו לוקח כשעה–שעה וחצי בתנועה רגילה. Grab (האובר המקומי) עולה 70–100 שקלים. אפשר גם להזמין נהג פרטי דרך המלון. הימנעו מטקסי מטר בנמל — המחירים מנופחים.',
  },
  {
    q: 'האם צריך ויזה לבאלי לישראלים?',
    a: 'כן, ישראלים חייבים ויזה לבאלי. הדרך הקלה ביותר: eVOA (ויזה אלקטרונית) שמגישים אונליין 3–5 ימים לפני הטיסה. העלות כ-185 שקלים. אפשר גם להנפיק VOA בנמל התעופה אבל צפויים תורים ארוכים.',
  },
  {
    q: 'מה ההבדל בין קאנגו לאובוד לאולוואטו בבאלי?',
    a: 'קאנגו הוא מרכז הגולשים, חיי הלילה וה-digital nomads — אווירה צעירה ותוססת. אובוד הוא הלב התרבותי — שדות אורז, יוגה, מקדשים ואמנות. אולוואטו הוא הצד הדרמטי — צוקים מרשימים, גלים אגרסיביים ושקיעות מהיפות בעולם. רוב המטיילים משלבים את שלושתם.',
  },
  {
    q: 'האם באלי מתאימה למשפחות עם ילדים?',
    a: 'בהחלט! באלי מצוינת למשפחות. נוסה דואה מציעה חופים שקטים עם מים רדודים, אובוד מושלמת לפעילויות תרבותיות, ויש אטרקציות כמו Bali Safari Park ו-Waterbom Park. מומלץ להזמין נהג פרטי ליום (200–300 שקלים) במקום Grab עם ילדים.',
  },
  {
    q: 'מה חובה לארוז לטיול לבאלי?',
    a: 'הדברים החשובים ביותר: קרם הגנה חזק (SPF50), כובע ומשקפי שמש, בגדי ים, נעליים סגורות לטרקים, ביגוד צנוע לכניסה למקדשים (סארונג אפשר לקנות במקום), מתאם חשמל (שקע אירופאי Type C), ותרופות בסיסיות כולל נוגד שלשולים.',
  },
]
---
<Layout
  title="תכנון טיול לבאלי — מסלולים, תקציב ועצות | יאללה באלי"
  description="תכננו את הטיול המושלם לבאלי: מסלולים מומלצים ל-5, 7, 10 ו-14 ימים, אומדן תקציב לזוג, עצות מקצועיות לישראלים, ומה לארוז."
>
  <SchemaOrg schema={planSchema} />
<main dir="rtl" class="max-w-5xl mx-auto px-4 py-12">

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero -->
  <div class="text-center mb-16">
    <div class="text-6xl mb-4">🌴</div>
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">תכנון טיול לבאלי</h1>
    <p class="text-white/70 text-base sm:text-lg md:text-xl max-w-2xl mx-auto">כמה ימים יש לכם? בוחרים סגנון, ומקבלים מסלול מושלם לבאלי עם כל מה שצריך — יום אחרי יום</p>
  </div>

  <!-- Duration picker -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">כמה זמן אתם בבאלי?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { days: '5 ימים', emoji: '⚡', desc: 'נקודות השיא', id: '5' },
        { days: '7 ימים', emoji: '🌊', desc: 'שבוע מושלם', id: '7' },
        { days: '10 ימים', emoji: '🏄', desc: 'להכיר לעומק', id: '10' },
        { days: '14+ ימים', emoji: '🧘', desc: 'חיים בבאלי', id: '14' },
      ].map(t => (
        <button
          data-days={t.id}
          class="duration-btn bg-[#1A1208] rounded-xl p-6 text-center cursor-pointer hover:border-teal-500 border border-teal-500/10 hover:bg-teal-500/5 transition-all text-white"
        >
          <div class="text-4xl mb-3">{t.emoji}</div>
          <div class="font-bold text-lg">{t.days}</div>
          <div class="text-white/60 text-sm mt-1">{t.desc}</div>
        </button>
      ))}
    </div>
  </section>

  <!-- Traveler type -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">מה סגנון הטיול שלכם בבאלי?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {[
        { type: '🏄 גלישה', desc: 'גלים, חוף, קאנגו', id: 'surf' },
        { type: '🧘 ריטריט', desc: 'יוגה, מדיטציה, אובוד', id: 'retreat' },
        { type: '🎉 מסיבות', desc: 'קוטה, חיי לילה, ברים', id: 'party' },
        { type: '🏛️ תרבות', desc: 'מקדשים, אמנות, היסטוריה', id: 'culture' },
        { type: '🤿 הרפתקה', desc: 'צלילה, מפלים, הר געש', id: 'adventure' },
        { type: '👨‍👩‍👧 משפחות', desc: 'נוח, בטוח, מושלם לילדים', id: 'family' },
      ].map(t => (
        <button
          data-style={t.id}
          class="style-btn bg-[#1A1208] rounded-xl p-5 cursor-pointer hover:bg-teal-500/5 border border-teal-500/10 hover:border-teal-500 transition-all text-white text-right"
        >
          <div class="text-2xl mb-2">{t.type}</div>
          <div class="text-white/60 text-sm">{t.desc}</div>
        </button>
      ))}
    </div>
    <!-- Style-specific tips (shown dynamically) -->
    <div id="style-tips" class="hidden mt-6 bg-[#1A1208] rounded-2xl p-6 border border-teal-500/20 transition-all">
      <div id="style-tip-content"></div>
    </div>
  </section>

  <!-- Pre-built itineraries -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-8 text-center">מסלולים מומלצים לטיול בבאלי</h2>

    <!-- 5-day itinerary -->
    <div data-itinerary="5" class="itinerary-card hidden bg-[#1A1208] rounded-2xl p-8 mb-6 border border-teal-500/10 hover:border-teal-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">⚡</div>
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 5 ימים בבאלי — נקודות השיא</h3>
          <p class="text-white/60 text-sm">מסלול אינטנסיבי שמכסה את הנקודות הכי שוות בבאלי</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'נחיתה + קאנגו', emoji: '✈️', note: 'הגעה בבוקר, צ\'ק-אין בווילה, מנוחה, ערב ב<a href="/areas/canggu" class="text-teal-400 hover:underline">חופי קאנגו</a>' },
          { day: 'יום 2', place: 'קאנגו — גלישה וחופים', emoji: '🏄', note: 'שיעור גלישה בבוקר ב-<a href="/beaches" class="text-teal-400 hover:underline">Padang Padang Beach</a>, צהריים בשוק, sunset bar בערב' },
          { day: 'יום 3', place: 'אובוד — שדות אורז ומקדשים', emoji: '🌾', note: '<a href="/areas/ubud" class="text-teal-400 hover:underline">Tegallalang Rice Terraces</a>, מקדשים, ערב חזרה לקאנגו' },
          { day: 'יום 4', place: 'נוסה פניידה — יום שלם', emoji: '🏝️', note: 'Day trip ל-<a href="/areas/nusa-penida" class="text-teal-400 hover:underline">נוסה פניידה</a>: Kelingking Beach, Broken Beach, צלילה' },
          { day: 'יום 5', place: 'צ\'ק-אאוט ונמל תעופה', emoji: '✈️', note: 'ארוחת בוקר, קניות אחרונות, טיסה חזרה' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="text-2xl w-8 flex-shrink-0">{d.emoji}</div>
            <div class="flex-1 border-r-2 border-teal-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} — {d.place}</div>
              <div class="text-white/70 text-sm mt-1" set:html={d.note} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 7-day itinerary -->
    <div data-itinerary="7" class="itinerary-card hidden bg-[#1A1208] rounded-2xl p-8 mb-6 border border-teal-500/10 hover:border-teal-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">🌊</div>
        <div>
          <h3 class="text-xl font-bold text-white">מסלול שבוע בבאלי — הכי פופולרי</h3>
          <p class="text-white/60 text-sm">7 ימים — המסלול הקלאסי והכי מומלץ לישראלים בבאלי</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'נחיתה + קאנגו', emoji: '✈️', note: 'הגעה, צ\'ק-אין בווילה או בוטיק, מסאג\' ראשון, ערב ב<a href="/areas/canggu" class="text-teal-400 hover:underline">קאנגו</a>' },
          { day: 'ימים 2–3', place: 'קאנגו — גלישה וחוף', emoji: '🏄', note: 'שיעורי גלישה, <a href="/beaches" class="text-teal-400 hover:underline">Padang Padang Beach</a>, קפה מקומי, <a href="/nightlife" class="text-teal-400 hover:underline">חיי לילה בקאנגו</a>' },
          { day: 'יום 4', place: 'אובוד — תרבות בלינזית', emoji: '🌾', note: '<a href="/areas/ubud" class="text-teal-400 hover:underline">שדות אורז Tegallalang</a>, Goa Gajah (מערת הפיל), שוק אובוד' },
          { day: 'יום 5', place: 'נוסה פניידה — יום מלא', emoji: '🏝️', note: 'Day trip ל-<a href="/areas/nusa-penida" class="text-teal-400 hover:underline">נוסה פניידה</a>: Kelingking Beach, Angel Billabong, Broken Beach + צלילה' },
          { day: 'יום 6', place: 'אולוואטו — שקיעה בצוקים', emoji: '🌅', note: '<a href="/areas/uluwatu" class="text-teal-400 hover:underline">מקדש אולוואטו</a>, ריקוד Kecak ב-18:30, ארוחת פירות ים בשקיעה' },
          { day: 'יום 7', place: 'צ\'ק-אאוט ונמל תעופה', emoji: '✈️', note: 'בוקר חופשי, קניות אחרונות, נמל תעופה' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="text-2xl w-8 flex-shrink-0">{d.emoji}</div>
            <div class="flex-1 border-r-2 border-teal-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} — {d.place}</div>
              <div class="text-white/70 text-sm mt-1" set:html={d.note} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 10-day itinerary -->
    <div data-itinerary="10" class="itinerary-card hidden bg-[#1A1208] rounded-2xl p-8 mb-6 border border-teal-500/10 hover:border-teal-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">🏄</div>
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 10 ימים בבאלי — להכיר לעומק</h3>
          <p class="text-white/60 text-sm">צלילה, טרקים בהרים, תרבות, ונוסה פניידה — חוויה מלאה</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'יום 1', place: 'נחיתה + קאנגו', emoji: '✈️', note: 'הגעה, צ\'ק-אין, מנוחה מהטיסה, ערב ב<a href="/areas/canggu" class="text-teal-400 hover:underline">קאנגו</a>' },
          { day: 'ימים 2–3', place: 'קאנגו — גלישה וחוף', emoji: '🏄', note: 'שיעורי גלישה, <a href="/beaches" class="text-teal-400 hover:underline">חופי באלי</a>, קפה מקומי, <a href="/nightlife" class="text-teal-400 hover:underline">Ku De Ta בערב</a>' },
          { day: 'ימים 4–5', place: 'אובוד — ריטריט ותרבות', emoji: '🌾', note: '<a href="/areas/ubud" class="text-teal-400 hover:underline">שדות אורז Tegallalang</a>, סדנת בישול בלינזית, יוגה, Monkey Forest, מקדש בערב' },
          { day: 'יום 6', place: 'הר בטור — Sunrise Trek', emoji: '🌋', note: 'יציאה בחצות, טרק להר בטור, זריחה מהפסגה, ארוחת בוקר בכפר בדרך חזרה' },
          { day: 'יום 7', place: 'נוסה פניידה — יום מלא', emoji: '🏝️', note: 'Day trip ל-<a href="/areas/nusa-penida" class="text-teal-400 hover:underline">נוסה פניידה</a>: Kelingking, Angel Billabong, Broken Beach + צלילה (2 dives)' },
          { day: 'יום 8', place: 'אמד — צלילה', emoji: '🤿', note: 'USAT Liberty Wreck Dive, שונית אמד, יום רגוע על החוף' },
          { day: 'יום 9', place: 'אולוואטו — ערב מלכותי', emoji: '🌅', note: '<a href="/areas/uluwatu" class="text-teal-400 hover:underline">מקדש אולוואטו</a>, ריקוד Kecak Fire Dance, ארוחת פירות ים בשקיעה' },
          { day: 'יום 10', place: 'צ\'ק-אאוט ונמל תעופה', emoji: '✈️', note: 'בוקר חופשי, קניות אחרונות, טיסה חזרה' },
        ].map(d => (
          <div class="flex gap-4 items-start">
            <div class="text-2xl w-8 flex-shrink-0">{d.emoji}</div>
            <div class="flex-1 border-r-2 border-teal-500 pr-4">
              <div class="font-bold text-white text-sm">{d.day} — {d.place}</div>
              <div class="text-white/70 text-sm mt-1" set:html={d.note} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 14+ day itinerary -->
    <div data-itinerary="14" class="itinerary-card hidden bg-[#1A1208] rounded-2xl p-8 border border-teal-500/10 hover:border-teal-500/30 transition-all">
      <div class="flex items-center gap-3 mb-6">
        <div class="text-3xl">🧘</div>
        <div>
          <h3 class="text-xl font-bold text-white">מסלול 14+ ימים בבאלי — כמו מקומיים</h3>
          <p class="text-white/60 text-sm">וילות חודשיות, קהילה ישראלית, מסלולים שלא בגלויות</p>
        </div>
      </div>
      <div class="space-y-4">
        {[
          { day: 'ימים 1–3', place: 'קאנגו — התבססות', emoji: '🏄', note: 'צ\'ק-אין בווילה או co-living ב<a href="/areas/canggu" class="text-teal-400 hover:underline">קאנגו</a>, מציאת הריטמו, קפה, קהילה ישראלית' },
          { day: 'ימים 4–6', place: 'אובוד — ריטריט שבועי', emoji: '🌾', note: 'ריטריט יוגה ב<a href="/areas/ubud" class="text-teal-400 hover:underline">אובוד</a>, סדנת מדיטציה, סדנת בישול בלינזית' },
          { day: 'יום 7', place: 'הר בטור + מקדש Bratan', emoji: '🌋', note: 'Sunrise trek, Bedugul, מקדש על האגם, חוות תותים' },
          { day: 'ימים 8–9', place: 'צפון באלי — רגיעה', emoji: '🌿', note: 'Lovina, Singaraja, מעיינות חמים, <a href="/attractions" class="text-teal-400 hover:underline">מפלים</a>, חיי לילה רגועים' },
          { day: 'יום 10', place: 'אמד — צלילה מתקדמת', emoji: '🤿', note: 'Advanced diving, Japanese Garden, drift diving — לבעלי תעודת Open Water' },
          { day: 'יום 11', place: 'לומבוק — טיול יומי', emoji: '🏝️', note: 'איי גילי, צלילה, חוף לבן — סירה מ-Padang Bai' },
          { day: 'יום 12', place: 'אולוואטו', emoji: '🌅', note: '<a href="/areas/uluwatu" class="text-teal-400 hover:underline">מקדש אולוואטו</a>, ריקוד Kecak, infinity pool clubs' },
