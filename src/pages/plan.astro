<script>
  document.addEventListener('DOMContentLoaded', () => {
    const durationBtns = document.querySelectorAll('.duration-btn');
    const styleBtns = document.querySelectorAll('.style-btn');
    const itineraryCards = document.querySelectorAll('.itinerary-card');
    const placeholder = document.getElementById('itinerary-placeholder');
    const styleTips = document.getElementById('style-tips');
    const styleTipContent = document.getElementById('style-tip-content');

    let selectedDays = null;

    const styleData = {
      surf: {
        title: '🏄 טיפים לגולשים בבאלי',
        tips: [
          'קאנגו (Brawah, Echo Beach) — הספוט המרכזי, גלים כל יום',
          'Padang Padang ו-Uluwatu — גלים מתקדמים, tube rides',
          'שיעור גלישה ראשון: 150,000–200,000 רופיה (40–55 ₪) כולל ציוד',
          'עונת הגלים הטובה: מאי–ספטמבר (יבשה, גלים גדולים)',
          'השכרת סרפבורד: 50,000 רופיה ליום',
        ],
      },
      retreat: {
        title: '🧘 טיפים לריטריט ויוגה בבאלי',
        tips: [
          'אובוד — הלב של תרבות היוגה בבאלי, עשרות סטודיואים',
          'ריטריט יוגה שבועי: 2,000–5,000 ₪ כולל לינה וארוחות',
          'Yoga Barn באובוד — המקום האיקוני, שיעורים מ-80,000 רופיה',
          'שלבו ספא בלינזי (100–200 ₪ לטיפול מלא) וסדנאות בישול',
          'אובוד + קאנגו = השילוב המושלם: רוחניות + חוף',
        ],
      },
      party: {
        title: '🎉 טיפים לחיי לילה בבאלי',
        tips: [
          'קאנגו — Old Man\'s, Finns Beach Club, La Brisa',
          'סמינייק — Potato Head, Ku De Ta, W Hotel',
          'Beach clubs: כניסה חינם, מינימום הזמנה 200,000–500,000 רופיה',
          'Happy hour ברוב המקומות: 16:00–18:00',
          'קוטה — Legian Street, פאבים, מחירים הכי זולים',
        ],
      },
      culture: {
        title: '🏛️ טיפים לטיול תרבותי בבאלי',
        tips: [
          'אובוד — מרכז האמנות, מקדשים, מוזיאונים, ריקודים מסורתיים',
          'מקדש Uluwatu — ריקוד Kecak בשקיעה (150,000 רופיה)',
          'Tirta Empul — מקדש המים הקדוש, טקס טיהור',
          'סארונג חובה בכניסה למקדשים (אפשר לקנות/לשכור במקום)',
          'Nyepi (יום הדממה) — חוויה ייחודית אם אתם בבאלי במרץ',
        ],
      },
      adventure: {
        title: '🤿 טיפים להרפתקנים בבאלי',
        tips: [
          'הר בטור — Sunrise Trek (יציאה בחצות, 300–500 ₪ כולל מדריך)',
          'צלילה באמד — USAT Liberty Wreck, מהספוטים הטובים בעולם',
          'נוסה פניידה — Manta Rays, Crystal Bay, צלילה מדהימה',
          'רפטינג בנהר Ayung (אובוד) — 200–350 ₪, חוויה של 2 שעות',
          'Canyoning ב-Gitgit — גלישה במפלים, רק למנוסים',
        ],
      },
      family: {
        title: '👨‍👩‍👧 טיפים למשפחות עם ילדים בבאלי',
        tips: [
          'נוסה דואה — חופים שקטים, מים רדודים, מלונות מותאמים',
          'Bali Safari & Marine Park — חוויה לכל המשפחה',
          'Waterbom Bali (קוטה) — פארק מים מדורג #1 באסיה',
          'נהג פרטי ליום (200–300 ₪) — נוח ובטוח עם ילדים',
          'הימנעו מקטנועים עם ילדים — השתמשו ב-Grab או נהג',
        ],
      },
    };

    function updateItinerary() {
      itineraryCards.forEach(card => card.classList.add('hidden'));
      if (selectedDays) {
        placeholder?.classList.add('hidden');
        const matchingCard = document.querySelector(`[data-itinerary="${selectedDays}"]`);
        if (matchingCard) matchingCard.classList.remove('hidden');
      } else {
        placeholder?.classList.remove('hidden');
      }
    }

    durationBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        durationBtns.forEach(b => {
          b.classList.remove('bg-teal-500/5', 'border-teal-500');
        });
        btn.classList.add('bg-teal-500/5', 'border-teal-500');
        selectedDays = btn.dataset.days;
        updateItinerary();
      });
    });

    styleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        styleBtns.forEach(b => {
          b.classList.remove('bg-teal-500/5', 'border-teal-500');
        });
        btn.classList.add('bg-teal-500/5', 'border-teal-500');

        const style = btn.dataset.style;
        const data = styleData[style];
        if (data && styleTips && styleTipContent) {
          styleTipContent.innerHTML = `
            <h3 class="text-lg font-bold text-white mb-4">${data.title}</h3>
            <ul class="space-y-2">
              ${data.tips.map(t => `<li class="text-white/70 text-sm flex gap-2"><span class="text-teal-400 flex-shrink-0">•</span> ${t}</li>`).join('')}
            </ul>
          `;
          styleTips.classList.remove('hidden');
        }
      });
    });
  });
</script>

</Layout>
