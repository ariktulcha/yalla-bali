---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import NightlifeCard from '../../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('nightlife')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('venue_type', 'beach-club')

const items = data || []

const pageTitle = "ביץ' קלאבים בבאלי | Yalla Bali"
const pageDescription = "ביץ' קלאבים מומלצים בבאלי. בריכות, מוזיקה, אוכל ואווירה — החוויה המושלמת ליום על החוף בבאלי."

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: "ביץ' קלאבים בבאלי",
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/nightlife/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: "ביץ' קלאבים" },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/nightlife/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/nightlife/bars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🍸 ברים</a>
      <a href="/nightlife/clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎵 מועדונים</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🏖️ ביץ׳ קלאב</span>
      <a href="/nightlife/rooftop/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌇 רופטופ</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">ביץ' קלאבים בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        ביץ' קלאבים הם חלק בלתי נפרד מהחוויה בבאלי. בריכות מפוארות, מוזיקה מדי-ג'יי,
        אוכל ושתייה על שפת הים — הנה המקומות שחייבים לבקר בהם.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <NightlifeCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            type={item.type}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו ביץ' קלאבים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — ביץ' קלאבים בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה כניסה לביץ' קלאב בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מחירי כניסה נעים בין $15-50, תלוי ביום ובמקום. רוב המקומות מציעים מינימום צריכה שכולל אוכל ושתייה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הביץ' קלאב הכי טוב בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">הבחירה תלויה בהעדפה שלכם — יש ביץ' קלאבים שקטים ואלגנטיים ויש כאלה עם מסיבות ומוזיקה חזקה. בדקו את הרשימה שלנו למציאת המתאים לכם.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם צריך להזמין מקום מראש?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מומלץ מאוד, במיוחד בסופי שבוע ובעונה (נובמבר-מרץ). הזמנה מראש מבטיחה לכם מקום ולפעמים גם מחיר טוב יותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה שעות פתיחה של ביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ביץ' קלאבים בבאלי בדרך כלל פתוחים מ-10:00 בבוקר עד שקיעה וחלק מהם ממשיכים כברים בלילה. ביץ' קלאבים בבאלי פתוחים בימים אמצע שבוע וסוף שבוע.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה סוגי בריכות בביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ביץ' קלאבים בבאלי מציעים בריכות אינסוף מחוממות, בריכות שחייה קטנות ובריכות עם אזורי יושיבה שקועים. ביץ' קלאבים בבאלי עם בריכות גדולות מעניקים חוויית ספא מלאה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה המזון בביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ביץ' קלאבים בבאלי מציעים מתכונים בינלאומיים: פיצה, פסטה, סלטים, פרי ים וקבב. ביץ' קלאבים בבאלי מומלצים מספקים מוקד גאורמה עם מתבחנים בשפים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש מוזיקה בביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, ביץ' קלאבים בבאלי מעסיקים דיג'יים אורחים וליבים שמגיעים מהשעה שקיעה. ביץ' קלאבים בבאלי עם מוזיקה כזו מעניקים אווירה דיסקוטקית על החוף.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה אזורים טובים לביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ביץ' קלאבים בבאלי נמצאים בעיקר בסמינייק, קאנגו וסנור. ביץ' קלאבים בסמינייק מציעים אווירה חיה ופופולרית, בעוד ב-סנור יותר רחוק ודרומי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה דרס קוד לביץ' קלאב בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">לביץ' קלאבים בבאלי קוד לבוש קז'ואלי — בגדי ים, כנדליים וטי-שירט בסדר. ביץ' קלאבים בבאלי יוקרתיים דורשים Smart Casual בערב.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה פעילויות בביץ' קלאבים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ביץ' קלאבים בבאלי מציעים שחייה, איור, נשמור בבריכה, טניס חולי וישיבה בשמש. ביץ' קלאבים בבאלי עם מרכזי כושר גם מציעים יוגה על החוף.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים המלצה לביץ' קלאב בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent("היי, אני מחפש ביץ' קלאב בבאלי 🏖️")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
