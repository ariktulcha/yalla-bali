---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { pickMetaDescription } from '../../lib/seo'
import { site, pageTitle as buildPageTitle } from '../../config/site'
import Layout from '../../components/Layout.astro'
import PhotoGallery from '../../components/PhotoGallery.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: venues } = await supabaseAdmin
    .from('nightlife')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (venues ?? []).map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }))
}

const { venue } = Astro.props

const venueType = venue.type ?? venue.metadata?.type
const openingHours = venue.opening_hours ?? venue.metadata?.opening_hours
const dressCode = venue.dress_code ?? venue.metadata?.dress_code
const address = venue.address ?? venue.metadata?.address
const priceRange = venue.price_range ?? venue.metadata?.price_range

let hoursArray: string[] = []
if (openingHours) {
  try {
    const parsed = typeof openingHours === 'string' ? JSON.parse(openingHours) : openingHours
    hoursArray = Array.isArray(parsed) ? parsed : [String(openingHours)]
  } catch {
    hoursArray = [String(openingHours)]
  }
}

const contentHtml = venue.full_content ? await marked(venue.full_content) : ''

const titlePrefix = `${venue.name_he}${venue.name_en ? ` — ${venue.name_en}` : ''}`
const pageTitle = venue.meta_title || buildPageTitle(titlePrefix, 'nightlife')
const pageDescription = venue.meta_description || pickMetaDescription(venue, `חיי לילה ב${site.destinationName}`)

const venueSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: venue.name_he,
  alternateName: venue.name_en || undefined,
  description: venue.description || venue.excerpt,
  image: venue.image ? (venue.image.startsWith('http') ? venue.image : new URL(venue.image, Astro.site).toString()) : undefined,
  url: new URL(`/nightlife/${venue.slug}`, Astro.site).toString(),
  ...(address ? { address: { '@type': 'PostalAddress', streetAddress: address } } : {}),
  ...(priceRange ? { priceRange } : {}),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: venue.name_he },
]

// Distance & pricing estimates by area
const areaDistancePricing: Record<string, { distance: string; grabPrice: string }> = {
  'סמינייק': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'seminyak': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'קאנגו': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'canggu': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'אובוד': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ubud': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ג\'ימברן': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'jimbaran': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'אולוואטו': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'uluwatu': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'נוסה דואה': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'nusa-dua': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'סנור': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'sanur': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'קוטה': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
  'kuta': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
}

const areaKey = (venue.area || '').toLowerCase()
const distancePricing = areaDistancePricing[areaKey] || { distance: '20-25 ק"מ', grabPrice: '₪70-100' }

// Related nightlife venues in same area
const { data: areaNightlife } = await supabaseAdmin
  .from('nightlife')
  .select('slug, name_he, description, image')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', venue.area)
  .neq('slug', venue.slug)
  .limit(3)

const relatedNightlife = areaNightlife ?? []

const dbFaq = Array.isArray(venue.faq) ? venue.faq : []
// If DB faq questions don't mention the venue name (handwritten "short" style),
// wrap them with an intro + outro Q&A that includes Name+באלי for SEO, keeping
// the handwritten tone intact in the middle.
const faqMentionsName = dbFaq.filter((it: any) => (it.q || '').includes(venue.name_he)).length
const needsEnrichment = faqMentionsName < 2 && dbFaq.length > 0
const faqIntro = needsEnrichment
  ? [{
      q: `מה כדאי לדעת על ${venue.name_he} בבאלי?`,
      a: venue.description || `${venue.name_he} הוא אחד המקומות המומלצים לחיי לילה בבאלי${venue.area ? ` ב${venue.area}` : ''}. מידע מפורט על שעות פתיחה, דרס קוד ותמחור ב${venue.name_he} מובא בשאלות הבאות.`,
    }]
  : []
const faqOutro = needsEnrichment
  ? [{
      q: `איך מזמינים שולחן או מגיעים ל${venue.name_he} בבאלי?`,
      a: `כדי להזמין שולחן או לקבל פרטים עדכניים על ${venue.name_he}, מומלץ לפנות ישירות למקום דרך הרשתות החברתיות שלו. נהג מקומי או Grab ייקח אתכם ישירות ל${venue.name_he} — זמן הנסיעה תלוי באזור ההתחלה בבאלי.`,
    }]
  : []
const faqItems = dbFaq.length > 0
  ? [...faqIntro, ...dbFaq.map((item: any) => ({ q: item.q, a: item.a })), ...faqOutro]
  : [
      {
        q: `מה גיל הכניסה ל${venue.name_he} בבאלי?`,
        a: `בבאלי, גיל הכניסה הרשמי לרוב המקומות הוא 18, אך חלק מהמקומות הסלקטיביים יותר דורשים 21+. בדקו את דרישות הגיל של ${venue.name_he} מראש. אנחנו ממליצים להביא תעודת זהות תקפה בכל מקרה.`,
      },
      {
        q: `האם ${venue.name_he} דורש הזמנה מראש?`,
        a: `זה תלוי בלילה ובגודל הקבוצה. בימי שישי ושבת מומלץ להזמין שולחן ב${venue.name_he} מראש. אם אתם קבוצה קטנה, בדרך כלל תוכלו להיכנס בלי הזמנה. כדי להזמין שולחן, פנו ישירות למקום דרך הרשתות החברתיות שלו.`,
      },
      {
        q: `מה קוד הלבוש ב${venue.name_he}?`,
        a: `${dressCode ? `קוד הלבוש ב${venue.name_he} הוא: ${dressCode}. ` : ''}בדרך כלל מקומות חיי לילה בבאלי דורשים smart-casual: לא טנקטופ או שורטס במקומות סטנדרטיים. ביץ' קלאבים ובארי חוף יותר רגועים בקוד הלבוש.`,
      },
      {
        q: `כמה עולה שתייה ב${venue.name_he} בבאלי?`,
        a: `${priceRange ? `טווח המחירים ב${venue.name_he} הוא: ${priceRange}. ` : ''}בבאלי, שתייה בחיי הלילה הרבה פחות יקרה מאשר בחו"ל. משקה בודד ב${venue.name_he} בדרך כלל עולה בין ₪20-₪60 בהתאם לסוג המשקה ומיקום המקום.`,
      },
    ]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://ibalibali.com/nightlife/${venue.slug}`}
  ogImage={venue.image}
  ogType="article"
  schema={venueSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mb-8">
      <PhotoGallery
        mainImage={venue.image}
        galleryUrls={venue.gallery_urls || []}
        name={venue.name_he}
      />
    </div>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{venue.name_he}</h1>
      {venue.name_en && (
        <p class="text-lg text-white/50">{venue.name_en}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
      {venue.area && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {venue.area}
        </span>
      )}
      {venueType && (
        <span class="text-sm px-3 py-1 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20">
          {venueType}
        </span>
      )}
      {priceRange && (
        <span class="text-teal-400 font-medium">{priceRange}</span>
      )}
    </div>

    {venue.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-white/80 leading-relaxed">{venue.description}</p>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      {hoursArray.length > 0 && (
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6">
          <h2 class="text-lg font-bold text-teal-400 mb-3">שעות פתיחה — {venue.name_he}</h2>
          {hoursArray.map((h) => (
            <p class="text-white/70">{h}</p>
          ))}
        </div>
      )}
      {dressCode && (
        <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6">
          <h2 class="text-lg font-bold text-teal-400 mb-3">דרס קוד ב{venue.name_he}</h2>
          <p class="text-white/70">{dressCode}</p>
        </div>
      )}
    </div>

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">כיצד מגיעים ל{venue.name_he}? 🚕</h2>
      <div class="space-y-4 text-white/70">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
          <div>
            <p class="font-medium text-white">מנמל התעופה Ngurah Rai (DPS)</p>
            <p class="text-sm">מרחק משוער: <span class="text-white">{distancePricing.distance}</span></p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="font-medium text-white">Grab/Gojek Taxi</p>
            <p class="text-sm">משוער: <span class="text-white">{distancePricing.grabPrice}</span> להובלה מהנמל</p>
            <p class="text-xs text-white/50 mt-1">* המחירים הם משוער בלבד. בדקו את היישום עבור תמחור חיוני.</p>
          </div>
        </div>
        {(address || venue.area) && (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 003 16.382V5.618a1 1 0 011.447-.894L9 7.5m0 0l6.553-3.276A1 1 0 0117 5.618v10.764a1 1 0 01-1.447.894L9 7.5m0 0L3 10m6-6v6m6-6v6"/></svg>
            <div>
              <p class="font-medium text-white">Maps</p>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent((address || venue.area || venue.name_he) + ', Bali')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-teal-400 hover:text-teal-300 text-sm transition-colors"
              >
                פתחו ב-Google Maps ↗
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="mb-8">
      <FAQSection items={faqItems} entityName={venue.name_he} />
    </div>

    {relatedNightlife.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-800" dir="rtl">
        <h2 class="text-2xl font-bold text-white mb-6">🌙 מקומות לילה נוספים ב{venue.area}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedNightlife.map((item: any) => (
            <a
              href={`/nightlife/${item.slug}`}
              class="group bg-gray-900 rounded-xl overflow-hidden hover:bg-gray-800 transition-colors"
            >
              {item.image ? (
                <img
                  src={item.image}
                  alt={item.name_he}
                  class="w-full h-40 object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-40 bg-gray-800 flex items-center justify-center">
                  <span class="text-4xl">🌙</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-tight group-hover:text-teal-400 transition-colors">
                  {item.name_he}
                </h3>
                {item.description && (
                  <p class="text-gray-400 text-xs mt-1 line-clamp-2">{item.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center mt-16">
      <p class="text-white/80 mb-4">אהבתם את {venue.name_he}? רוצים עוד המלצות לחיי לילה בבאלי?</p>
      <a
        href="/nightlife"
        class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-[#0D0D0D] font-bold px-6 py-3 rounded-full transition-colors"
      >
        🌙 לכל מקומות הלילה בבאלי
      </a>
    </div>
  </div>
</Layout>
