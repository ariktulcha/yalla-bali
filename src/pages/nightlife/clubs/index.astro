---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import NightlifeCard from '../../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('nightlife')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('venue_type', 'club')

const items = data || []

const pageTitle = 'מועדונים בבאלי | Yalla Bali'
const pageDescription = 'המועדונים הטובים ביותר בבאלי. מועדוני ריקודים, מסיבות ודי-ג\'יים בינלאומיים — חיי הלילה של באלי במיטבם.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מועדונים בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/nightlife/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: 'מועדונים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/nightlife/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/nightlife/bars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🍸 ברים</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🎵 מועדונים</span>
      <a href="/nightlife/beach-clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ ביץ׳ קלאב</a>
      <a href="/nightlife/rooftop/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌇 רופטופ</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מועדונים בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        חיי הלילה בבאלי לוהטים ומגוונים. מועדונים עם די-ג'יים בינלאומיים,
        מערכות סאונד מתקדמות ואווירה שלא תשכחו. הנה המועדונים שחייבים להכיר.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <NightlifeCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            type={item.type}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מועדונים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מועדונים בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה שעות הפעילות של מועדונים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב המועדונים פותחים בין 22:00-23:00 ונסגרים בין 3:00-4:00 בלילה. בסופי שבוע (חמישי-שישי) חלק מהמקומות פתוחים עד מאוחר יותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה כניסה למועדון בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כניסה למועדון בבאלי עולה בין 100-300 דירהם, לפעמים כולל שתייה. בלילות מיוחדים עם די-ג'יים בינלאומיים המחיר יכול להיות גבוה יותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה קוד הלבוש במועדונים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">קוד הלבוש הוא Smart Casual עד Dressy. נעליים סגורות חובה, ללא כפכפים, שורטס או גופיות. מומלץ להתלבש אלגנטי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה המועדונים הטובים ביותר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מועדונים מובילים בבאלי: Hive, STORY, Dady'O. מועדונים בבאלי אלה משכנעים בדיג'יים בינלאומיים, תאורה מתקדמת ואווירה מדהימה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם צריך הזמנה למועדון בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">הזמנה מראש מומלצת למועדונים בבאלי, במיוחד בחמישי-שישי. מועדונים בבאלי פופולריים מתמלאים מהר וההזמנה יכולה להבטיח מקום משובח.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה סוגי המוזיקה במועדונים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מועדונים בבאלי משדרים: House, Techno, Hip-Hop, وجنرות בינלאומיות. מועדונים בבאלי שונים מתמחים ביוצרים מוזיקה שונה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מערכות הסאונד במועדונים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מועדונים בבאלי משתמשים בציוד סאונד מתקדם מהיצרנים המובילים בתחום כמו Funktion-One. מערכות הסאונד במועדונים בבאלי מספקות חוויה אקוסטית גבוהה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה דיג'יים בינלאומיים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מועדונים בבאלי מארחים דיג'יים מפורסמים מעולם כמו Mark Knight, Vini Vici וSlushii. דיג'יים בינלאומיים במועדונים בבאלי מופיעים בערבים מיוחדים וכנסי EDM.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה שתייה בבאלי כלכלי טוב במועדונים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מועדונים בבאלי מציעים פרימיום בכניסה עם שתייה כלולה. בחלק מהמועדונים בבאלי יש Bottle Service בקבוצות גדולות בעלות טובה יותר.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים המלצה למועדון בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מועדון בבאלי 🎶')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
