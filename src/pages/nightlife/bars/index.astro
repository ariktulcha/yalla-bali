---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import NightlifeCard from '../../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('nightlife')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .in('venue_type', ['bar', 'lounge'])

const items = data || []

const pageTitle = 'ברים בבאלי | Yalla Bali'
const pageDescription = 'הברים הטובים ביותר בבאלי. מברים אלגנטיים ועד ברים מזדמנים — המדריך המלא לחיי הלילה בבאלי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'ברים בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/nightlife/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: 'ברים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/nightlife/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🍸 ברים</span>
      <a href="/nightlife/clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎵 מועדונים</a>
      <a href="/nightlife/beach-clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ ביץ׳ קלאב</a>
      <a href="/nightlife/rooftop/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌇 רופטופ</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">ברים בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי מציעה סצנת ברים מגוונת ומרשימה — מברים על גגות עם נוף מהמם,
        ברי קוקטיילים אלגנטיים, וברי ספורט בפאבים בסגנון בריטי.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <NightlifeCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            type={item.type}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו ברים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — ברים בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם מותר לשתות אלכוהול בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מותר לשתות אלכוהול בבאלי בברים, מסעדות ומלונות מורשים. גיל המינימום הרשמי הוא 18. שתייה ברחוב או שכרות בפומבי אסורים וחוקים על הנהיגה בשתייה מחוזקים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה שתייה בבר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בירה עולה בין 3-6 דולר, קוקטייל בין 5-10 דולר. יש Happy Hours במקומות רבים עם מחירים מופחתים עד 50% בשעות אחר הצהריים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה קוד הלבוש בברים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב הברים היוקרתיים דורשים Smart Casual. ברים קז'ואליים יותר מקבלים לבוש חופשי אבל לא כפכפים או בגדי ים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה זה Happy Hour בברים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">Happy Hour הוא תקופה בברים בבאלי כאשר המשקאות זולים יותר — בדרך כלל בין 4-7 בערב. ברים בבאלי רבים מציעים ל-50% הנחה על קוקטיילים והחטיפים בשעות Happy Hour.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזה ברים בבאלי טובים לחברים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים בבאלי טובים לקבוצות חברים: La Favela, Mirror, Motel Mexicola. ברים בבאלי עם אווירה חברתית וקוקטיילים יצירתיים מאפשרים להזמין שולחנות ובקבוקים לקבוצות גדולות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הברים הטובים ביותר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים המובילים בבאלי: La Favela, Mirror, Motel Mexicola. ברים בבאלי אלה מפורסמים בקוקטיילים משובחים, אווירה מעולה ומוקד שירות ברמה הגבוהה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם צריך הזמנה לברים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים בבאלי קז'ואליים לא דורשים הזמנה. ברים בבאלי יוקרתיים או מקומות עם זמן כנסה מומלצת להזמין מראש בעיקר בסוף השבוע.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה סוגי הקוקטיילים בברים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים בבאלי מציעים: קוקטיילים קלאסיים (Margarita, Mojito), קוקטיילים יצירתיים עם רכיבים אקזוטיים. ברים בבאלי מומלצים משתמשים בספיריטוסים פרימיום וחומרים טריים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מתי ברים בבאלי פתוחים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ברים בבאלי בדרך כלל פתוחים מ-12:00 עד 3:00-4:00 בבוקר. ברים בבאלי במלונות יכולים להיות פתוחים עד מאוחר יותר בסוף השבוע.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש ברים בבאלי ללא אלכוהול?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, ברים בבאלי מציעים משקאות ללא אלכוהול — קוקטיילים מוקד, מיצים, קפה ותה. ברים בבאלי מצייתים לדרישות אסלאמיות ותומכים באפשרויות עבור מי שלא שותה אלכוהול.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
