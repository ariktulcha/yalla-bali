---
import Layout from '../../components/Layout.astro'
import NightlifeCard from '../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('nightlife')
  .select('name_he, name_en, slug, image, area, excerpt, price_range, venue_type')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const nightlife = items || []

const title = 'חיי לילה בבאלי — ברים, מועדונים ועוד | Yalla Bali'
const description = 'המדריך לחיי הלילה בבאלי: ברים, מועדונים, ביץ׳ קלאבים, רופטופ בארים ועוד. כתובות, שעות פתיחה ודרס קוד.'

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'חיי לילה בבאלי',
  description,
  numberOfItems: nightlife.length,
  itemListElement: nightlife.map((n, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: n.name_he,
    url: `https://yalla-bali.co.il/nightlife/${n.slug}`,
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: 'https://yalla-bali.co.il/' },
    { '@type': 'ListItem', position: 2, name: 'חיי לילה' },
  ],
}

const categoryLinks = [
  { label: '🍸 ברים', href: '/nightlife/bars/' },
  { label: '🎵 מועדונים', href: '/nightlife/clubs/' },
  { label: '🏖️ ביץ׳ קלאב', href: '/nightlife/beach-clubs/' },
  { label: '🌇 רופטופ', href: '/nightlife/rooftop/' },
]

const pills = [
  { label: 'הכל', filter: 'all' },
  { label: '🛋️ לאונג׳', filter: 'lounge' },
]
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="relative py-20 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">חיי לילה</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black mb-4">חיי לילה בבאלי</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        באלי מציעה סצנת חיי לילה תוססת עם מועדונים בדיג'יים בינלאומיים, ברים קוקטיילים משובחים, וביץ׳ קלאבים מדהימים.
        מברים על החוף עם שקיעות כתומות ועד רופטופ בארים בהרים עם נוף פנורמי של הטבע של באלי — לכל אחד משהו.
        כל מקום בעלי מוזיקה חיה, שתייה טובה וקהל בינלאומי לוהט.
      </p>
      <p class="mt-4 text-teal-400 font-medium" id="nl-count">{nightlife.length} מקומות</p>
    </div>
  </section>

  <!-- Category links (SEO pages) + Filter pills -->
  <section class="sticky top-0 z-30 bg-[#0d0d0d]/95 backdrop-blur border-b border-white/5 px-4 py-3">
    <div class="max-w-6xl mx-auto flex gap-2 overflow-x-auto scrollbar-hide">
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black">הכל</span>
      {categoryLinks.map((cat) => (
        <a
          href={cat.href}
          class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap"
        >
          {cat.label}
        </a>
      ))}
      {pills.filter(p => p.filter !== 'all').map((p) => (
        <button
          data-filter={p.filter}
          class="nl-pill flex-none px-4 py-1.5 rounded-full text-sm font-medium transition-all whitespace-nowrap cursor-pointer bg-white/5 text-white/60 hover:bg-white/10 hover:text-white"
        >
          {p.label}
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-20 pt-8">
    {nightlife.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="nl-grid">
        {nightlife.map((place) => (
          <div class="nl-item" data-type={place.venue_type || ''}>
            <NightlifeCard {...place} />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו מקומות חיי לילה כרגע.</p>
    )}
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.nl-pill')
    const items = document.querySelectorAll<HTMLElement>('.nl-item')
    const countEl = document.getElementById('nl-count')

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter || 'all'

        // Update active pill
        pills.forEach((p) => {
          p.classList.remove('bg-teal-500', 'text-black', 'font-bold')
          p.classList.add('bg-white/5', 'text-white/60')
        })
        pill.classList.remove('bg-white/5', 'text-white/60')
        pill.classList.add('bg-teal-500', 'text-black', 'font-bold')

        // Filter items
        let visible = 0
        items.forEach((item) => {
          const type = item.dataset.type || ''
          const show = filter === 'all' || type === filter
          item.style.display = show ? '' : 'none'
          if (show) visible++
        })

        if (countEl) countEl.textContent = visible + ' מקומות'
      })
    })
  })
</script>
