---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import NightlifeCard from '../../../components/Cards/NightlifeCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('nightlife')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

// Rooftop = bars/lounges with rooftop/sky/terrace keywords (no dedicated venue_type)
const ROOFTOP_KEYWORDS = ['סקיי', 'sky', 'רוף', 'roof', 'טרסה', 'terrace', 'לאונג', 'lounge', 'תצפית']
const items = (data || []).filter(n =>
  ROOFTOP_KEYWORDS.some(kw =>
    (n.name_he || '').toLowerCase().includes(kw.toLowerCase()) ||
    (n.name_en || '').toLowerCase().includes(kw.toLowerCase())
  )
)

const pageTitle = 'רופטופ בארים בבאלי | Yalla Bali'
const pageDescription = 'רופטופ בארים מובילים בבאלי. שתייה עם נוף פנורמי של קו הרקיע של באלי — החוויה הכי יפה בעיר.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'רופטופ בארים בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/nightlife/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'חיי לילה', href: '/nightlife' },
  { label: 'רופטופ' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/nightlife/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/nightlife/bars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🍸 ברים</a>
      <a href="/nightlife/clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎵 מועדונים</a>
      <a href="/nightlife/beach-clubs/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ ביץ׳ קלאב</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🌇 רופטופ</span>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">רופטופ בארים בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי מציעה רופטופ בארים מדהימים עם נוף פנורמי של עמקים, טבע וים.
        קוקטיילים משובחים, אווירה רומנטית ושקיעות עוצרות נשימה בהרים ובחופים.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <NightlifeCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            type={item.type}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו רופטופ בארים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — רופטופ בארים בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הרופטופ בר הכי טוב בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">באלי מציעה רופטופ בארים מדהימים בנוף, רבים ממוקמים בהרים וחופים. הם מציעים נוף פנורמי של טבע בלתי מזוהם, שדות אורז וים ההודי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מתי הזמן הכי טוב לבקר ברופטופ בר?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">שעת השקיעה (17:00-19:00) היא הזמן המושלם — תוכלו ליהנות מהנוף באור יום ולראות את העיר נדלקת. מומלץ להגיע מוקדם לתפוס מקום טוב.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם צריך הזמנה לרופטופ בר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מומלץ מאוד להזמין מראש, במיוחד בסופי שבוע ובעונת התיירות. רופטופ בארים פופולריים מתמלאים מהר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה המחירים של משקאות ברופטופ בר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">משקאות ברופטופ בר בבאלי עולים בין $8-20 לקוקטייל. רופטופ בארים ביוקרה בבאלי יכולים להיות יקרים יותר, בטווח $20-30.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזה רופטופ בר בבאלי טוב לתאריך?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רופטופ בארים רומנטיים בבאלי: Karjasa Sky Dining (עם נוף הרים), Kayuputi (בחוף), Nujum Sky Lounge. אווירה רומנטית ונוף מדהים של טבע בלי מנויים מעניקים לתאריך חוויה בלתי נשכחת.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הטובים ביותר רופטופ בארים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רופטופ בארים מובילים בבאלי: Jungle Rum (בקאנגו), Karjasa Sky Dining (באובוד), Nujum Sky Lounge (בסמינייק). רופטופ בארים בבאלי המובילים מציעים קוקטיילים משובחים ונוף טבעי מדהים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש דרס קוד לרופטופ בר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">קוד הלבוש הוא Smart Casual עד Dressy. רופטופ בארים בבאלי לא מקבלים שורטס, כפכפים או גופיות. חשוב להתלבש בהגינות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה אוכל מוגש ברופטופ בארים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רופטופ בארים בבאלי מציעים בדרך כלל אפטיזרים ואוכל קל. חלק מהם גם יש מסעדות בתוך הרופטופ בר בבאלי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזו גיל מינימום לרופטופ בר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">גיל מינימום הוא 18 שנים בבאלי. רופטופ בארים בבאלי יכולים לדרוש תעודת זהות בתוקף. רופטופ בארים בבאלי עם אלכוהול בדרך כלל מאכפים את גבול הגיל בערב (אחרי שקיעה).</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
