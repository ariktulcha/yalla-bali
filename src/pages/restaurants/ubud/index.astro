---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Ubud')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן מסעדות הפיין דיינינג המובילות באובוד?', a: 'אובוד היא בירת הפיין דיינינג של באלי. לוקאבור NXT (זוכת פרס Sustainable של אסיה 50 הטובים 2025), אפריטיף (הקרוב ביותר ל-3 כוכבי מישלן), מוזאיק (הוותיקה והאגדית), ו-Room4Dessert (תפריט טעימה של קינוחים) — כולן כאן.' },
  { q: 'איפה הכי טוב לאכול טבעוני באובוד?', a: 'אובוד היא יעד עולמי לאוכל טבעוני וצמחוני. סאיורי הילינג פוד (Raw Food אגדי), מוקסה (גן פרמקלצ\'ר), וזסט אובוד (נוף לג\'ונגל) הן המובילות. גם Alchemy Ubud וSeeds of Life הן מצוינות.' },
  { q: 'כמה עולה ארוחה באובוד?', a: 'אובוד מגוונת במחירים: ווארונג מקומי 40,000-80,000 רופי (10-20 ש"ח), מסעדה טובה 150,000-400,000 רופי (40-110 ש"ח), וארוחת פיין דיינינג 1,500,000-5,500,000 רופי (400-1,500 ש"ח). המגוון הרחב ביותר בבאלי.' },
  { q: 'איפה הרחובות הקולינריים באובוד?', a: 'המרכז המסורתי של אובוד (Jalan Hanoman, Jalan Monkey Forest) עמוס מסעדות תיירותיות. הסצנה הגורמה נמצאת בכפרים הסמוכים: Sayan, Penestanan, Kedewatan. את פיין דיינינג המובילה (לוקאבור NXT, מוזאיק, Room4Dessert) תמצאו שם.' },
  { q: 'האם צריך להזמין מקום באובוד מראש?', a: 'בהחלט. לוקאבור NXT ואפריטיף דורשות הזמנה 2-3 חודשים מראש, במיוחד בעונת השיא. סאיורי, מוקסה וזסט — מומלץ להזמין לפחות יום קודם. במסעדות המרכז של אובוד אפשר להסתובב בלי הזמנה.' },
  { q: 'מה זה אוכל בריא/הילינג באובוד?', a: 'אובוד היא בירת ה-conscious eating של אסיה — אוכל הזנה, אורגני, סופר-פוד, Raw Food, פרמקלצ\'ר. כל מה שתאכלו כאן מחובר לרוחניות, יוגה, ובריאות. מסעדות כמו סאיורי ומוקסה הן חוויות רוחניות לא פחות מקולינריות.' },
  { q: 'האם אובוד מתאימה למשפחות?', a: 'כן, אובוד מתאימה למשפחות — מסעדות קלאסיות כמו This Is Bali, Naughty Nuri\'s (צלעות BBQ אגדיות), קפה פומגרנט, וBridges. גם קפה גן ירוק (Cafe Lotus) וBebek Tepi Sawah (ברווז צלוי בשדות אורז) אהובים על ילדים.' },
  { q: 'האם יש מסעדות ישראליות באובוד?', a: 'אין מסעדה ישראלית ייעודית באובוד, אבל הרבה מהמסעדות הצמחוניות/טבעוניות של אובוד מציעות מנות מזרח-תיכוניות (חומוס, טבולה, שקשוקה). דוגמאות: Seeds of Life, Zest, Alchemy. לאוכל ישראלי אמיתי — סבבה בצ\'נגו (שעה נסיעה).' },
  { q: 'מה הסגנון הקולינרי של אובוד?', a: 'אובוד משלבת שני עולמות: (1) סצנת פיין דיינינג ברמה עולמית (לוקאבור NXT, אפריטיף, מוזאיק), ו-(2) סצנת אוכל טבעוני/בריא/רוחני (סאיורי, מוקסה, זסט). גם מטבח בלינזי אותנטי ביותר ומסעדות BBQ אגדיות (נאוטי נוריז המקורי משנת 1995).' },
  { q: 'איך מגיעים למסעדות באובוד?', a: 'אובוד פרוסה על שטח גדול. המרכז ניתן לרגל. למסעדות בכפרים (Sayan, Penestanan, Kedewatan) צריך Grab/Gojek (10,000-30,000 רופי לנסיעה). לוקאבור NXT נמצאת ב-Lodtunduh — כ-15 דקות נסיעה מהמרכז.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות באובוד — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות באובוד: פיין דיינינג (לוקאבור NXT, אפריטיף, מוזאיק), אוכל טבעוני (סאיורי, מוקסה, זסט), BBQ אגדי (נאוטי נוריז), ומטבח בלינזי. המלצות ומחירים."
  h1="מסעדות באובוד"
  intro="אובוד היא בירת הגסטרונומיה של באלי — יעד פיין דיינינג ברמה עולמית (לוקאבור NXT זוכת פרס Sustainable של אסיה 50) לצד מסעדות טבעוניות וצמחוניות מהמובילות בעולם (סאיורי, מוקסה, זסט). המגוון הקולינרי של אובוד הוא הרחב ביותר בבאלי."
  items={items}
  faq={faq}
  categorySlug="ubud"
  breadcrumbLabel="אובוד"
  schemaName="מסעדות באובוד"
  faqHeading="שאלות נפוצות — מסעדות באובוד"
/>
