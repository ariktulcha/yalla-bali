---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Seminyak')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בסמיניאק?', a: 'סמיניאק היא בירת הקולינריה של באלי הדרומית, עם מגוון עצום של מסעדות. המובילות כוללות את טאקומי (סושי יפני ברמה עולמית), לה לוצ\'ולה (איטלקי על החוף), מטיס (צרפתי-ים תיכוני), מאמא סאן (פן-אסייתי), ובוי אנד קאו (סטייקהאוס פרימיום).' },
  { q: 'כמה עולה ארוחה במסעדה בסמיניאק?', a: 'טווח המחירים בסמיניאק רחב: ארוחה במסעדה קז\'ואלית עולה 150,000-300,000 רופי לאדם (40-80 ש"ח), ארוחה במסעדה טובה 400,000-800,000 רופי (110-220 ש"ח), וארוחת פיין דיינינג 1,500,000+ רופי (400+ ש"ח).' },
  { q: 'איפה רחוב המסעדות המרכזי בסמיניאק?', a: 'הרחוב הקולינרי המרכזי של סמיניאק הוא Jalan Petitenget ו-Jalan Kayu Aya, שם מרוכזים המסעדות היפניות (טאקומי, רייג\'ין, שיצ\'ירין), האיטלקיות (מאורי, סטימו צ\'לו), והפיין דיינינג (מטיס, קילו קיטשן). גם Jalan Camplung Tanduk פופולרי.' },
  { q: 'האם צריך להזמין מקום במסעדות סמיניאק מראש?', a: 'במסעדות הפופולריות והיוקרה של סמיניאק (טאקומי, מטיס, מאורי, בוי אנד קאו, לה לוצ\'ולה) מומלץ מאוד להזמין מקום מראש, לעיתים שבועות קדימה. במסעדות קז\'ואליות אפשר להגיע ללא הזמנה.' },
  { q: 'איפה הכי טוב לאכול שקיעה בסמיניאק?', a: 'לה לוצ\'ולה על חוף פטיטנגט היא הקלאסיקה לשקיעה בסמיניאק. גם Ku De Ta (עם מג\'קאווי למעלה) ו-La Plancha ביץ\' קלאב הם אופציות מעולות לשקיעה על החוף.' },
  { q: 'האם יש מסעדות כשרות או ישראליות בסמיניאק?', a: 'כן, בסמיניאק נמצא בית חב"ד באלי (ארוחות כשרות בהזמנה מראש), מסעדת זולה גן עדן צמחוני (100% צמחוני), וטאג\'ין (מרוקאי ללא חזיר). בצ\'נגו הסמוכה יש גם את סבבה (ישראלי).' },
  { q: 'איפה הכי טוב לאכול סושי בסמיניאק?', a: 'סמיניאק היא בירת הסושי של באלי. הטובים ביותר: טאקומי (אומקאסה 18 מנות), קאג\'ין (סושי בר אינטימי), סושימי (סושי טריין כיף למשפחות), וריושי (ג\'אז + סושי). כולם מרוכזים בפטיטנגט.' },
  { q: 'האם סמיניאק מתאימה למשפחות עם ילדים?', a: 'כן, סמיניאק מציעה מגוון מסעדות ידידותיות למשפחות — סושימי (סושי טריין), ריושי, לה לוצ\'ולה (ישיבה על החוף), ו-KYND (אווירה צעירה). חלק מהמסעדות הטרנדיות מתאימות יותר לערב זוגי.' },
  { q: 'מה הסגנון הקולינרי של סמיניאק?', a: 'סמיניאק מציעה את המגוון הרחב ביותר בבאלי — יפני פרימיום, איטלקי אותנטי, צרפתי-ים תיכוני, פן-אסייתי מודרני, סטייקהאוס, וכל זאת מעורבב עם קולינריה אינדונזית. האווירה טרנדית ויוקרתית יחסית.' },
  { q: 'איך מגיעים למסעדות בסמיניאק?', a: 'הדרך הנוחה ביותר היא Grab או Gojek (מחירים הוגנים, כ-15,000-40,000 רופי לנסיעה באזור). מטקסי רגיל — הקפידו על מונה. במרחק הליכה בין מסעדות סמיניאק אבל מזג האוויר החם לא תמיד מזמין הליכה.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בסמיניאק — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בסמיניאק: מטבח יפני, איטלקי, פיין דיינינג, סטייקהאוס, פן-אסייתי ועוד. המלצות, מחירים וטיפים לסצנת האוכל המובילה בבאלי."
  h1="מסעדות בסמיניאק"
  intro="סמיניאק היא בירת הקולינריה של באלי הדרומית — רחוב פטיטנגט ורחוב קאיו אייה מרוכזים בהם המסעדות היפניות הטובות ביותר באי, מטבח איטלקי אותנטי, פיין דיינינג צרפתי, סטייקהאוסים יוקרתיים וחוויות פן-אסייתיות מהשורה הראשונה."
  items={items}
  faq={faq}
  categorySlug="seminyak"
  breadcrumbLabel="סמיניאק"
  schemaName="מסעדות בסמיניאק"
  faqHeading="שאלות נפוצות — מסעדות בסמיניאק"
/>
