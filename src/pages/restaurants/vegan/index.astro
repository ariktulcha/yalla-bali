---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = ['טבעוני', 'Raw Food', 'raw food', 'בריאות', 'אורגני', 'צמחוני']
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן המסעדות הטבעוניות הטובות ביותר בבאלי?', a: 'באלי היא יעד עולמי לאוכל טבעוני. המובילות: דה שיידי שאק (צ\'נגו — אייקון), סאיורי הילינג פוד (אובוד — Raw Food אגדי), מוקסה אובוד (גן פרמקלצ\'ר), זסט אובוד (נוף לג\'ונגל), ארת\' קפה סמיניאק, KYND קומיוניטי, פלוטון סופרשופ, ופלנט קרטל.' },
  { q: 'איפה הכי טוב לאכול טבעוני בבאלי?', a: 'שני האזורים המובילים לאוכל טבעוני הם צ\'נגו (השיידי שאק, פלוטון, פלנט קרטל, KYND הסמוכה) ואובוד (סאיורי, מוקסה, זסט). בכל אחד מהאזורים יש עשרות אופציות. סמיניאק פחות ידועה אבל מציעה את ארת\' קפה וזולה.' },
  { q: 'מה זה Raw Food?', a: 'Raw Food הוא סגנון בישול שבו מאכלים לא מתבשלים בטמפרטורה מעל 42°C (108°F) — מה שלפי התיאוריה שומר על אנזימים וחומרי תזונה. מסעדות כמו סאיורי ומוקסה באובוד מתמחות ב-Raw Food — לזניה גלם, פיצה גלם, פאד תאי גלם.' },
  { q: 'כמה עולה ארוחה טבעונית בבאלי?', a: 'ארוחה טבעונית קז\'ואלית בצ\'נגו/אובוד: 100,000-200,000 רופי לאדם (25-55 ש"ח). מסעדה טובה (השיידי שאק, סאיורי): 150,000-300,000 רופי (40-80 ש"ח). Raw Food פיין דיינינג (מוקסה, זסט): 200,000-400,000 רופי (55-110 ש"ח).' },
  { q: 'האם יש אוכל טבעוני באלי-אותנטי?', a: 'כן, למעשה רוב המטבח האינדונזי הוא בטבעו ידידותי לטבעוניים. גאדו-גאדו (סלט ירקות עם רוטב בוטנים) הוא טבעוני. טמפה (פולי סויה מותססים — המקורית של אינדונזיה!) היא מקור חלבון טבעוני אגדי. נאסי גורנג וקארי ירק בלינזי גם טבעוניים.' },
  { q: 'מהי הפופולריות של אוכל טבעוני באלי?', a: 'באלי היא אחד היעדים המובילים בעולם לאוכל טבעוני. בגלל תרבות היוגה, המדיטציה והאוכל הבריא (במיוחד באובוד), ובגלל הקהילה הגדולה של זרים וטבעוניים. HappyCow (מדריך טבעוני עולמי) מעריך שיש יותר מ-300 מסעדות טבעוניות/צמחוניות בבאלי.' },
  { q: 'מהו טמפה?', a: 'טמפה (Tempeh) היא המצאה אינדונזית — פולי סויה מותססים שעוברים תהליך התססה והופכים לחלבון מלא עם מרקם דחוס. הוא מקור חלבון טבעוני מצוין, עשיר בפרוביוטיקה. בבאלי הטמפה זול וטרי — כל ווארונג מגיש אותו.' },
  { q: 'האם מסעדות טבעוניות בבאלי מתאימות לאלרגיות?', a: 'כן, מסעדות טבעוניות מובילות בבאלי מאוד מודעות לאלרגיות. סאיורי, מוקסה, זסט, וארת\' קפה מציינות בבירור בתפריטים אילו מנות מכילות גלוטן, אגוזים, או סויה. הצוות לרוב רגיל לשאלות אלרגיה ויכול להציע חלופות.' },
  { q: 'האם יש אוכל טבעוני-כשר בבאלי?', a: 'רוב המסעדות הטבעוניות של בבאלי הן פרווה (ללא בשר וללא חלב) — מה שהופך אותן למתאימות לכשרות. מסעדות כמו זולה, השיידי שאק, ומוקסה הן בחירות בטוחות לישראלים שומרי כשרות. צריך רק לוודא שהמסעדה לא מערבבת כלים עם מסעדה בשרית או חלבית.' },
  { q: 'האם צריך להזמין מקום במסעדות טבעוניות?', a: 'במסעדות הפופולריות (השיידי שאק, KYND, סאיורי) מומלץ להגיע לפני 19:00 או להזמין. בעונת השיא הקפה הוויראלי של KYND יכול לדרוש המתנה של שעה. ב-Raw Food פיין דיינינג (מוקסה, זסט) בהחלט הזמינו.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות טבעוניות בבאלי — Raw Food ואוכל צמחי | יאללה באלי"
  pageDescription="מדריך מסעדות טבעוניות בבאלי: שיידי שאק, סאיורי, מוקסה, זסט, ארת׳ קפה, KYND, פלוטון ועוד. Raw Food, אוכל הזנה, סופר-פוד. יעד עולמי לאוכל צמחי."
  h1="מסעדות טבעוניות בבאלי"
  intro="באלי היא אחד היעדים המובילים בעולם לאוכל טבעוני. מדה שיידי שאק האייקוני בצ׳נגו, דרך סאיורי הילינג פוד (Raw Food אגדי) ומוקסה אובוד (גן פרמקלצ׳ר) באובוד, ועד לקפה הוורוד הוויראלי KYND בסמיניאק. HappyCow מעריך יותר מ-300 מסעדות טבעוניות באי."
  items={items}
  faq={faq}
  categorySlug="vegan"
  breadcrumbLabel="טבעוני"
  schemaName="מסעדות טבעוניות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות טבעוניות בבאלי"
/>
