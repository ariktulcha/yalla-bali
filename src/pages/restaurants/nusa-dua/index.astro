---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Nusa Dua')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בנוסה דואה?', a: 'נוסה דואה היא אזור הרזורטים של באלי, עם מסעדות ברמת מלון 5 כוכבים. המובילות: בומבו באלי (מטבח בלינזי אותנטי עם בית ספר לבישול), אדוגין במוליה (יפני פיין דיינינג), מנדלה (פיוז\'ן אסייתי), סאפה סיפוד גריל (פירות ים), וסוקון (בלינזי מודרני).' },
  { q: 'כמה עולה ארוחה בנוסה דואה?', a: 'נוסה דואה יוקרתית: ארוחה במסעדה טובה 400,000-800,000 רופי לאדם (110-220 ש"ח), ארוחה במסעדת מלון 600,000-1,200,000 רופי (165-330 ש"ח). אדוגין (פיין דיינינג יפני) — 1,000,000+ רופי לאדם.' },
  { q: 'האם אני יכול לאכול במסעדת מלון בלי להיות אורח?', a: 'בהחלט. כל המסעדות של מלונות 5 כוכבים בנוסה דואה (מוליה, פור סיזנס, סנט רג\'יס, ריץ\'-קרלטון) פתוחות לאורחים חיצוניים. אדוגין במוליה הוא דוגמא מצוינת — פיין דיינינג יפני פתוח לכל מי שמזמין מקום.' },
  { q: 'מהי בומבו באלי?', a: 'בומבו באלי היא הסטנדרט של מטבח בלינזי אותנטי. נוסדה ב-1996 על ידי השף השוויצרי היינץ פון הולזן ואשתו הבאלינזית פוג\'י. המסעדה מציעה ארוחות מסורתיות כמו ראיסטפל (סעודת רב-מנות) ובבק בטוטו (ברווז צלוי לאט), ובית ספר לבישול בצד.' },
  { q: 'האם צריך להזמין מקום בנוסה דואה מראש?', a: 'בהחלט. רוב המסעדות של נוסה דואה הן בסגנון פיין דיינינג או ברמת מלון, ודורשות הזמנה מראש — במיוחד אדוגין במוליה, בומבו באלי, וסונדארה (גם היא אחת הטובות). בעונת השיא תזמינו 2-3 ימים מראש לפחות.' },
  { q: 'האם נוסה דואה מתאימה למשפחות עם ילדים?', a: 'כן, נוסה דואה היא אידיאלית למשפחות — אזור רגוע, מלונות גדולים עם בריכות ענק, חוף שקט ומוגן, והרבה מסעדות משפחתיות במלונות. האוכל בינלאומי ומגוון, כולל אופציות לילדים ברוב המסעדות.' },
  { q: 'מה זה ראיסטפל?', a: 'ראיסטפל (Rijsttafel) היא מילה הולנדית שפירושה "שולחן אורז" — זוהי סעודת רב-מנות קלאסית אינדונזית הכוללת אורז עם 15-20 מנות קטנות שונות של בשר, דגים, ירקות ותבלינים. בומבו באלי מפורסמת בראיסטפל הכי אותנטי בבאלי.' },
  { q: 'איפה נמצאות מסעדות נוסה דואה?', a: 'רוב המסעדות של נוסה דואה נמצאות בתוך קומפלקס של ITDC (International Tourism Development Corporation) — שטח מגודר עם מלונות 5 כוכבים. בומבו באלי מחוץ לקומפלקס ב-Tanjung Benoa. רכב/גראב הכרחיים לניוד בין המסעדות.' },
  { q: 'האם יש אופציות קולינריות זולות בנוסה דואה?', a: 'כן, יש כמה וארונגים וקפה מחוץ לקומפלקס המלונות (בכפר Bualu, Tanjung Benoa). אבל בגדול — נוסה דואה היא אזור יוקרתי שלא מתמחה באוכל זול. למחירים הוגנים יותר, יש ללכת לסאנור או קוטה הסמוכות.' },
  { q: 'מה הסגנון הקולינרי של נוסה דואה?', a: 'נוסה דואה = פיין דיינינג במלונות 5 כוכבים. הסגנון הוא בינלאומי-יוקרתי, עם דגש על מטבח יפני (אדוגין), בלינזי אותנטי (בומבו באלי, קקב), פירות ים (סאפה, סונדארה), ואיטלקי/צרפתי במלונות הגדולים.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בנוסה דואה — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בנוסה דואה: בומבו באלי (בלינזי אותנטי עם בית ספר לבישול), אדוגין במוליה (יפני פיין דיינינג), מנדלה, סאפה סיפוד, סוקון. אזור הרזורטים היוקרתי של באלי."
  h1="מסעדות בנוסה דואה"
  intro="נוסה דואה היא אזור הרזורטים היוקרתי של באלי — עם מסעדות ברמת מלון 5 כוכבים. מהמטבח הבלינזי האותנטי של בומבו באלי (עם בית ספר לבישול), דרך אדוגין במוליה (פיין דיינינג יפני), ועד מסעדות פירות ים על הים. נוסה דואה מושלמת למטיילים שמחפשים חוויה יוקרתית ושקטה."
  items={items}
  faq={faq}
  categorySlug="nusa-dua"
  breadcrumbLabel="נוסה דואה"
  schemaName="מסעדות בנוסה דואה"
  faqHeading="שאלות נפוצות — מסעדות בנוסה דואה"
/>
