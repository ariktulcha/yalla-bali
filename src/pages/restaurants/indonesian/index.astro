---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = ['אינדונזי', 'אינדונזית', 'Indonesian']
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן המסעדות האינדונזיות הטובות ביותר בבאלי?', a: 'לאוכל אינדונזי מסורתי בבאלי: הוג\'אן לוקאלה באובוד (אינדונזי מודרני), בומבו באלי בנוסה דואה (ראיסטפל אותנטי), מאדה\'ס וארונג בקוטה (מוסד משנת 1969), קאלומה בסאנור (אינדונזי-פירות ים), וג\'ולי בסט ויו קפה באמד.' },
  { q: 'מה המנות האינדונזיות הקלאסיות?', a: 'המנות האינדונזיות הקלאסיות כוללות: נאסי גורנג (אורז מטוגן), מי גורנג (נודלס מטוגנים), גאדו-גאדו (סלט ירקות מבושלים עם רוטב בוטנים), סאטה (שיפודי בשר בסגנון הודי), רנדנג (בקר מתובל), ובאבי גולינג (חזיר צלוי).' },
  { q: 'מה ההבדל בין מטבח אינדונזי לבלינזי?', a: 'המטבח האינדונזי הוא רחב — יש 17,500 איים באינדונזיה, כל אחד עם מטבח אזורי (סומטרה חריף יותר, ג\'אווה מתוק יותר, סולאוואסי ים-תיכוני). המטבח הבלינזי הוא אחד הסגנונות — ייחודי באלי, עם דגש על בישול איטי ותבלינים מורכבים.' },
  { q: 'מה זה נאסי גורנג?', a: 'נאסי גורנג (Nasi Goreng) הוא מנת הדגל של אינדונזיה — אורז מטוגן עם קצ\'אפ מאניס (רוטב סויה מתוק), שום, צ\'ילי, ביצה, ותוספות כמו עוף, שרימפס או ירקות. כל ווארונג בבאלי מגיש נאסי גורנג, עם הגרסה המקומית שלו. המחיר הממוצע: 25,000-50,000 רופי.' },
  { q: 'מה זה גאדו-גאדו?', a: 'גאדו-גאדו (Gado-Gado) הוא סלט אינדונזי קלאסי — ירקות מבושלים (תפוחי אדמה, שעועית ארוכה, ברוקולי, כרוב, ביצה) עם רוטב בוטנים עבה ומעודן. זו אופציה מצוינת לצמחוניים. בומבו באלי וUma Garden מגישות גאדו-גאדו ברמה גבוהה.' },
  { q: 'כמה עולה ארוחה אינדונזית?', a: 'ווארונג אינדונזי מקומי: 25,000-70,000 רופי לאדם (6-18 ש"ח). מסעדה טובה: 100,000-250,000 רופי (25-70 ש"ח). מסעדה יוקרתית (הוג\'אן לוקאלה): 400,000-700,000 רופי (110-190 ש"ח).' },
  { q: 'מה זה רנדנג ואיפה אוכלים אותו?', a: 'רנדנג (Rendang) הוא בקר מבושל לאט בחלב קוקוס ותערובת תבלינים (עד 8 שעות) — המנה הוכתרה על ידי CNN כ"המנה הטעימה בעולם". זה מטבח מינאנגקבאו (סומטרה). מסעדות כמו הוג\'אן לוקאלה וווארונג אגונג אמד מגישות רנדנג ברמה גבוהה.' },
  { q: 'האם מסעדות אינדונזיות בבאלי מתאימות לצמחוניים?', a: 'כן, בהחלט. רוב המסעדות מגישות גרסאות צמחוניות של המנות הקלאסיות: נאסי גורנג ירק, מי גורנג ירק, גאדו-גאדו (טבעי צמחוני), טמפה (טופו אינדונזי), ו-סייור בלנדה (ירקות מבושלים). טמפה היא פטנט אינדונזי — פולי סויה מותססים.' },
  { q: 'מה זה סאטה?', a: 'סאטה (Sate/Satay) זה שיפודי בשר (עוף, בקר, טלה, או חזיר) עם רוטב בוטנים עבה. אינדונזיה המציאה את הסאטה לפני 100 שנים. מסעדות כמו נאוטי נוריז, בומבו באלי, ומאדה\'ס וארונג מגישות סאטה ברמה מצוינת.' },
  { q: 'איפה הכי טוב לאכול אינדונזי אותנטי בבאלי?', a: 'לאוכל אינדונזי אותנטי: ווארונגים מקומיים (במרכז אובוד או קוטה — 30,000-50,000 רופי), מאדה\'ס וארונג (המוסד), בומבו באלי בנוסה דואה (פיין דיינינג), הוג\'אן לוקאלה באובוד (מודרני-מעודן). הסגנון והאווירה שונים לחלוטין בכל אחת.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות אינדונזיות בבאלי — מטבח מסורתי | יאללה באלי"
  pageDescription="מדריך מסעדות אינדונזיות בבאלי: הוג׳אן לוקאלה, בומבו באלי, מאדה׳ס וארונג, קאלומה ועוד. נאסי גורנג, גאדו-גאדו, רנדנג וסאטה — המטבח המסורתי של 17,500 איים."
  h1="מסעדות אינדונזיות בבאלי"
  intro="המטבח האינדונזי הוא אחד המגוונים בעולם — 17,500 איים, כל אחד עם מטבח אזורי. מנאסי גורנג וגאדו-גאדו ועד רנדנג וסאטה, מהווארונג המקומי הפשוט ועד הוג׳אן לוקאלה באובוד (אינדונזי מודרני-מעודן). באלי מציעה את החלון הכי רחב לטעמי אינדונזיה."
  items={items}
  faq={faq}
  categorySlug="indonesian"
  breadcrumbLabel="אינדונזי"
  schemaName="מסעדות אינדונזיות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות אינדונזיות בבאלי"
/>
