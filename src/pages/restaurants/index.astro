---
import Layout from '../../components/Layout.astro'
import RestaurantCard from '../../components/Cards/RestaurantCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('name_he')

const restaurants = items || []

const title = 'מסעדות בבאלי — המדריך המלא | Yalla Bali'
const description = 'מדריך מסעדות בבאלי: מסעדות כשרות, יפניות, בשרים, פיין דיינינג ועוד. המלצות אמיתיות עם כתובות, מחירים ודירוגים.'

// Category pages (real URLs for SEO)
const categoryLinks = [
  { label: '✡ כשר', href: '/restaurants/kosher/' },
  { label: 'Fine Dining', href: '/restaurants/fine-dining/' },
  { label: '🍣 יפנית', href: '/restaurants/japanese/' },
  { label: '🥩 בשרים', href: '/restaurants/meat/' },
]

// Client-side filter categories (for remaining types without dedicated pages)
const categories = [
  { label: 'הכל', key: 'all' },
  { label: '🍕 איטלקי', key: 'italian', match: ['איטלקי', 'פסטה', 'פיצה', 'טוסקני'] },
  { label: '🥘 הודי', key: 'indian', match: ['הודי', 'הודית מודרנית', 'פנג׳אבי', 'פקיסטני'] },
  { label: '🫒 ים תיכוני', key: 'mediterranean', match: ['ים תיכוני', 'ריביירה'] },
  { label: '☕ ברנץ׳', key: 'brunch', match: ['ברנץ׳', 'ברנץ\'', 'ארוחת בוקר'] },
  { label: '🌏 אסייתי', key: 'asian', match: ['אסייתי', 'אסייתית פיוז׳ן', 'אסייתית', 'תאילנדי'] },
  { label: '🫙 ערבי', key: 'arabic', match: ['ערבי', 'אמירתי', 'לבנוני', 'מרוקאי', 'ערבי מודרני', 'אמירתי מסורתי', 'מזרח תיכוני'] },
]

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מסעדות בבאלי',
  description,
  numberOfItems: restaurants.length,
  itemListElement: restaurants.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: r.name_he,
    url: `https://yalla-bali.co.il/restaurants/${r.slug}`,
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: 'https://yalla-bali.co.il/' },
    { '@type': 'ListItem', position: 2, name: 'מסעדות' },
  ],
}

// Attach cuisines as data-attribute values (for JS filter)
const restaurantsWithData = restaurants.map(r => ({
  ...r,
  cuisineData: JSON.stringify(r.cuisine_types || []),
}))
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="relative py-16 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">מסעדות</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black mb-4">מסעדות בבאלי</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        באלי מארחת מעל 4,000 מסעדות — מדובי-מישלן עד מסעדות מזון רחוב ממושלם.
        צאו למסעדת יפנית מובילה בעולם, ביסטרו צרפתי אלגנטי, או לטחון בשר מומלץ בבאלי.
        כל מטבח בעולם בתוך העיר: יהודי כשר, איטלקי אותנטי, מזרח תיכוני מסורתי וקולינריה ח'יו.
      </p>
      <p class="mt-3 text-teal-400 font-medium" id="restaurant-count">{restaurants.length} מסעדות</p>
    </div>
  </section>

  <!-- Category Links (SEO pages) + Filter Pills -->
  <div class="sticky top-0 z-30 bg-[#0D0D0D]/95 backdrop-blur-sm border-b border-teal-500/10">
    <div class="max-w-6xl mx-auto px-4 py-3 overflow-x-auto scrollbar-hide">
      <div class="flex gap-2 min-w-max" dir="rtl">
        <span class="px-4 py-2 rounded-full text-sm font-bold bg-teal-500 text-black">הכל</span>
        {categoryLinks.map((cat) => (
          <a
            href={cat.href}
            class="px-4 py-2 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap"
          >
            {cat.label}
          </a>
        ))}
        {categories.filter(c => c.key !== 'all').map((cat) => (
          <button
            class="category-pill px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-all duration-200 bg-white/5 text-white/60 hover:bg-white/10 hover:text-white"
            data-category={cat.key}
            data-match={JSON.stringify(cat.match)}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Grid -->
  <section class="max-w-6xl mx-auto px-4 py-8 pb-20">
    {restaurants.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="restaurants-grid">
        {restaurantsWithData.map((restaurant) => (
          <div
            class="restaurant-item"
            data-cuisines={restaurant.cuisineData}
          >
            <RestaurantCard {...restaurant} />
          </div>
        ))}
      </div>
      <p class="text-center text-white/30 py-8 hidden" id="no-results">לא נמצאו מסעדות בקטגוריה זו</p>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו מסעדות כרגע.</p>
    )}
  </section>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill')
    const items = document.querySelectorAll<HTMLElement>('.restaurant-item')
    const countEl = document.getElementById('restaurant-count')
    const noResults = document.getElementById('no-results')

    // Pre-parse data once instead of on every click
    const itemCuisines = new Map<HTMLElement, string[]>()
    items.forEach(item => {
      itemCuisines.set(item, JSON.parse(item.dataset.cuisines || '[]'))
    })
    const pillMatches = new Map<HTMLButtonElement, string[]>()
    pills.forEach(pill => {
      const raw = pill.dataset.match
      pillMatches.set(pill, raw ? JSON.parse(raw) : [])
    })

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => {
          p.classList.remove('bg-teal-500', 'text-black')
          p.classList.add('bg-white/5', 'text-white/60')
        })
        pill.classList.remove('bg-white/5', 'text-white/60')
        pill.classList.add('bg-teal-500', 'text-black')

        const category = pill.dataset.category
        const matchTerms = pillMatches.get(pill) || []

        let visible = 0
        items.forEach(item => {
          const cuisines = itemCuisines.get(item) || []
          const show = category === 'all' || matchTerms.some(term =>
            cuisines.some(c => c.toLowerCase().includes(term.toLowerCase()))
          )
          item.style.display = show ? '' : 'none'
          if (show) visible++
        })

        if (countEl) countEl.textContent = `${visible} מסעדות`
        if (noResults) noResults.classList.toggle('hidden', visible > 0)
      })
    })
  })
</script>
