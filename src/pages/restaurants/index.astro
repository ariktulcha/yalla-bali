---
import Layout from '../../components/Layout.astro'
import RestaurantCard from '../../components/Cards/RestaurantCard.astro'
import RestaurantCategoryNav from '../../components/RestaurantCategoryNav.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import SchemaOrg from '../../components/SchemaOrg.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const restaurants = items || []

const title = 'מסעדות בבאלי — המדריך המלא | יאללה באלי'
const description = 'מדריך מסעדות מקיף בבאלי לפי איזורים וסגנונות — סמיניאק, אובוד, צ׳נגו, כשר, יפנית, פיין דיינינג, טבעוני ועוד. המלצות אמיתיות עם כתובות, מחירים ודירוגים.'

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מסעדות' },
]

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מסעדות בבאלי',
  description,
  numberOfItems: restaurants.length,
  itemListElement: restaurants.slice(0, 30).map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: r.name_he,
    url: `https://ibalibali.com/restaurants/${r.slug}`,
  })),
}
---

<Layout title={title} description={description}>
  <SchemaOrg schema={schemaItemList} />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <RestaurantCategoryNav currentSlug="all" />

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-5xl font-black text-white mb-4">מסעדות בבאלי</h1>
      <p class="text-white/60 max-w-3xl mx-auto leading-relaxed">
        באלי מארחת אלפי מסעדות — מפיין דיינינג מהמובילות באסיה ועד ווארונגים מקומיים אותנטיים.
        מטבח יפני, איטלקי, צרפתי, ישראלי, טבעוני וכשר-סטייל — הכל כאן.
        בחרו באיזור או סגנון בניווט למעלה, או גלו את כל המסעדות ברשימה למטה.
      </p>
      <p class="mt-3 text-teal-400 font-medium text-sm">{restaurants.length} מסעדות</p>
    </header>

    {restaurants.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {restaurants.map(r => (
          <RestaurantCard
            name_he={r.name_he}
            name_en={r.name_en}
            slug={r.slug}
            image={r.image}
            area={r.area}
            cuisine_types={r.cuisine_types}
            price_range={r.price_range}
            rating={r.rating}
            excerpt={r.excerpt}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו מסעדות כרגע.</p>
    )}
  </main>
</Layout>
