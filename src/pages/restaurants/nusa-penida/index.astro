---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Nusa Penida')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בנוסה פנידה?', a: 'נוסה פנידה היא אי קטן ומקסים עם סצנה קולינרית צומחת. המובילות: פנידה קולדה (בר חוף אייקוני עם מוסיקה חיה), מאמבו ביץ\' רסטורנט, סיקרט פנידה (בינלאומי-בלינזי), דה צ\'יל פנידה (אסייתי), ואיסטסייד פנידה (בלינזי-אינדונזי).' },
  { q: 'האם יש הרבה אופציות קולינריות בנוסה פנידה?', a: 'נוסה פנידה מתפתחת מהר, ויש הרבה יותר מסעדות משנה לשנה. רוב המסעדות מרוכזות בכפר Ped (שבצפון האי, ליד הנמל) וב-Toyapakeh. במערב האי (בסמוך ל-Crystal Bay) יש פחות מסעדות. המרחב הדרומי (Kelingking, Diamond Beach) כמעט לא מאוכלס.' },
  { q: 'כמה עולה ארוחה בנוסה פנידה?', a: 'נוסה פנידה זולה יחסית: ארוחה במסעדה קז\'ואלית 80,000-150,000 רופי לאדם (20-40 ש"ח), ארוחה טובה 150,000-300,000 רופי (40-80 ש"ח). בבר חוף טרנדי כמו פנידה קולדה — 200,000-400,000 רופי עם קוקטייל.' },
  { q: 'איך מגיעים לנוסה פנידה?', a: 'הדרך היחידה לנוסה פנידה היא סירת מהירה (Fast Boat) מסאנור או מבליאטונג. הנסיעה 45-60 דקות, עולה 200,000-400,000 רופי לכיוון. באי עצמו — חובה להשכיר סקוטר (70,000-100,000 רופי ליום) או להזמין נהג (500,000-700,000 רופי ליום).' },
  { q: 'האם כדאי לאכול בבר חוף בנוסה פנידה?', a: 'בהחלט — פנידה קולדה היא חובה לסוף יום של טיולים. הנוף על הים, האי באלי ברקע והר אגונג בצלעה מעוצם. המוסיקה חיה כל ערב מ-19:00. האפי האוור 16:00-18:00. אחת האופציות הטובות ביותר בנוסה פנידה.' },
  { q: 'האם יש בעיית מים במסעדות בנוסה פנידה?', a: 'נוסה פנידה היא אי חצי-מפותח, וחשוב לשתות רק מים מינרלים בבקבוק. במסעדות הטובות (פנידה קולדה, סיקרט פנידה) המים מסוננים והקרח בטוח. במסעדות פחות מוכרות — שאלו לפני. הקפידו על היגיינה.' },
  { q: 'האם צריך להזמין מקום בנוסה פנידה מראש?', a: 'בדרך כלל לא חובה. נוסה פנידה פחות רשמית, ורוב המסעדות מקבלות Walk-in. יוצא מכלל — פנידה קולדה לשעת השקיעה בסוף שבוע עשויה להיות עמוסה. במקרה הזה הגיעו 30-60 דקות לפני השקיעה או הזמינו בטלפון מראש.' },
  { q: 'האם נוסה פנידה מתאימה למשפחות?', a: 'נוסה פנידה היא יעד מתגבר, ומתאימה גם למשפחות עם ילדים גדולים יותר (8+). האיים קטנים, החופים יפים, אבל הנסיעה בסקוטר או הרכב הפרטי בדרכים קרעוסות עלולה להיות מאתגרת. למשפחות עם ילדים קטנים — מומלץ להישאר בבאלי.' },
  { q: 'מה הסגנון הקולינרי של נוסה פנידה?', a: 'נוסה פנידה היא אי קטן עם אווירה משוחררת של סיור ייחודי. הסגנון — בינלאומי-תיירותי, עם מטבח בלינזי מסורתי, פירות ים, בארים על החוף, וקפה של תרבות סירפים. האוכל לא מתחרה עם המטבח של באלי העיקרי אבל לגמרי טעים.' },
  { q: 'איפה נמצאת פנידה קולדה?', a: 'פנידה קולדה נמצאת בכפר Ped, בצפון-צפון-מזרח האי, במרחק של כ-15 דקות נסיעה מהנמל (Toyapakeh Port). זה באלי השקיעה הטוב ביותר כי הוא פונה לכיוון מערב-צפון-מערב — רואים גם את באלי הגדולה וגם את הר אגונג בשעת שקיעה.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בנוסה פנידה — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בנוסה פנידה: פנידה קולדה (בר חוף אייקוני), מאמבו ביץ׳, סיקרט פנידה, דה צ׳יל פנידה. סצנה קולינרית קטנה אבל איכותית על האי הקסום של באלי."
  h1="מסעדות בנוסה פנידה"
  intro="נוסה פנידה היא אי קטן ומקסים, והסצנה הקולינרית שלו מתפתחת מהר. מבר החוף האייקוני פנידה קולדה (עם מוסיקה חיה ושקיעה מעל אגונג), דרך מסעדות פירות ים במאמבו ביץ׳, ועד למטבח בלינזי אותנטי באיסטסייד פנידה — האי מציע חוויות קולינריות ייחודיות."
  items={items}
  faq={faq}
  categorySlug="nusa-penida"
  breadcrumbLabel="נוסה פנידה"
  schemaName="מסעדות בנוסה פנידה"
  faqHeading="שאלות נפוצות — מסעדות בנוסה פנידה"
/>
