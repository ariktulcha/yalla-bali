---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Kuta')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בקוטה?', a: 'קוטה היא אזור תיירותי-ותיק עם תערובת של מסעדות תיירותיות ומוסדות מקומיים. המובילות כוללות את מאדה\'ס וארונג (מוסד משנת 1969), בלה אודנג (פירות ים אינדונזים), סוקון (מטבח בלינזי מסורתי), ובורדווק (בינלאומי על החוף).' },
  { q: 'איפה הכי טוב לאכול על חוף קוטה?', a: 'בורדווק רסטורנט ממש על חוף קוטה מציעה נוף לאוקיינוס עם תפריט בינלאומי. גם Hard Rock Cafe, Ma Joly ו-Discovery Cafe נמצאים במרחק הליכה מהחוף. לחוויה יותר אותנטית — מאדה\'ס וארונג קצת פנימה מהחוף.' },
  { q: 'כמה עולה ארוחה בקוטה?', a: 'קוטה היא מהזולות יחסית באזור הדרום: ווארונג מקומי 30,000-70,000 רופי (8-18 ש"ח), מסעדה תיירותית טובה 100,000-250,000 רופי (25-70 ש"ח), ומסעדה על החוף 200,000-400,000 רופי (55-110 ש"ח).' },
  { q: 'האם קוטה מתאימה למשפחות?', a: 'בהחלט — קוטה היא אחד האזורים המתאימים ביותר למשפחות בבאלי. המסעדות ידידותיות לילדים, התפריט בינלאומי ומגוון, והמחירים הוגנים. ספציפית: מאדה\'ס וארונג, בורדווק, Hard Rock, Pizza Hut, וסוקון כולן טובות למשפחות.' },
  { q: 'איפה הרחובות הקולינריים המרכזיים בקוטה?', a: 'הרחובות המרכזיים בקוטה הם Jalan Pantai Kuta (רחוב החוף, עם בורדווק, מאדה\'ס), Jalan Legian (מרכז בילוי עם מסעדות ובארים), ו-Jalan Kartika Plaza (אזור יותר שקט עם מסעדות משפחתיות).' },
  { q: 'האם יש מסעדות כשרות בקוטה?', a: 'אין מסעדות כשרות ייעודיות בקוטה. אופציות ידידותיות לישראלים: מסעדות טבעוניות/צמחוניות, מסעדות פיצה (כשרות חלקית), ומסעדות הודיות. לארוחה כשרה אמיתית — בית חב"ד באלי בסמיניאק הסמוכה (30 דק\' נסיעה).' },
  { q: 'מהו וארונג?', a: 'וארונג (Warung) הוא מסעדה מקומית באלינזית/אינדונזית — פשוטה, זולה, אותנטית. מגישים מנות בסיס כמו נאסי גורנג (אורז מטוגן), מיי גורנג (נודלס), סאטה, ונאסי קמפור (אורז עם מגוון מנות קטנות). מאדה\'ס וארונג הוא הוארונג הכי מפורסם בבאלי.' },
  { q: 'מה זה נאסי קמפור?', a: 'נאסי קמפור (Nasi Campur) הוא מנה אינדונזית קלאסית — אורז לבן עם מבחר קטן מכל מנה על הצלחת: עוף, בקר, ירקות, פיצוחים, ביצה, ותבלינים. זה "כל מה שטעים על צלחת אחת". מאדה\'ס וארונג בקוטה מפורסמת בנאסי קמפור ספציאליסטי.' },
  { q: 'האם צריך להזמין מקום בקוטה מראש?', a: 'בדרך כלל לא חובה. קוטה היא אזור לא-יוקרתי, ורוב המסעדות מקבלות Walk-in. במסעדות פופולריות מאוד בערב (מאדה\'ס וארונג, בורדווק) בסופי שבוע כדאי להזמין, אבל זה לא קריטי.' },
  { q: 'מה הסגנון הקולינרי של קוטה?', a: 'קוטה היא התיירות הוותיקה של באלי — תערובת של מטבח אינדונזי אותנטי (וארונגים, נאסי, סאטה), מטבח בינלאומי (פיצה, פאסטה, המבורגרים), ואוכל על החוף. האווירה פחות טרנדית מסמיניאק אבל יותר אותנטית ועממית.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בקוטה — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בקוטה: מאדה׳ס וארונג (משנת 1969), בלה אודנג, סוקון, בורדווק ועוד. מטבח אינדונזי אותנטי, וארונגים מסורתיים ומחירים הוגנים במרכז התיירות הוותיק."
  h1="מסעדות בקוטה"
  intro="קוטה היא התיירות הוותיקה של באלי — אזור עם ריבוי וארונגים אותנטיים, מטבח בלינזי ואינדונזי מסורתי, ומחירים הוגנים במיוחד. מהוארונג האגדי מאדה׳ס (משנת 1969) ועד מסעדות פירות ים וחוף, קוטה מושלמת למשפחות ולטיול ראשון בבאלי."
  items={items}
  faq={faq}
  categorySlug="kuta"
  breadcrumbLabel="קוטה"
  schemaName="מסעדות בקוטה"
  faqHeading="שאלות נפוצות — מסעדות בקוטה"
/>
