---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = [
  'יפנית', 'יפני', 'japanese', 'Japanese',
  'סושי', 'איזאקאיה', 'איזקאיה',
  'טפניאקי', 'יקיניקו', 'גיוקאטסו', 'אומקאסה', 'קאיסקי',
  'סשימי', 'יפני-קוריאני',
]
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן מסעדות הסושי והיפניות הטובות ביותר בבאלי?', a: 'מסעדות הסושי והיפניות הטובות ביותר בבאלי כוללות את טאקומי (סמיניאק, אומקאסה ברמה עולמית), סושימי (סושי טריין כיף למשפחות), רייג\'ין (טפניאקי), שיצ\'ירין (גיוקאטסו וטפניאקי), קאג\'ין (סושי אינטימי) ואדוגין במוליה נוסה דואה.' },
  { q: 'כמה עולה אומקאסה בבאלי?', a: 'אומקאסה בבאלי עולה בין 1,500,000 ל-2,500,000 רופי לאדם (400-680 ש"ח). טאקומי היא היקרה עם 18 מנות ב-2,500,000 רופי. יש אופציות זולות יותר כמו סושימי במחירי סושי טריין (20,000-50,000 רופי לצלחת).' },
  { q: 'איפה הכי טוב לאכול סושי בבאלי?', a: 'הריכוז העיקרי של מסעדות סושי טובות בבאלי הוא בסמיניאק, במיוחד על פטיטנגט (טאקומי, רייג\'ין, שיצ\'ירין, קאג\'ין). באי הדרומי יש גם את אדוגין במלון מוליה בנוסה דואה עם רמה בינלאומית.' },
  { q: 'האם צריך להזמין מקום במסעדה יפנית בבאלי מראש?', a: 'כן, מומלץ מאוד להזמין מקום מראש במסעדות יפנית פיין דיינינג בבאלי כמו טאקומי ואדוגין — לעיתים שבועות מראש. במסעדות כמו סושימי וריושי אפשר להגיע ללא הזמנה.' },
  { q: 'האם יש אומקאסה טבעוני או צמחוני בבאלי?', a: 'רוב מסעדות האומקאסה בבאלי מתמקדות בדגים טריים ובשר, אבל ניתן ליצור קשר מראש עם טאקומי או אדוגין כדי להתאים תפריט טבעוני. גם שיצ\'ירין מציעה אופציות ירק על הטפניאקי.' },
  { q: 'מה ההבדל בין סושי טריין לסושי בר בבאלי?', a: 'סושי טריין (כמו סושימי) זה קונספט שבו צלחות סובבות על סרט נע והצרכן לוקח מה שרוצה — זול וכיף למשפחות. סושי בר (כמו קאג\'ין) זה חוויה אינטימית מול השף שמכין את הסושי בזמן אמת — איכות גבוהה יותר, אווירה שקטה.' },
  { q: 'מה זה גיוקאטסו?', a: 'גיוקאטסו (Gyukatsu) הוא קציצת בקר ואגיו עטופה בפירורי פאנקו ומטוגנת קצרה — הבשר בפנים רזה ורך. מסעדת שיצ\'ירין בסמיניאק מתמחה בגיוקאטסו, חוויה ייחודית שלא רואים בדרך כלל בישראל.' },
  { q: 'האם מסעדות יפניות בבאלי מתאימות למשפחות?', a: 'סושימי (סושי טריין), ריושי והאדוגין הן מצוינות למשפחות עם ילדים — אווירה קז\'ואלית ותפריט מגוון. אומקאסה אינטימית (טאקומי, קאג\'ין) פחות מתאימה לילדים קטנים בגלל אורך הארוחה.' },
  { q: 'מה זה אומקאסה?', a: 'אומקאסה (Omakase) היא חוויית טעימה יפנית שבה הצרכן מפקיד את הבחירה בידי השף — 15-20 מנות של הסושי וסשימי הטוב ביותר באותו יום. בבאלי, טאקומי ואדוגין מציעות את חוויות האומקאסה הטובות ביותר.' },
  { q: 'האם יש מסעדות יפניות באלי עם ג\'אז חי?', a: 'ריושי סמיניאק (House of Jazz) מציעה ג\'אז חי בימי שני ושישי מ-21:00. זו מסעדה ותיקה (משנות ה-90) עם תפריט סושי וסשימי במחירים הוגנים ואווירה נוסטלגית.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות יפניות וסושי בבאלי | יאללה באלי"
  pageDescription="מדריך למסעדות היפניות הטובות ביותר בבאלי: טאקומי, סושימי, רייג׳ין, שיצ׳ירין, קאג׳ין, ריושי ואדוגין. סושי, אומקאסה, טפניאקי וגיוקאטסו ברמה עולמית."
  h1="מסעדות יפניות וסושי בבאלי"
  intro="באלי מציעה סצנת מסעדות יפנית ברמה עולמית — מהאומקאסה המובילה באי בטאקומי, דרך הטפניאקי המרהיב ברייג׳ין, ועד הסושי טריין הכיפי לכל המשפחה בסושימי. הרוב המוחלט מרוכז בסמיניאק, אזור פטיטנגט, אבל יש גם אופציות יוקרה בנוסה דואה."
  items={items}
  faq={faq}
  categorySlug="japanese"
  breadcrumbLabel="יפנית"
  schemaName="מסעדות יפניות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות יפניות בבאלי"
/>
