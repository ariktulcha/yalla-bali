---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = [
  'ים תיכוני', 'Mediterranean', 'mediterranean',
  'איטלקי', 'איטלקית', 'Italian',
  'ספרדי', 'ספרדית', 'Spanish',
  'צרפתי', 'צרפתית', 'French',
  'לטיני / ים תיכוני', 'יווני',
]
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן המסעדות הים תיכוניות הטובות ביותר בבאלי?', a: 'באלי מציעה סצנה ים-תיכונית עשירה. המובילות: מטיס (צרפתי-ים תיכוני בפביליון מעל ברכת לוטוסים, סמיניאק), לה לוצ\'ולה (איטלקי אגדי על חוף פטיטנגט), מאסימו בסאנור (האיטלקי האהוב בבאלי), מאורי (איטלקי מודרני פיין דיינינג), וסטימו צ\'לו (איטלקי רומנטי).' },
  { q: 'איפה הכי טוב לאכול פסטה איטלקית אמיתית?', a: 'מאסימו בסאנור הוא ללא ספק המקום הטוב ביותר — פסטה ביתית, פיצה אש עם תסיסה טבעית, מוצרלה טרי כל יום. יותר מ-12,000 ביקורות ב-Google. גם סטימו צ\'לו (סמיניאק) ומאורי (פיין דיינינג איטלקי) מגישים פסטה ביתית ברמה עולמית.' },
  { q: 'כמה עולה ארוחה איטלקית בבאלי?', a: 'מאסימו בסאנור הוגן: 200,000-400,000 רופי לאדם (55-110 ש"ח). סטימו צ\'לו: 400,000-800,000 רופי (110-220 ש"ח). מאורי (פיין דיינינג): 1,500,000-2,500,000 רופי לתפריט טעימה. לה לוצ\'ולה: 400,000-800,000 רופי.' },
  { q: 'האם יש מסעדות צרפתיות בבאלי?', a: 'כן, מספר מסעדות צרפתיות מצוינות. מטיס (סמיניאק) היא האיקון הצרפתי-ים תיכוני עם 350 מקומות בפביליון מעל ברכת לוטוסים. גוסברי באולוואטו (צרפתי-בינלאומי), רו באלי בסאנור (צרפתי-אירופי), ולה בראסרי בג\'ימבאראן (פיוז\'ן צרפתי-אסייתי).' },
  { q: 'מהי לה לוצ\'ולה ומדוע היא אגדית?', a: 'לה לוצ\'ולה היא מוסד איטלקי על חוף פטיטנגט בן 30 שנה, ליד מקדש פטיטנגט מהמאה ה-15. היא מגישה בישול איטלקי אזורי בפביליון קש פתוח עם נוף לאוקיינוס ההודי. ערב השקיעה שם הוא טקס מעבר אגדי בבאלי — הזמינו שולחן ל-18:00 וצפו באוקיינוס הופך לזהב.' },
  { q: 'האם יש מסעדות ספרדיות בבאלי?', a: 'כן, אל קברון באולוואטו היא המסעדה הספרדית האייקונית — טאפאס ופאיה על הצוקים מעל הים. לה בריסה בצ\'נגו מציעה ספרדי-ים-תיכוני בסגנון ביץ\' קלאב. קוקה (Cuca) בג\'ימבאראן — טאפאס גורמה יצירתי. סנטנרה בצ\'נגו — לטיני/ים תיכוני.' },
  { q: 'מהו פיין דיינינג איטלקי בבאלי?', a: 'מאורי (Mauri) בסמיניאק הוא פיין דיינינג האיטלקי המוביל בבאלי. השף מאוריציו בומבני מגיש תפריטי טעימה עונתיים שחוגגים את פוליה (אזור הולדתו), עם עשבי תיבול מהגן ההידרופוני של המסעדה. זו חוויה שמשתווה לפיין דיינינג של מילאנו.' },
  { q: 'האם מסעדות איטלקיות בבאלי מתאימות למשפחות?', a: 'בהחלט. מאסימו בסאנור הוא אידיאלי למשפחות — פיצה, פסטה, גלידה איטלקית ביתית שהילדים אוהבים. לה לוצ\'ולה עם הישיבה על החוף גם נהדרת למשפחות. המחירים הוגנים והתפריט מוכר לילדים ישראלים.' },
  { q: 'איך קרה שיש כל כך הרבה איטלקים בבאלי?', a: 'באלי משכה קהילה גדולה של שפים ושפיות איטלקים בעשורים האחרונים. מאסימו (1996), לה לוצ\'ולה (30 שנה), מאורי, מטיס (שף צרפתי), וסטימו צ\'לו — כולם מנוהלים על ידי איטלקים אמיתיים. התוצאה: בבאלי האיטלקי האותנטי ברמה של איטליה עצמה.' },
  { q: 'מה הסגנון הים תיכוני הפופולרי ביותר בבאלי?', a: 'איטלקי הוא הסגנון הים תיכוני הפופולרי ביותר בבאלי, אחריו צרפתי. רוב המסעדות הים תיכוניות נמצאות בסמיניאק (מטיס, לה לוצ\'ולה, מאורי, סטימו צ\'לו), ובסאנור (מאסימו, מוצה). אולוואטו ואובוד מציעות אופציות פחות רבות אבל איכותיות.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות ים תיכוניות בבאלי — איטלקי, צרפתי וספרדי | יאללה באלי"
  pageDescription="מדריך מסעדות ים תיכוניות בבאלי: מאסימו (איטלקי אהוב), לה לוצ׳ולה (חוף פטיטנגט), מטיס (צרפתי-ים תיכוני), מאורי, אל קברון ועוד. פסטה ביתית, פיצה אש ופיין דיינינג."
  h1="מסעדות ים תיכוניות בבאלי"
  intro="באלי הפכה ליעד מרכזי לקולינריה ים-תיכונית — איטלקית, צרפתית וספרדית. קהילה גדולה של שפים איטלקים (מאסימו 1996, לה לוצ׳ולה 30 שנה, מאורי), ומסעדות צרפתיות אייקוניות (מטיס, גוסברי, רו באלי), ממקמות את באלי בין המסעדות הים תיכוניות הטובות באסיה."
  items={items}
  faq={faq}
  categorySlug="mediterranean"
  breadcrumbLabel="ים תיכוני"
  schemaName="מסעדות ים תיכוניות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות ים תיכוניות בבאלי"
/>
