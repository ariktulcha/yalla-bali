---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Sanur')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בסאנור?', a: 'סאנור מפורסמת בסצנה משפחתית ואיכותית. המובילות: מאסימו (האיטלקי האהוב בבאלי עם גלידה מפורסמת), מוצה סאנור (פיצה איטלקית), קוסטה (ים תיכוני על הים), קאלומה (אינדונזי-פירות ים), ורו באלי (צרפתי-אירופאי).' },
  { q: 'כמה עולה ארוחה בסאנור?', a: 'סאנור הוגן יחסית: ארוחה במסעדה קז\'ואלית 100,000-250,000 רופי לאדם (25-70 ש"ח), ארוחה טובה 300,000-500,000 רופי (80-140 ש"ח). מאסימו, הפופולרי ביותר, הוא 200,000-400,000 רופי לאדם — הוגן ואיכותי.' },
  { q: 'מהי מאסימו בסאנור?', a: 'מאסימו הוא המסעדה האיטלקית האהובה ביותר בבאלי, פועלת בסאנור מאז 1996. מפורסמת בפסטה ביתית, פיצה אש עם תסיסה טבעית, מוצרלה טרי כל יום, והגלידה הטובה ביותר בבאלי. תמיד יש תור, ולא בכדי.' },
  { q: 'האם סאנור מתאימה למשפחות?', a: 'בהחלט — סאנור נחשבת לאחד האזורים המשפחתיים ביותר בבאלי. המסעדות ידידותיות לילדים, הים שקט (עם שוניות מגנות), ויש מגוון רחב של מסעדות אוכל מוכר לילדים: פיצה, פאסטה, גלידה, והמבורגרים.' },
  { q: 'האם צריך להזמין מקום במאסימו?', a: 'כדאי. מאסימו הוא פופולרי במיוחד בערבים ובסופי שבוע, עם יותר מ-12,000 ביקורות ב-Google. בעונת השיא (יולי-אוגוסט, דצמבר-ינואר) תור של חצי שעה ויותר זה רגיל. הזמנה מראש מומלצת לערב שישי/שבת.' },
  { q: 'איפה הרחובות הקולינריים בסאנור?', a: 'הרחוב המרכזי של סאנור הוא Jalan Danau Tamblingan — שם מרוכזות רוב המסעדות, כולל מאסימו, מוצה, רו באלי. גם Jalan Mertasari (אזור חוף Mertasari) מציע מסעדות על החוף. החוף של סאנור ארוך 5 קילומטר ומלא מסעדות.' },
  { q: 'איפה הכי טוב לאכול על החוף בסאנור?', a: 'קוסטה (COSTA) היא הבחירה המובילה לארוחת ערב רומנטית על החוף. גם The Porch Cafe, Genius Cafe, וCafe Batujimbar הן אופציות מעולות. החוף של סאנור מתאים לארוחות בוקר שלווה וארוחות ערב עם שקיעה מעל הים (צד מזרחי — זריחה מעל הים).' },
  { q: 'האם יש מסעדות ישראליות בסאנור?', a: 'אין מסעדה ישראלית ייעודית בסאנור. לארוחה ישראלית יש ללכת לסבבה בצ\'נגו (כשעה נסיעה). מסעדות טבעוניות/צמחוניות בסאנור מתאימות לישראלים: Soul in a Bowl, Cafe Organic סאנור, ועוד. גם מסעדות איטלקיות (מאסימו, מוצה) מוכרות וידידותיות.' },
  { q: 'מה הסגנון הקולינרי של סאנור?', a: 'סאנור היא השקטה והאיכותית של האי — סצנה משפחתית-הגונה יחסית לסמיניאק. דגש על מטבח איטלקי (מאסימו, מוצה), ים תיכוני (קוסטה, רו באלי), פירות ים (קאלומה), ומטבח אינדונזי מסורתי. פחות טרנדי, יותר אמיתי.' },
  { q: 'איך מגיעים למסעדות בסאנור?', a: 'סאנור היא רצועה ארוכה לאורך הים — כל המסעדות על Jalan Danau Tamblingan או קרוב אליו. Grab/Gojek הן הדרך הטובה לתוך סאנור ובתוכה (10,000-30,000 רופי לנסיעה). גם הליכה מעל חוף סאנור (The Esplanade) היא אופציה נחמדה בבוקר/ערב.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בסאנור — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בסאנור: מאסימו (איטלקי אהוב עם גלידה), מוצה, קוסטה, קאלומה ורו באלי. סצנה משפחתית-איכותית לצד הים, מחירים הוגנים והמלצות מדריך."
  h1="מסעדות בסאנור"
  intro="סאנור היא השקטה והאיכותית של האי — סצנה משפחתית-איכותית לצד הים, עם דגש חזק על מטבח איטלקי (מאסימו, האהוב בבאלי), ים תיכוני ומטבח אינדונזי מסורתי. אווירה פחות טרנדית מסמיניאק, יותר אמיתית ומשפחתית."
  items={items}
  faq={faq}
  categorySlug="sanur"
  breadcrumbLabel="סאנור"
  schemaName="מסעדות בסאנור"
  faqHeading="שאלות נפוצות — מסעדות בסאנור"
/>
