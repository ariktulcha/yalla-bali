---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Amed')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר באמד?', a: 'אמד היא כפר דייגים שקט במזרח באלי, עם סצנה קולינרית קטנה אבל מיוחדת. המובילות: גרין מלון ווארונג (בלינזי-אינדונזי אותנטי 5/5), סיילס רסטורנט (אלגנטי על הים), גלנגה, ווארונג אגונג אמד, ומסעדת אסמט.' },
  { q: 'למה אמד היא יעד מעניין?', a: 'אמד היא יעד צלילה עולמי — "Japanese Wreck" (ספינה יפנית שקעה), "USAT Liberty" (ספינת מלחמה אמריקאית ב-Tulamben), ושוניות אלמוגים עשירות. האזור הרבה יותר שקט ואותנטי מדרום באלי, עם אוכל במחירים נמוכים משמעותית.' },
  { q: 'כמה עולה ארוחה באמד?', a: 'אמד זולה משמעותית מסמיניאק/אובוד: ווארונג מקומי 25,000-50,000 רופי לאדם (6-14 ש"ח), מסעדה טובה 80,000-200,000 רופי (20-55 ש"ח). סיילס רסטורנט (האלגנטית) — 250,000-500,000 רופי לאדם.' },
  { q: 'איך מגיעים לאמד?', a: 'אמד נמצאת במזרח באלי, כ-3 שעות נסיעה מסמיניאק ו-2 שעות מאובוד. הדרך ציורית עם הרבה עצירות. אפשר להזמין נהג פרטי (600,000-900,000 רופי לכיוון), לשכור רכב, או להגיע ב-Perama Shuttle (מיני-באס ציבורי, 175,000 רופי). מומלץ לינה לפחות לילה.' },
  { q: 'האם יש מסעדות טבעוניות באמד?', a: 'רוב המסעדות באמד מגישות מטבח בלינזי-אינדונזי מסורתי. אופציות טבעוניות מוגבלות יחסית לסמיניאק/אובוד, אבל ברוב הווארונגים אפשר להזמין נאסי גורנג ירק, מי גורנג ירק, גאדו-גאדו (סלט ירקות עם רוטב בוטנים). מסעדות כמו Warung Boni מציעות אופציות טבעוניות.' },
  { q: 'מה המיוחד בגרין מלון ווארונג?', a: 'גרין מלון ווארונג באמד זכתה לדירוג מושלם של 5/5 — נדיר ביותר. זה ווארונג משפחתי שמנוהל על ידי אמא ובתה, עם אוכל ביתי אותנטי, חומרי גלם טריים מהגן הפרטי, ומחירים הוגנים במיוחד. חובה למי שמבקר באמד.' },
  { q: 'האם צריך להזמין מקום באמד מראש?', a: 'בדרך כלל לא. אמד היא אזור לא תיירותי-יוקרתי, ורוב הווארונגים מקבלים Walk-in. במסעדות הפופולריות (גרין מלון, סיילס) בעונת השיא (יולי-אוגוסט) כדאי להזמין 1-2 ימים מראש בטלפון.' },
  { q: 'האם אמד מתאימה לצמאים/צוללים?', a: 'בהחלט — אמד היא יעד הצלילה המוביל של באלי. אחרי יום צלילה, המסעדות המקומיות הן חוויה לעצמן. סיילס רסטורנט מציעה אפילו שירות איסוף חינם מהמלון (בדקו בהזמנה), ואוכל אירופי-אסייתי איכותי. חוויה של אחרי צלילה.' },
  { q: 'מה הסגנון הקולינרי של אמד?', a: 'אמד = מטבח בלינזי אותנטי + פירות ים. בכפר הדייגים הזה, ווארונגים משפחתיים מגישים מנות מסורתיות (נאסי קמפור, סאטה, נאסי גורנג, פירות ים על האש), לצד מסעדות אירופיות קטנות שצצות בשנים האחרונות. אווירה שקטה ואותנטית.' },
  { q: 'האם ניתן ללון ליד מסעדה באמד?', a: 'רוב המסעדות של אמד מחוברות להומסטיי או לקוטג\'ים קטנים. חברות כמו Warung Agung, Warung Boni, וסיילס — כולן מציעות לינה פשוטה לצד המסעדה. זו חוויה מיוחדת של "לינה בחיק הטבע".' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות באמד — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות באמד (מזרח באלי): גרין מלון ווארונג (5/5 מושלם), סיילס רסטורנט, גלנגה ומסעדות מקומיות אותנטיות. מחירים הוגנים וסצנה קולינרית שקטה בכפר הדייגים."
  h1="מסעדות באמד"
  intro="אמד היא פנינה שקטה במזרח באלי — כפר דייגים עם סצנה קולינרית אותנטית, מחירים נמוכים משמעותית, ומסעדות משפחתיות מיוחדות. הדירוג המושלם של גרין מלון ווארונג (5/5) מעיד על איכות האוכל הביתי האמיתי. אמד מושלמת לצוללים ולמי שמחפש את האי בפחות תיירות."
  items={items}
  faq={faq}
  categorySlug="amed"
  breadcrumbLabel="אמד"
  schemaName="מסעדות באמד"
  faqHeading="שאלות נפוצות — מסעדות באמד"
/>
