---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Uluwatu')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר באולוואטו?', a: 'אולוואטו מציעה חוויות קולינריות ייחודיות על צוקים מעל האוקיינוס. המובילות: אל קברון (ספרדי עם נוף אגדי לשקיעה), סינגל פין (בר אייקוני על צוקי הסירף), אולו גארדן (ים תיכוני), גוסברי (צרפתי), ארטיזן (מטבח מודרני), ואלקמי (טבעוני).' },
  { q: 'איפה הכי טוב לשקיעה באולוואטו?', a: 'אולוואטו מפורסמת בשקיעות המרהיבות ביותר בבאלי — על הצוקים מעל הים. סינגל פין הוא הבר האייקוני לשקיעה, אל קברון מציע ארוחת ערב רומנטית על הצוק, וThe Edge (במלון The Edge) מציעה בריכת אינסוף על הצוק עם שקיעה מעל האוקיינוס.' },
  { q: 'כמה עולה ארוחה באולוואטו?', a: 'אולוואטו יוקרתית יחסית: ארוחה טובה 300,000-600,000 רופי לאדם (80-165 ש"ח), ארוחה על הצוק 500,000-1,200,000 רופי (140-330 ש"ח). בסינגל פין יותר קז\'ואלי — 200,000-400,000 רופי.' },
  { q: 'איפה נמצאות מסעדות אולוואטו?', a: 'אולוואטו מחולקת לכמה אזורים: Pecatu-Suluban (סינגל פין, מסעדות סירף), Bingin Beach (קטנה ואינטימית), Padang Padang, ואזור המקדש (Pura Luhur Uluwatu). כל אזור עם מסעדות מסגנון שונה. רכב/גראב חיוני.' },
  { q: 'האם באולוואטו מתאים למשפחות?', a: 'אולוואטו יותר מתאימה לזוגות ולמטיילים סולו או עם ילדים גדולים. הצוקים הגבוהים, הגישה לחופים ב-100 מדרגות, והאווירה של סירף-חוף פחות מתאימה לילדים קטנים. אבל מלון כמו Mulia של נוסה דואה עם ילדים יש שם המון פעילויות.' },
  { q: 'איפה הכי טוב לאכול טבעוני באולוואטו?', a: 'אלקמי אולוואטו היא היחידה הטבעונית האמיתית באזור — מסעדת Raw Food אגדית עם בר סלטים, סופר-פוד, וסמודי בולים. גם כמה קפה שכונתיים במרחב אולוואטו מציעים אופציות טבעוניות.' },
  { q: 'מהי מסעדת סינגל פין?', a: 'סינגל פין הוא בר ומסעדה אייקונית על צוקי חוף Suluban באולוואטו, מעל אחד מגלי הסירף הטובים בעולם. הם מפורסמים ב"Sunday Sessions" — מסיבות DJ עם קהל של סירפים מכל העולם. התפריט קז\'ואלי: המבורגרים, פיצה, טאקו, וקוקטיילים.' },
  { q: 'האם צריך להזמין מקום באולוואטו מראש?', a: 'במסעדות הפיין דיינינג (אל קברון, גוסברי) מומלץ להזמין מראש, במיוחד לערב השקיעה. בסינגל פין אפשר להגיע רגיל, אבל בימי ראשון (Sunday Sessions) כדאי להגיע מוקדם. במסעדות אחרות — גישה חופשית.' },
  { q: 'מה הסגנון הקולינרי של אולוואטו?', a: 'אולוואטו מציעה סגנון ייחודי של "אוכל עם נוף" — מסעדות על צוקים מעל האוקיינוס, ים תיכוני, ספרדי, צרפתי, ופיין דיינינג עם שקיעה. בחופים: אוכל סירף קז\'ואלי (המבורגרים, פיצה, טאקו). האווירה משוחררת אבל איכותית.' },
  { q: 'איך מגיעים למסעדות באולוואטו?', a: 'אולוואטו היא שטח גדול ומסעדותיו פזורות. חובה רכב שכור, סקוטר או Grab. המרחקים בין המסעדות יכולים להיות 10-20 דקות נסיעה. טיפ: תכננו את הערב סביב מסעדה אחת ובר אחד, במקום לנוע בין מסעדות.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות באולוואטו — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות באולוואטו: אל קברון (ספרדי), סינגל פין (בר סירף אייקוני), גוסברי (צרפתי), אולו גארדן, ואלקמי (טבעוני). שקיעות מרהיבות וחוויות על הצוקים."
  h1="מסעדות באולוואטו"
  intro="אולוואטו מציעה את החוויות הקולינריות הדרמטיות ביותר בבאלי — מסעדות על צוקים מעל האוקיינוס, שקיעות אגדיות, ובר הסירפים האייקוני סינגל פין. ממטבח ספרדי-רומנטי באל קברון ועד פיין דיינינג צרפתי, אולוואטו היא יעד מיוחד לחובבי נוף."
  items={items}
  faq={faq}
  categorySlug="uluwatu"
  breadcrumbLabel="אולוואטו"
  schemaName="מסעדות באולוואטו"
  faqHeading="שאלות נפוצות — מסעדות באולוואטו"
/>
