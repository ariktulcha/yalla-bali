---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import RestaurantCard from '../../../components/Cards/RestaurantCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => ['Fine Dining', 'fine dining', 'fine-dining', 'פיין דיינינג', 'מולקולרי', 'מולקולרית'].includes(t))
)

const pageTitle = 'מסעדות Fine Dining בבאלי | Yalla Bali'
const pageDescription = 'מסעדות היוקרה והפיין דיינינג הטובות ביותר בבאלי. חוויות אוכל ברמה עולמית עם שפים מוכשרים ואווירה יוקרתית.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מסעדות Fine Dining בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/restaurants/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מסעדות', href: '/restaurants' },
  { label: 'Fine Dining' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/restaurants/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/restaurants/kosher/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">✡ כשר</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">Fine Dining</span>
      <a href="/restaurants/japanese/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🍣 יפנית</a>
      <a href="/restaurants/meat/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🥩 בשרים</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מסעדות Fine Dining בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי היא אחת מבירות הקולינריה של העולם, עם מסעדות פיין דיינינג שמציעות חוויות אוכל בלתי נשכחות.
        שפים מהשורה הראשונה, עיצוב מרהיב ותפריטים שמשלבים מסורת וחדשנות.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <RestaurantCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            cuisine_types={item.cuisine_types}
            price_range={item.price_range}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מסעדות פיין דיינינג כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מסעדות Fine Dining בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה ארוחה במסעדת פיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מחירי ארוחה במסעדות פיין דיינינג בבאלי נעים בין 300 ל-1,500 דירהם לאדם. מסעדות פיין דיינינג בבאלי מציעות תפריטי טעימות עם מחירים משתנים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם צריך להזמין מקום במסעדת יוקרה בבאלי מראש?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בהחלט. מסעדות פיין דיינינג מובילות בבאלי דורשות הזמנה מראש, לפעמים שבועות קדימה. יש מסעדות פיין דיינינג בבאלי שמתמלאות רבות חודשים קדימה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה קוד הלבוש בפיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב מסעדות פיין דיינינג בבאלי דורשות Smart Casual לפחות. קוד הלבוש בבאלי פיין דיינינג: אין כפכפים, מכנסיים קצרים או חולצות גופייה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה שפים כוכבי מישלן יש במסעדות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">לבאלי יש מספר מסעדות פיין דיינינג עם שפים בעלי כוכבי מישלן. מסעדות בבאלי של שפים מובילים בעולם מציעות חוויות קולינריות בלתי נשכחות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">אילו מטבחות מוצגים במסעדות פיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מסעדות פיין דיינינג בבאלי מציעות מטבחות מגוונים — צרפתי, איטלקי, עדכני, יפני ועוד. פיין דיינינג בבאלי משלב מטבח בינלאומי בגבוה ביותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש מסעדות פיין דיינינג כשרות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">חלק מהמסעדות הפיין דיינינג בבאלי מציעות אפשרויות כשרות. יש מסעדות פיין דיינינג בבאלי שיכולות להתאים לדרישות כשרות בהסכמה מראש.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מהו הדרס קוד של מטיילים בפיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מטיילים בבאלי לפיין דיינינג מומלצים להתחזות בלבוש פורמלי או Smart Casual. באלי פיין דיינינג דורשת לבוש עלוב וגמיש.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הממוצע מחיר וקטגוריה בפיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מסעדות פיין דיינינג בבאלי מחולקות לקטגוריות מחיר — מנומסות יותר (300-500 דירהם) עד יוקרתיות (1,000+ דירהם). פיין דיינינג בבאלי מתאים לכל תקציב.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איך בוחרים בין מסעדות פיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בחרו מסעדת פיין דיינינג בבאלי לפי השף, הטבח, האווירה וההערות. מסעדות פיין דיינינג בבאלי הטובות ביותר קיבלו דירוגים גבוהים מטיילים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה כלול בתפריט הטעימות של פיין דיינינג בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">תפריט הטעימות (tasting menu) בפיין דיינינג בבאלי כולל 6-12 מנות קטנות של קאלינריה מושקעת. מסעדות פיין דיינינג בבאלי עם תפריט טעימות מציעות חוויה גסטרונומית בלתי נשכחת.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים המלצה למסעדת יוקרה בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מסעדת Fine Dining בבאלי 🍽️')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
