---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = [
  'Fine Dining', 'fine dining', 'fine-dining', 'פיין דיינינג',
  'מולקולרי', 'מולקולרית', 'גורמה אירופית', 'טאפאס גורמה',
  'קינוחים גורמה', 'פיוז\'ן צרפתי-אסייתי', 'אינדונזי מודרני',
]
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן המסעדות הפיין דיינינג המובילות בבאלי?', a: 'מסעדות הפיין דיינינג המובילות בבאלי כוללות את לוקאבור NXT (אובוד, זוכת פרס Sustainable של אסיה 50), אפריטיף (אובוד), מוזאיק (אובוד), Room4Dessert ומג\'קאווי בסמיניאק. כל אחת מציעה חוויית טעימה ייחודית.' },
  { q: 'כמה עולה ארוחת פיין דיינינג בבאלי?', a: 'תפריט טעימה במסעדות פיין דיינינג בבאלי נע בין 1,500,000 ל-5,500,000 רופי לאדם (400-1,500 ש"ח). לוקאבור NXT היא היקרה ביותר עם תפריט 20 מנות, ומג\'קאווי הוא הזול יחסית עם תפריט 5 מנות.' },
  { q: 'האם צריך להזמין מקום בפיין דיינינג בבאלי מראש?', a: 'בהחלט. מסעדות פיין דיינינג מובילות בבאלי דורשות הזמנה מראש, לפעמים חודשים קדימה. לוקאבור NXT ואפריטיף נוטות להתמלא 2-3 חודשים מראש, במיוחד בעונת השיא (יולי-אוגוסט, דצמבר-ינואר).' },
  { q: 'מה קוד הלבוש בפיין דיינינג בבאלי?', a: 'רוב מסעדות פיין דיינינג בבאלי דורשות Smart Casual או Cocktail Attire. לא לובשים כפכפים, מכנסיים קצרים או חולצות גופייה. באפריטיף ומוזאיק מומלץ מאוד ללבוש חולצה מכופתרת ונעליים סגורות.' },
  { q: 'כמה כוכבי מישלן יש לבאלי?', a: 'אין מדריך מישלן רשמי לאינדונזיה עדיין, אבל מספר מסעדות פיין דיינינג בבאלי נחשבות לרמת מישלן. לוקאבור NXT זכתה בפרס Sustainable של אסיה 50 הטובים 2025, ואפריטיף נחשבת לקרובה ביותר ל-3 כוכבי מישלן באי.' },
  { q: 'איזו מסעדת פיין דיינינג באלי הכי מתאימה לזוג?', a: 'לערב רומנטי בפיין דיינינג באלי, מטיס בסמיניאק (צרפתי-ים תיכוני בפביליון מעל ברכה), אפריטיף (קסטל קולוניאלי), ומאורי (איטלקי מודרני) הן הבחירות הטובות ביותר. כולן מציעות שולחנות זוגיים אינטימיים.' },
  { q: 'האם יש מסעדות פיין דיינינג באלי עם תפריט צמחוני?', a: 'כן, מסעדות פיין דיינינג בבאלי מציעות תפריטי טעימה צמחוניים וטבעוניים. לוקאבור NXT מפורסמת בגישה היפר-מקומית לצמחי הארכיפלג, ואפריטיף מציעה דגוסטסיון צמחוני וטבעוני מלא. גם מוזאיק מתאימה את התפריט.' },
  { q: 'באיזה אזור של באלי יש את מסעדות הפיין דיינינג הטובות?', a: 'אובוד היא הבירה של פיין דיינינג בבאלי — לוקאבור NXT, אפריטיף, מוזאיק ו-Room4Dessert כולן שם. בסמיניאק יש מג\'קאווי ומאורי. הבחירה תלויה באווירה שמחפשים: ג\'ונגל (אובוד) או ים (סמיניאק).' },
  { q: 'מה כלול בתפריט טעימה בפיין דיינינג בבאלי?', a: 'תפריט טעימה בפיין דיינינג בבאלי כולל 5-20 מנות קטנות, לרוב עם זיווגי יין או קוקטיילים אופציונליים. באפריטיף התפריט נמשך 3-4 שעות, ובלוקאבור NXT החוויה נמשכת 4-5 שעות ויש אפשרות לינה בבקתות.' },
  { q: 'איך בוחרים בין מסעדות פיין דיינינג באלי?', a: 'בחרו מסעדת פיין דיינינג בבאלי לפי: סגנון המטבח (מודרני אינדונזי = לוקאבור, אירופי = אפריטיף, צרפתי = מטיס, איטלקי = מאורי), האווירה (ג\'ונגל או ים), התקציב, והזמינות. לכל אחת יש חוויה ייחודית.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות Fine Dining בבאלי | יאללה באלי"
  pageDescription="מדריך למסעדות הפיין דיינינג הטובות ביותר בבאלי: לוקאבור NXT, אפריטיף, מוזאיק, מטיס ומאורי. חוויות טעימה ברמה עולמית, תפריטי טעימה, מחירים וטיפים להזמנה."
  h1="מסעדות Fine Dining בבאלי"
  intro="באלי היא אחת מבירות הפיין דיינינג של אסיה, עם מסעדות שמציעות חוויות אוכל בלתי נשכחות. מאובוד ועד סמיניאק — שפים מהשורה הראשונה, תפריטי טעימה יצירתיים, עיצוב מרהיב ותפריטים שמשלבים מסורת עם חדשנות."
  items={items}
  faq={faq}
  categorySlug="fine-dining"
  breadcrumbLabel="Fine Dining"
  schemaName="מסעדות Fine Dining בבאלי"
  faqHeading="שאלות נפוצות — מסעדות Fine Dining בבאלי"
/>
