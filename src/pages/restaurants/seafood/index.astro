---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = ['פירות ים', 'seafood', 'Seafood']
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'איפה הכי טוב לאכול פירות ים בבאלי?', a: 'היעד האגדי של פירות ים בבאלי הוא חוף ג\'ימבאראן (Muaya Beach) — עשרות מסעדות על החוף, שולחנות בחול, ודגים טריים שנאכלים תוך שקיעה. המובילות: מנגה קפה, באוונג מרה, סונדארה (במלון פור סיזנס), וקוסטה בסאנור.' },
  { q: 'כמה עולה ארוחת פירות ים בבאלי?', a: 'בג\'ימבאראן על החוף: פלטת פירות ים ל-2 אנשים 600,000-1,200,000 רופי (165-330 ש"ח). לובסטר 400,000-800,000 רופי. ארוחה ברמת מסעדה 300,000-600,000 רופי לאדם. המחירים תלויים בדגים הטריים של היום.' },
  { q: 'האם הדגים בבאלי טריים?', a: 'כן, מאוד. באלי מוקפת באוקיינוס והדגים נתפסים ביום הגשה. במסעדות חוף מובילות (מנגה קפה, באוונג מרה, סונדארה) הדגים מוצגים בקרח והלקוחות בוחרים לפני שהם נצלים. זה שיטת הבחירה החתימה של בשר בבאלי.' },
  { q: 'איזה דגים פופולריים בבאלי?', a: 'הדגים הפופולריים בבאלי: סנאפר (Red Snapper), מאהי מאהי, טונה, גרופר, לובסטר, שרימפס, ודג גריל. במסעדות בלינזיות פופולריים גם "Pepes Ikan" — דג מעוטף בעלי בננה עם תבלינים.' },
  { q: 'האם צריך להזמין מקום במסעדות פירות ים?', a: 'במסעדות הפיין דיינינג (סונדארה, קוקה, פאסיר) — בהחלט. בג\'ימבאראן על החוף (מנגה, באוונג מרה) בדרך כלל לא חובה, אבל בעונת השיא ובסופי שבוע עדיף להזמין לפחות שולחן ראשון מול הים.' },
  { q: 'איפה הכי טוב לאכול לובסטר בבאלי?', a: 'לובסטר בבאלי מגיש במיטבו במסעדות פירות ים על חוף ג\'ימבאראן (מנגה קפה, באוונג מרה) — על הגריל עם חמאה ושום. גם סונדארה וקוקה מגישות לובסטר פיין דיינינג. סיילס רסטורנט באמד מציעה אופציה קצת יותר זולה אבל איכותית.' },
  { q: 'מה זה פאפס איקאן?', a: 'פאפס איקאן (Pepes Ikan) היא שיטת בישול בלינזית מסורתית שבה דג טחון עם תבלינים (טרמריק, שום, ג\'ינג\'ר, צ\'ילי) נארז בעלי בננה ונאפה על הגריל. הטעם ייחודי וארומטי. מסעדות בלינזיות אותנטיות (בומבו באלי, וארונג דמאר) מגישות את זה.' },
  { q: 'האם יש אופציות פירות ים כשרות בבאלי?', a: 'פירות ים עם סנפירים וקשקשים (סנאפר, טונה, מאהי מאהי, גרופר) נחשבים כשרים. לובסטר, שרימפס, צדפות, וסרטן — לא כשרים. למטיילים שומרי כשרות, מומלץ להתמקד בדגים בלבד ולוודא שהבישול נפרד מכלים שנגעו בפירות ים לא-כשרים.' },
  { q: 'מהי השעה האידיאלית לארוחת פירות ים בג\'ימבאראן?', a: 'השעה האידיאלית היא 17:00-18:00 — תגיעו 30 דקות לפני השקיעה, תבחרו דגים, תזמינו שולחן מול הים, ותאכלו תוך כדי שקיעה. השקיעה בבאלי היא 18:00-18:30 רוב השנה. בעונת הגשמים השקיעה לא תמיד גלויה.' },
  { q: 'האם מסעדות פירות ים בבאלי מגישות גם מנות צמחוניות?', a: 'כן, רוב מסעדות פירות ים בבאלי מגישות גם מנות צמחוניות — סלטים, ירקות על הגריל, נאסי גורנג ירק, וטופו. בג\'ימבאראן על החוף יש אפילו אופציות עוף ובקר לילדים שלא אוכלים דגים.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות פירות ים בבאלי | יאללה באלי"
  pageDescription="מדריך מסעדות פירות ים בבאלי: חוף ג׳ימבאראן (מנגה, באוונג מרה, סונדארה), קוסטה בסאנור, קוקה, פאסיר ועוד. פירות ים טריים על החוף עם שקיעה מרהיבה."
  h1="מסעדות פירות ים בבאלי"
  intro="באלי מוקפת באוקיינוס, והדגים נתפסים ביום ההגשה. חוף ג׳ימבאראן (Muaya Beach) הוא היעד האגדי — שולחנות על החול, בוחרים דג טרי מהדלפק, ואוכלים עם הרגליים בחול תוך כדי שקיעה. לצידו, מסעדות פיין דיינינג פירות ים במלונות 5 כוכבים."
  items={items}
  faq={faq}
  categorySlug="seafood"
  breadcrumbLabel="פירות ים"
  schemaName="מסעדות פירות ים בבאלי"
  faqHeading="שאלות נפוצות — מסעדות פירות ים בבאלי"
/>
