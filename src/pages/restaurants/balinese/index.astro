---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = ['בלינזי', 'באלינזי', 'בלינזית', 'באלינזית']
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן המסעדות המטבח הבלינזי האותנטי הטובות ביותר?', a: 'למטבח בלינזי אותנטי בבאלי, המובילות הן: בומבו באלי בנוסה דואה (סטנדרט זהב עם בית ספר לבישול), מסעדת קקב, סוקון (בלינזי מודרני), This Is Bali באובוד, ווארונג דמאר בקוטה, ומאדה\'ס וארונג (מוסד משנת 1969).' },
  { q: 'מה זה מטבח בלינזי ובמה הוא שונה מאינדונזי?', a: 'המטבח הבלינזי מבוסס על בישול איטי, תבלינים מורכבים (בסיס "בסא גדה" — שום, צ\'ילי, טרמריק, ג\'ינג\'ר, גלנגל), ושימוש באורגני מקומי. הוא חריף וארומטי יותר מהמטבח האינדונזי הכללי. מנות מפורסמות: בבי גולינג (חזיר צלוי), בבק בטוטו (ברווז), סאטה לילית, ונאסי קמפור.' },
  { q: 'מה זה באבי גולינג?', a: 'באבי גולינג (Babi Guling) הוא חזיר חלב שלם שצולה לאט על גחלים, עם מילוי של תבלינים בלינזיים מסורתיים. זו המנה החגיגית של באלי — מוגשת באירועים, בחתונות, ובטקסים דתיים. את הבאבי גולינג האותנטי הטוב ביותר תמצאו ב-Warung Ibu Oka באובוד.' },
  { q: 'מה זה נאסי קמפור?', a: 'נאסי קמפור (Nasi Campur) הוא המנה הבלינזית הכי קלאסית — אורז לבן עם מגוון מנות קטנות: סאטה, עוף/בקר, ירקות מעובדים, פיצוחים, ביצה, ותבלינים. כל מסעדה בלינזית מציעה את הגרסה שלה. בומבו באלי וסוקון מפורסמות בנאסי קמפור מיוחדת.' },
  { q: 'מה זה בבק בטוטו?', a: 'בבק בטוטו (Bebek Betutu) הוא ברווז שלם ממולא בתבלינים בלינזיים, נארז בעלי בננה וצלוי לאט (6-8 שעות). הבשר נרדף ונמס. זו המנה הכי מפורסמת של המטבח הבלינזי. בומבו באלי מגישה את הגרסה האותנטית ביותר.' },
  { q: 'כמה עולה ארוחה בלינזית אותנטית?', a: 'ווארונג בלינזי מקומי: 30,000-70,000 רופי לאדם (8-18 ש"ח). מסעדה בלינזית טובה (סוקון, קקב): 150,000-300,000 רופי (40-80 ש"ח). בומבו באלי עם ראיסטפל: 400,000-700,000 רופי לאדם (110-190 ש"ח).' },
  { q: 'איפה הכי טוב ללמוד לבשל בלינזי?', a: 'בומבו באלי בנוסה דואה מציעה את בית הספר לבישול הבלינזי המוביל — השף היינץ פון הולזן מעביר את הקורסים בעצמו. הקורס מתחיל בשוק מקומי, ממשיך בבישול בסדנה, ומסתיים בארוחה. גם באובוד יש הרבה אופציות (Paon Bali, Casa Luna).' },
  { q: 'האם יש ווארונגים בלינזיים כשרים?', a: 'לא, ווארונגים בלינזיים לרוב מכילים חזיר (באבי) שהוא חלק מרכזי במטבח. אופציות "כשר-סטייל" יכולות להיות מסעדות ללא חזיר (מאדה\'ס וארונג מציעה מנות ללא חזיר), אבל לכשרות אמיתית צריך להתמקד במסעדות מזרח-תיכוניות או טבעוניות.' },
  { q: 'מה זה ראיסטפל?', a: 'ראיסטפל (Rijsttafel) היא מילה הולנדית — "שולחן אורז". זוהי סעודת רב-מנות קולוניאלית הולנדית שהותאמה למטבח האינדונזי — אורז עם 15-20 מנות קטנות של בשר, דגים, ירקות ותבלינים. בומבו באלי מגישה את הראיסטפל הכי אותנטי בבאלי.' },
  { q: 'מה הסגנון המיוחד של אובוד במטבח בלינזי?', a: 'אובוד מתמחה בגרסה רוחנית-אורגנית של המטבח הבלינזי — המסעדות משתמשות רק בחומרי גלם מקומיים, מהגן שלהן או מחוות סמוכות. This Is Bali, Nusa by Suka, וארקדיה מציעות גרסאות מודרניות של המטבח הבלינזי המסורתי.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בלינזיות בבאלי — מטבח אותנטי | יאללה באלי"
  pageDescription="מדריך מסעדות בלינזיות אותנטיות בבאלי: בומבו באלי (עם בית ספר לבישול), קקב, סוקון, This Is Bali, מאדה׳ס ועוד. באבי גולינג, בבק בטוטו, נאסי קמפור וראיסטפל מסורתי."
  h1="מסעדות בלינזיות אותנטיות בבאלי"
  intro="המטבח הבלינזי הוא פנינה של בישול איטי, תבלינים מורכבים ומנות חגיגיות. ממסעדת בומבו באלי (הסטנדרט הזהב עם בית ספר לבישול) ועד מאדה׳ס וארונג (מוסד משנת 1969), כאן תמצאו את המסעדות שמגישות באבי גולינג, בבק בטוטו, נאסי קמפור וראיסטפל אותנטי ברמה הגבוהה ביותר."
  items={items}
  faq={faq}
  categorySlug="balinese"
  breadcrumbLabel="בלינזי"
  schemaName="מסעדות בלינזיות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות בלינזיות בבאלי"
/>
