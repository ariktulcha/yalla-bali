---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { pickMetaDescription } from '../../lib/seo'
import { site, pageTitle as buildPageTitle } from '../../config/site'
import Layout from '../../components/Layout.astro'
import PhotoGallery from '../../components/PhotoGallery.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: restaurants } = await supabaseAdmin
    .from('restaurants')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (restaurants ?? []).map((restaurant) => ({
    params: { slug: restaurant.slug },
    props: { restaurant },
  }))
}

const { restaurant } = Astro.props

const cuisineTypes = restaurant.cuisine_types ?? restaurant.metadata?.cuisine_types ?? []
const openingHours = restaurant.opening_hours ?? restaurant.metadata?.opening_hours
const priceRange = restaurant.price_range ?? restaurant.metadata?.price_range
const rating = restaurant.rating ?? restaurant.metadata?.rating
const reviewCount = restaurant.review_count ?? restaurant.metadata?.review_count ?? 10
const address = restaurant.address ?? restaurant.metadata?.address

let hoursArray: string[] = []
if (openingHours) {
  try {
    const parsed = typeof openingHours === 'string' ? JSON.parse(openingHours) : openingHours
    hoursArray = Array.isArray(parsed) ? parsed : [String(openingHours)]
  } catch {
    hoursArray = [String(openingHours)]
  }
}

const contentHtml = restaurant.full_content ? await marked(restaurant.full_content) : ''

const titlePrefix = `${restaurant.name_he}${restaurant.name_en ? ` — ${restaurant.name_en}` : ''}`
const pageTitle = restaurant.meta_title || buildPageTitle(titlePrefix, 'restaurant')
const pageDescription = restaurant.meta_description || pickMetaDescription(restaurant, `מסעדה ב${site.destinationName}`)

const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: restaurant.name_he,
  alternateName: restaurant.name_en || undefined,
  description: restaurant.description || restaurant.excerpt,
  image: restaurant.image ? (restaurant.image.startsWith('http') ? restaurant.image : new URL(restaurant.image, Astro.site).toString()) : undefined,
  url: new URL(`/restaurants/${restaurant.slug}`, Astro.site).toString(),
  ...(address ? { address: { '@type': 'PostalAddress', streetAddress: address } } : {}),
  ...(cuisineTypes.length > 0 ? { servesCuisine: cuisineTypes } : {}),
  ...(priceRange ? { priceRange } : {}),
  ...(rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: rating, ratingCount: reviewCount, bestRating: 5 } } : {}),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מסעדות', href: '/restaurants' },
  { label: restaurant.name_he },
]

// Distance & pricing estimates by area
const areaDistancePricing: Record<string, { distance: string; grabPrice: string }> = {
  'סמינייק': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'seminyak': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'קאנגו': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'canggu': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'אובוד': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ubud': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ג\'ימברן': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'jimbaran': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'אולוואטו': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'uluwatu': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'נוסה דואה': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'nusa-dua': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'סנור': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'sanur': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'קוטה': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
  'kuta': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
}

const areaKey = (restaurant.area || '').toLowerCase()
const distancePricing = areaDistancePricing[areaKey] || { distance: '20-25 ק"מ', grabPrice: '₪70-100' }

const dbFaq = Array.isArray(restaurant.faq) ? restaurant.faq : []
const faqMentionsName = dbFaq.filter((it: any) => (it.q || '').includes(restaurant.name_he)).length
const needsEnrichment = faqMentionsName < 2 && dbFaq.length > 0
const faqIntro = needsEnrichment
  ? [{
      q: `מה כדאי לדעת על ${restaurant.name_he} בבאלי?`,
      a: restaurant.description || `${restaurant.name_he} היא מסעדה מומלצת בבאלי${restaurant.area ? `, באזור ${restaurant.area}` : ''}. פרטים נוספים על התפריט, השעות והתמחור של ${restaurant.name_he} מובאים בשאלות הבאות.`,
    }]
  : []
const faqOutro = needsEnrichment
  ? [{
      q: `איך מזמינים שולחן או מגיעים ל${restaurant.name_he} בבאלי?`,
      a: `כדי להזמין שולחן או לקבל פרטים עדכניים על ${restaurant.name_he}, מומלץ לפנות ישירות למסעדה דרך הרשתות החברתיות. ניתן להגיע ל${restaurant.name_he} עם Grab, Gojek או רכב פרטי — זמן הנסיעה משתנה לפי אזור היציאה בבאלי.`,
    }]
  : []
const faqItems = dbFaq.length > 0
  ? [...faqIntro, ...dbFaq.map((item: any) => ({ q: item.q, a: item.a })), ...faqOutro]
  : [
      {
        q: `האם צריך להזמין מראש שולחן ב${restaurant.name_he} בבאלי?`,
        a: `זה תלוי בגודל הקבוצה שלכם ובעונה. ב${restaurant.name_he}, לקבוצות גדולות וביום שישי בלילה מומלץ מאוד לעשות הזמנה מראש. ניתן ליצור קשר ישירות עם המסעדה כדי להזמין שולחן או לבדוק זמינות.`,
      },
      {
        q: `האם ${restaurant.name_he} מתאימה לצמחוניים וטבעונים?`,
        a: `כן, ${restaurant.name_he} מציעה אפשרויות צמחוניות וטבעוניות בתפריט. מומלץ להודיע בעת ההזמנה כדי שהמסעדה תהיה מוכנה לצרכיכם המיוחדים. אם יש דיאטות נוספות (ללא גלוטן, אלרגיות), כדאי לציין זאת מראש.`,
      },
      {
        q: `כמה עולה ארוחה ב${restaurant.name_he} בבאלי?`,
        a: `${priceRange ? `טווח המחירים ב${restaurant.name_he} הוא: ${priceRange}.` : `המחיר ב${restaurant.name_he} תלוי בתפריט שתבחרו.`} מומלץ לבדוק את התפריט המעודכן ברשת החברתית של המסעדה לפרטים עדכניים על מחירים בבאלי.`,
      },
      {
        q: `האם ${restaurant.name_he} פתוחה בסוף השבוע?`,
        a: `כן, רוב המסעדות בבאלי פתוחות בסופי שבוע, כולל ${restaurant.name_he}. אנו ממליצים להזמין שולחן מראש כי הביקוש גבוה בערבי שישי ושבת. בדקו את שעות הפתיחה של ${restaurant.name_he} וודאו שהמסעדה פתוחה בשעה המועדפת עליכם.`,
      },
    ]

// Related restaurants in same area
const { data: allRestaurants } = await supabaseAdmin
  .from('restaurants')
  .select('slug, name_he, description, image')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', restaurant.area)
  .neq('slug', restaurant.slug)
  .limit(3)

const related = allRestaurants ?? []
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://ibalibali.com/restaurants/${restaurant.slug}`}
  ogImage={restaurant.image}
  ogType="article"
  schema={restaurantSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mb-8">
      <PhotoGallery
        mainImage={restaurant.image}
        galleryUrls={restaurant.gallery_urls || []}
        name={restaurant.name_he}
      />
    </div>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{restaurant.name_he}</h1>
      {restaurant.name_en && (
        <p class="text-lg text-white/50">{restaurant.name_en}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
      {(restaurant.area || address) && (
        <a
          href={`https://maps.google.com/?q=${encodeURIComponent((address || restaurant.area || restaurant.name_he) + ', Bali')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-white/70 hover:text-teal-400 transition-colors"
        >
          <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {address || restaurant.area} ↗
        </a>
      )}
      {priceRange && (
        <span class="text-teal-400 font-medium">{priceRange}</span>
      )}
      {rating && (
        <span class="inline-flex items-center gap-1 text-teal-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {rating.toFixed?.(1) ?? rating}
        </span>
      )}
    </div>

    {cuisineTypes.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {cuisineTypes.map((cuisine: string) => (
          <span class="text-sm px-3 py-1 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20">
            {cuisine}
          </span>
        ))}
      </div>
    )}

    {restaurant.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">על {restaurant.name_he} בבאלי</h2>
        <p class="text-white/80 leading-relaxed">{restaurant.description}</p>
      </div>
    )}

    {hoursArray.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">שעות פתיחה — {restaurant.name_he}</h2>
        {hoursArray.map((h) => (
          <p class="text-white/70">{h}</p>
        ))}
      </div>
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">כיצד מגיעים ל{restaurant.name_he}? 🚕</h2>
      <div class="space-y-4 text-white/70">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
          <div>
            <p class="font-medium text-white">מנמל התעופה Ngurah Rai (DPS)</p>
            <p class="text-sm">מרחק משוער: <span class="text-white">{distancePricing.distance}</span></p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="font-medium text-white">Grab/Gojek Taxi</p>
            <p class="text-sm">משוער: <span class="text-white">{distancePricing.grabPrice}</span> להובלה מהנמל</p>
            <p class="text-xs text-white/50 mt-1">* המחירים הם משוער בלבד. בדקו את היישום עבור תמחור חיוני.</p>
          </div>
        </div>
        {(address || restaurant.area) && (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 003 16.382V5.618a1 1 0 011.447-.894L9 7.5m0 0l6.553-3.276A1 1 0 0117 5.618v10.764a1 1 0 01-1.447.894L9 7.5m0 0L3 10m6-6v6m6-6v6"/></svg>
            <div>
              <p class="font-medium text-white">Maps</p>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent((address || restaurant.area || restaurant.name_he) + ', Bali')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-teal-400 hover:text-teal-300 text-sm transition-colors"
              >
                פתחו ב-Google Maps ↗
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="mb-8">
      <FAQSection items={faqItems} entityName={restaurant.name_he} />
    </div>

    {related.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-800" dir="rtl">
        <h2 class="text-2xl font-bold text-white mb-6">🍽️ מסעדות נוספות ב{restaurant.area}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((item: any) => (
            <a
              href={`/restaurants/${item.slug}`}
              class="group bg-gray-900 rounded-xl overflow-hidden hover:bg-gray-800 transition-colors"
            >
              {item.image ? (
                <img
                  src={item.image}
                  alt={item.name_he}
                  class="w-full h-40 object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-40 bg-gray-800 flex items-center justify-center">
                  <span class="text-4xl">🍽️</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-tight group-hover:text-teal-400 transition-colors">
                  {item.name_he}
                </h3>
                {item.description && (
                  <p class="text-gray-400 text-xs mt-1 line-clamp-2">{item.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="bg-gradient-to-br from-teal-900/20 to-teal-800/10 border border-teal-500/30 rounded-2xl p-8 text-center mt-16">
      <h3 class="text-2xl font-black text-teal-400 mb-3">מחפשים עוד חוויות בבאלי? 🍽️</h3>
      <p class="text-white/70 mb-6">גלו טיולים, אטרקציות ומסעדות נוספות שיעזרו לכם לתכנן את הטיול המושלם בבאלי.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/tours"
          class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-600 text-[#0D0D0D] font-bold px-8 py-3 rounded-full transition-colors"
        >
          🎯 טיולים בבאלי
        </a>
      </div>
    </div>
  </div>
</Layout>
