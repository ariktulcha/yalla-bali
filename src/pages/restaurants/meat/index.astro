---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import RestaurantCard from '../../../components/Cards/RestaurantCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => ['בשרי', 'בשר', 'סטייק', 'סטייקהאוס', 'meat', 'steak'].includes(t))
)

const pageTitle = 'מסעדות בשר בבאלי | Yalla Bali'
const pageDescription = 'מסעדות הבשר והסטייק הטובות ביותר בבאלי. סטייקים מעולים, בשר איכותי וחוויות אוכל בלתי נשכחות.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מסעדות בשר בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/restaurants/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מסעדות', href: '/restaurants' },
  { label: 'בשר' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/restaurants/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/restaurants/kosher/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">✡ כשר</a>
      <a href="/restaurants/fine-dining/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">Fine Dining</a>
      <a href="/restaurants/japanese/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🍣 יפנית</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🥩 בשרים</span>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מסעדות בשר בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי היא גן עדן לאוהבי בשר. מסטייקים מיושנים יבש ועד בשר וואגיו יפני —
        המסעדות בבאלי מציעות את חתיכות הבשר האיכותיות ביותר בעולם.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <RestaurantCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            cuisine_types={item.cuisine_types}
            price_range={item.price_range}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מסעדות בשר כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מסעדות בשר בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מסעדת הסטייק הכי טובה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">באלי מציעה מסעדות סטייק ברמה עולמית. מסעדות בשר בבאלי משתנות בסגנון — יוקרה או קז'ואל. בדקו את הרשימה שלנו של מסעדות בשר בבאלי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה סטייק במסעדה טובה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">סטייק בבאלי עולה בין 200 ל-800 דירהם תלוי בחתך. מסעדות סטייק בבאלי פרימיום מציעות בשר וואגיו ביותר."""</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">יש מסעדות בשר כשרות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, יש מסעדות בשר כשרות בבאלי. בשר כשר בבאלי גדל בשנים האחרונות. בדקו את המסעדות הכשרות בבאלי למידע מעודכן.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">אילו סוגי בשר זמינים במסעדות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מסעדות בשר בבאלי מציעות סוגים מגוונים — Wagyu, Kobe, Prime, וואגיו יפני. בשר בבאלי יכול להיות בן שנה או יותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הבדל בין סטייק שונים במסעדות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">סטייק בבאלי מעבד בחתכים שונים — ribeye, filet, NY strip. כל סוג סטייק בבאלי תיאור טעם שונה וברמת טדרנס ייחודית.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איך משמרים בשר טרוז בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מסעדות בשר בבאלי שומרות בשר טרוז בכיללים מקצועיים. בשר בבאלי הטוב ביותר מגיע מצמח שומרים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">צריך להזמין מקום במסעדות בשר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מומלץ להזמין במסעדות בשר בבאלי, במיוחד בסופי שבוע. מסעדות בשר מפורסמות בבאלי מתמלאות במהירות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה קוד הלבוש במסעדות בשר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">קוד הלבוש במסעדות בשר בבאלי Smart Casual עד פורמלי. יש מסעדות בשר בבאלי פחות קפדניות מאחרות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה ההוספות הטובות ביותר עם בשר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בבאלי מסעדות בשר מציעות הוספות — תפוחי אדמה, ירקות, רוטב. בשר בבאלי משמש בצד ירקות איכותיים ומתובלים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה דרגת הצלה (done) המומלצת לבשר בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">בדרך כלל, בשר בבאלי מומלץ לתבשל rare עד medium-rare כדי לשמור על הטעם ורכות. שפים במסעדות בשר בבאלי יכולים להתאים את דרגת הצלייה לחוק שלכם.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים המלצה למסעדת בשר בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מסעדת בשר בבאלי 🥩')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
