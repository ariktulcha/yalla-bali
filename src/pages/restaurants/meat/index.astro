---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = [
  'בשרים', 'בשרי', 'בשר', 'סטייקהאוס', 'סטייק',
  'meat', 'steak', 'BBQ', 'ברביקיו',
  'גריל בשרים', 'גריל', 'יקיניקו', 'טקסני',
]
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'מהן מסעדות הבשר הטובות ביותר בבאלי?', a: 'מסעדות הבשר המובילות בבאלי כוללות את בוי אנד קאו (סטייקהאוס יוקרה עם dry-aging בסמיניאק), נאוטי נוריז (צלעות חזיר אגדיות בסמיניאק ואובוד), סמוקהאוס BBQ (בריסקט טקסני), ודה גראמפי באצ\'ר (שילוב סטייקהאוס ומעשנת קפה-עץ).' },
  { q: 'כמה עולה ארוחה בסטייקהאוס בבאלי?', a: 'ארוחה בסטייקהאוס יוקרה בבאלי (כמו בוי אנד קאו או גראמפי באצ\'ר) עולה 500,000-1,000,000 רופי לאדם (140-270 ש"ח). במסעדות BBQ יותר קז\'ואלית (נאוטי נוריז, סמוקהאוס) המחירים נעים 300,000-600,000 רופי לאדם.' },
  { q: 'מה החזיר בבאלי?', a: 'חזיר הוא חלק מרכזי מהמטבח הבאלינזי — מדובר בחזיר מקומי איכותי. הצלעות של נאוטי נוריז מפורסמות בעולם ואנתוני בורדיין הציג אותן ב-CNN. שומרי כשרות יכולים להתמקד במסעדות BBQ בקר או ואגיו (בוי אנד קאו).' },
  { q: 'איפה הכי טוב לאכול צלעות BBQ בבאלי?', a: 'נאוטי נוריז הוא המוסד האגדי של צלעות חזיר BBQ בבאלי — הסניף המקורי באובוד מ-1995 והסניף הסמיניאקי. את הצלעות בגחלים פתוחות, עם המרטיני המפורסם של בורדיין. בעיני רבים זו חובה לכל מטייל.' },
  { q: 'מה זה dry-aged ואיפה יש בבאלי?', a: 'dry-aged זה בשר שיושן במערה מיוחדת למשך 28-60 יום, מה שמרכז את הטעמים ומרכך את הבשר. בוי אנד קאו בסמיניאק היא בוטיק הבשר הראשון בבאלי עם מערת dry-aging, ומגישה ריב-איי, סטריפלוין וטומהוק ואגיו ברמה עולמית.' },
  { q: 'האם יש סטייקים כשרים בבאלי?', a: 'בבאלי אין סטייקהאוסים עם תעודת כשרות. בית חב"ד באלי יכול לארגן ארוחות בשר כשרות בהזמנה מראש. למטיילים שומרי כשרות חלקית, מסעדות חלאל (אל מדינה, מארוש) מציעות מנגל בקר וטלה ללא חזיר.' },
  { q: 'מה זה סמוקהאוס BBQ?', a: 'סמוקהאוס זה מטבח ברביקיו אמריקאי-טקסני קלאסי: בריסקט (חזה בקר) מעושן 12 שעות, צלעות חזיר St. Louis, חזיר מפוצל (Pulled Pork) ו-Burnt Ends. בסמוקהאוס BBQ ובדה גראמפי באצ\'ר בסמיניאק יש את הגרסה הכי אותנטית בבאלי.' },
  { q: 'האם צריך להזמין מקום במסעדות בשר בבאלי מראש?', a: 'בוי אנד קאו דורשת הזמנה מראש (היא מדורגת #3 בטריפאדווייזר סמיניאק). נאוטי נוריז וסמוקהאוס BBQ ניתן להגיע ללא הזמנה בשעות רגילות, אבל בסופי שבוע כדאי להזמין. במיוחד בעונת השיא.' },
  { q: 'מה לבחור — נאוטי נוריז סמיניאק או אובוד?', a: 'הסניף המקורי של נאוטי נוריז באובוד (משנת 1995) הוא אגדי יותר עם אווירת ווארונג אותנטית וריח הגחלים הפתוחות. הסניף הסמיניאקי נוח יותר למי שיושב בסמיניאק. שני הסניפים מגישים את אותן הצלעות המפורסמות.' },
  { q: 'האם יש מסעדות ואגיו בבאלי?', a: 'כן, בוי אנד קאו מתמחה בואגיו פרימיום (Tomahawk, Striploin). גם במסעדות יפניות כמו טאקומי, רייג\'ין ואדוגין מגישים ואגיו A5 בטפניאקי. זו חוויה יקרה אבל ייחודית.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בשר וסטייקהאוס בבאלי | יאללה באלי"
  pageDescription="מדריך למסעדות הבשר הטובות ביותר בבאלי: בוי אנד קאו (סטייקהאוס dry-aged), נאוטי נוריז (צלעות BBQ אגדיות), סמוקהאוס BBQ וגראמפי באצ׳ר. מחירים, המלצות וטיפים."
  h1="מסעדות בשר וסטייקהאוס בבאלי"
  intro="באלי הפכה ליעד מוביל לחובבי בשר — מהצלעות האגדיות של נאוטי נוריז (שאנתוני בורדיין הציג ב-CNN), דרך הסטייקים dry-aged בבוי אנד קאו, ועד לבריסקט הטקסני המעושן בסמוקהאוס BBQ. הרוב המוחלט מרוכז בסמיניאק ואובוד."
  items={items}
  faq={faq}
  categorySlug="meat"
  breadcrumbLabel="בשרים"
  schemaName="מסעדות בשר בבאלי"
  faqHeading="שאלות נפוצות — מסעדות בשר בבאלי"
/>
