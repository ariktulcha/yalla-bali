---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Jimbaran')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בג׳ימבאראן?', a: 'ג\'ימבאראן מפורסמת בפירות ים על החוף. המובילות: מנגה קפה (BBQ פירות ים על החוף האייקוני), סונדארה (פיין דיינינג על הים במלון פור סיזנס), קוקה (טאפאס גורמה), באוונג מרה (פירות ים על החוף), ולה בראסרי (צרפתי-אסייתי).' },
  { q: 'איפה הכי טוב לאכול פירות ים על החוף בג׳ימבאראן?', a: 'החוף של ג\'ימבאראן (Muaya Beach) הוא היעד האגדי של פירות ים בבאלי — עשרות מסעדות ששולחנותיהן פרוסים על החול. בוחרים דג/לובסטר/שרימפס טרי בדלפק, ואוכלים עם הרגליים בחול תוך שקיעה. מנגה קפה ובאוונג מרה הן המפורסמות.' },
  { q: 'כמה עולה ארוחת פירות ים בג׳ימבאראן?', a: 'ארוחת פירות ים על החוף בג\'ימבאראן עולה 250,000-500,000 רופי לאדם (70-140 ש"ח), תלוי בדגים. פלטת פירות ים משותפת ל-2 אנשים יכולה להגיע ל-800,000-1,200,000 רופי. בפיין דיינינג (סונדארה, קוקה) — 1,000,000+ רופי לאדם.' },
  { q: 'באיזה שעה הכי טוב להגיע לחוף ג׳ימבאראן?', a: 'השעה האידיאלית היא 17:00-18:00 לשקיעה. הזמינו בערך 30 דקות לפני השקיעה בכדי לקבל שולחן עם נוף. בעונת השיא (יולי-אוגוסט, דצמבר-ינואר) הגיעו מוקדם יותר או הזמינו מקום מראש.' },
  { q: 'האם צריך להזמין מקום במסעדות ג׳ימבאראן מראש?', a: 'בסונדארה, קוקה ולה בראסרי — בהחלט, כי הן פיין דיינינג. במסעדות פירות ים על החוף (מנגה, באוונג מרה) בדרך כלל Walk-in מקובל, אבל בעונת השיא ובסופי שבוע כדאי להזמין בשביל מקום עם נוף לים.' },
  { q: 'מהי קוקה (Cuca) בג׳ימבאראן?', a: 'קוקה (Cuca) היא מסעדת טאפאס גורמה איקונית בג\'ימבאראן — שפים צעירים ויצירתיים מגישים מנות קטנות מודרניות עם טוויסט באלינזי-ספרדי. המסעדה זכתה בפרסים רבים, וקוקטייל בר הוא מהטובים באי.' },
  { q: 'איפה סונדארה במלון פור סיזנס ג׳ימבאראן?', a: 'סונדארה (Sundara) היא מסעדה על שפת הים במלון Four Seasons Jimbaran Bay. היא מציעה פיין דיינינג בינלאומי-פירות ים על הבריכה המרהיבה שעל הים. לא חייבים להיות אורחי המלון — המסעדה פתוחה לאורחים חיצוניים.' },
  { q: 'האם ג׳ימבאראן מתאימה למשפחות?', a: 'בהחלט — ג\'ימבאראן היא המקום האידיאלי למשפחות עם ילדים. האווירה משוחררת, הילדים יכולים לרוץ על החוף, בוחרים מהדגים, ויש חוויה ויזואלית מרשימה. בייחוד מומלץ לחוויית הקיץ הראשונה של הילדים בבאלי.' },
  { q: 'מה הסגנון הקולינרי של ג׳ימבאראן?', a: 'ג\'ימבאראן = פירות ים. זו הזהות הקולינרית הבלעדית שלה. פירות ים על גריל פחם, סגנון אינדונזי מסורתי של מנגל דגים על החוף. לצידם: מלונות 5 כוכבים עם פיין דיינינג על הים (סונדארה, קוקה, לה בראסרי).' },
  { q: 'איך מגיעים לחוף ג׳ימבאראן?', a: 'ג\'ימבאראן נמצאת כ-20 דקות דרומית לקוטה, 30 דקות מסמיניאק. Grab/Gojek הם הדרך הקלה (70,000-150,000 רופי מסמיניאק). טיפ: הזמינו הלוך-חזור לאותו נהג, כי הלילה קשה למצוא גראב חוזר מהחוף.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בג׳ימבאראן — פירות ים על החוף | יאללה באלי"
  pageDescription="מדריך מסעדות בג׳ימבאראן: מנגה קפה, סונדארה (פור סיזנס), קוקה (טאפאס גורמה), באוונג מרה ולה בראסרי. פירות ים על החוף, שקיעה והמלצות להזמנת ארוחה."
  h1="מסעדות בג׳ימבאראן"
  intro="ג׳ימבאראן היא היעד האייקוני של פירות ים על החוף בבאלי. על חוף Muaya Beach מסעדות פירות ים פרוסות שולחנותיהן על החול — בוחרים דג טרי בדלפק, יושבים ברגליים בחול וצופים בשקיעה. לצידן, פיין דיינינג מרהיב במלונות 5 כוכבים."
  items={items}
  faq={faq}
  categorySlug="jimbaran"
  breadcrumbLabel="ג׳ימבאראן"
  schemaName="מסעדות בג׳ימבאראן"
  faqHeading="שאלות נפוצות — מסעדות בג׳ימבאראן"
/>
