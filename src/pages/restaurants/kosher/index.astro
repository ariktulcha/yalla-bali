---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('rating', { ascending: false })

const matchTerms = ['כשר', 'kosher', 'Kosher', 'כשרות', 'ישראלי', 'חב"ד', 'חלאל', 'לבנוני', 'ערבי', 'מרוקאי', 'מזרח תיכוני']
const items = (data || []).filter(r =>
  (r.cuisine_types || []).some(t => matchTerms.some(term => t.includes(term)))
)

const faq = [
  { q: 'האם יש מסעדות כשרות מהדרין בבאלי?', a: 'בבאלי אין מסעדות עם תעודת כשרות מהדרין רשמית. האפשרות היחידה לארוחה כשרה אמיתית היא בית חב"ד באלי בסמיניאק, שמארגן ארוחות שבת וחג בהזמנה מראש דרך מייל kosherinbali@gmail.com.' },
  { q: 'אילו מסעדות בבאלי ידידותיות לישראלים שומרי כשרות?', a: 'מסעדות "כשר-סטייל" בבאלי כוללות את סבבה (צ\'נגו, ישראלי), זולה (סמיניאק, צמחוני 100%), מארוש ואל מדינה (חלאל לבנוני/ערבי בצ\'נגו), וטאג\'ין (מרוקאי בסמיניאק). כל אלה ללא חזיר ועם תפריטים מוכרים לישראלים.' },
  { q: 'איך מזמינים ארוחת שבת בבית חב"ד באלי?', a: 'מזמינים ארוחת שבת בבית חב"ד באלי דרך מייל kosherinbali@gmail.com לפחות 48 שעות מראש. התרומה המומלצת היא כ-25-35 דולר לאדם, ונכנסת לתחזוקת בית חב"ד.' },
  { q: 'איפה הריכוז העיקרי של מסעדות כשר-סטייל בבאלי?', a: 'הריכוז העיקרי של מסעדות כשר-סטייל בבאלי הוא בסמיניאק וצ\'נגו — שני האזורים שבהם מתרכזת הקהילה הישראלית הגדולה. בסאנור יש פחות אופציות אבל כן יש מסעדות צמחוניות מתאימות.' },
  { q: 'האם מסעדות חלאל בבאלי מתאימות לשומרי כשרות?', a: 'מסעדות חלאל בבאלי (כמו אל מדינה ומארוש) הן אופציה טובה לישראלים ששומרים על כשרות חלקית — אין חזיר, אין פירות ים בעייתיים, והבשר נשחט לפי דיני האסלאם. אבל זה לא תחליף לכשרות מהדרין.' },
  { q: 'האם יש מסעדות צמחוניות בבאלי שמתאימות לכשרות?', a: 'כן, יש מסעדות טבעוניות וצמחוניות מצוינות בבאלי שמתאימות לכשרות — הכל פרווה (ללא בשר וללא חלב). זולה גן עדן צמחוני בסמיניאק, סאיורי הילינג פוד באובוד, מוקסה אובוד והשיידי שאק בצ\'נגו הן בחירות בטוחות.' },
  { q: 'כמה עולה ארוחה כשרה בבאלי?', a: 'ארוחת שבת בבית חב"ד באלי עולה כ-25-35 דולר לאדם. ארוחה במסעדת כשר-סטייל (כמו סבבה או טאג\'ין) עולה 200,000-400,000 רופי לאדם (50-110 ש"ח). מחירים סבירים יחסית לישראל.' },
  { q: 'האם הקהילה הישראלית בבאלי מארגנת ארוחות חג?', a: 'כן, בית חב"ד באלי מארגן ארוחות שבת, ראש השנה, יום כיפור, סוכות, חנוכה ופסח. ליל הסדר בבאלי הוא חוויה מיוחדת עם עשרות ישראלים שחוגגים יחד. תיאום מראש דרך chabadbali.org.' },
  { q: 'האם ישראלים יכולים להזמין ארוחות פרטיות לחג?', a: 'כן, ניתן ליצור קשר עם בית חב"ד באלי ולהזמין ארוחה פרטית לחג עם המשפחה או חבורה ישראלית. הם גם מספקים שירות קייטרינג כשר לאירועים פרטיים.' },
  { q: 'האם יש סופרים עם מוצרים כשרים בבאלי?', a: 'בבאלי קשה למצוא סופרים עם תעודת כשרות. ניתן למצוא יין כשר בחנויות מובחרות, וכמה מוצרי יבוא יש בסופרים גדולים. בית חב"ד יכול להמליץ על מוצרים מתאימים.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות כשרות בבאלי — מדריך מלא | יאללה באלי"
  pageDescription="מדריך מסעדות כשרות וכשר-סטייל בבאלי: בית חב״ד באלי, מסעדות ישראליות, מזרח תיכוניות וטבעוניות. כל מה שחשוב לדעת לפני שמזמינים ארוחה כשרה בבאלי."
  h1="מסעדות כשרות בבאלי"
  intro="באלי אינה מציעה מסעדות עם תעודת כשרות מהדרין רשמית, אך יש פתרונות נהדרים לישראלים שומרי כשרות. בית חב״ד באלי הוא הפתרון לארוחות כשרות אמיתיות בהזמנה מראש, ולצידו רשת של מסעדות &quot;כשר-סטייל&quot; — ישראליות, חלאליות, צמחוניות ומרוקאיות — שמתאימות לישראלים שומרי כשרות חלקית."
  items={items}
  faq={faq}
  categorySlug="kosher"
  breadcrumbLabel="כשר"
  schemaName="מסעדות כשרות בבאלי"
  faqHeading="שאלות נפוצות — מסעדות כשרות בבאלי"
/>
