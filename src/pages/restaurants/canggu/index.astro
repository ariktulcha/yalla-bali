---
import RestaurantCategoryLayout from '../../../components/RestaurantCategoryLayout.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('restaurants')
  .select('name_he, name_en, slug, image, area, cuisine_types, price_range, rating, excerpt')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', 'Canggu')
  .order('rating', { ascending: false })

const items = data || []

const faq = [
  { q: 'מהן המסעדות הטובות ביותר בצ׳נגו?', a: 'צ\'נגו מפורסמת בסצנה הצמחונית-טבעונית שלה: דה שיידי שאק (אייקון טבעוני), פלוטון סופרשופ (קפה וסופר-מארקט בריא), ופלנט קרטל (פאסט פוד טבעוני). גם מסעדות ישראליות/מזרח תיכוניות פופולריות — סבבה (ישראלי), מארוש ואל מדינה (לבנוני/ערבי).' },
  { q: 'איפה הכי טוב לאכול ברנץ\' בצ׳נגו?', a: 'צ\'נגו היא בירת הברנץ\' של באלי. השיידי שאק, פלוטון סופרשופ, ו-KYND (בסמיניאק הסמוכה) מציעים ברנץ\' טבעוני יוצא מן הכלל. Milk & Madu, Crate Cafe וקטלה הם אופציות נוספות מצוינות לארוחת בוקר/ברנץ\' בצ\'נגו.' },
  { q: 'כמה עולה ארוחה בצ׳נגו?', a: 'צ\'נגו הוגן יחסית לסמיניאק: ארוחה במסעדה קז\'ואלית 80,000-200,000 רופי לאדם (20-55 ש"ח), ארוחה טובה 250,000-500,000 רופי (70-140 ש"ח), וביץ\' קלאב כמו פינס או לה בריסה 400,000-800,000 רופי.' },
  { q: 'איפה הביץ\' קלאבים בצ׳נגו?', a: 'צ\'נגו מפורסמת בביץ\' קלאבים מהעליונים בבאלי — פינס ביץ\' קלאב (צפופה, פופולרית), לה בריסה (בוהו-אקולוגי, חוף אקו), Atlas Beach Club (חדש ויוקרתי). כולם על חוף בראווה-אקו.' },
  { q: 'האם יש מסעדות ישראליות בצ׳נגו?', a: 'כן, סבבה באלי בברווא היא מסעדה ישראלית אמיתית עם שווארמה, חומוס ומנגל — הקרובה ביותר לארוחה תל אביבית בבאלי. הצוות מבין עברית. גם מארוש ואל מדינה (חלאל לבנוני/ערבי) מציעות מנות מוכרות.' },
  { q: 'איפה הרחובות הקולינריים המרכזיים בצ׳נגו?', a: 'הרחובות המרכזיים של צ\'נגו הם Jalan Batu Bolong (המקורי, פופולרי), Jalan Pantai Berawa (ברווא, שכונה חדשה עם הרבה מסעדות), ו-Jalan Pantai Batu Mejan (אקו ביץ\'). כל רחוב עם אופי אחר.' },
  { q: 'האם צ׳נגו מתאימה לדיגיטל נומאדים?', a: 'מאוד — צ\'נגו היא בירת הדיגיטל נומאדים של אסיה. מסעדות/קפה רבים עם WiFi מהיר ונוחות לעבודה: פלוטון סופרשופ, Crate Cafe, Milk & Madu, ו-Dojo Coworking. פתוחים כל היום.' },
  { q: 'כמה עולה מסעדה טבעונית בצ׳נגו?', a: 'מסעדה טבעונית קז\'ואלית בצ\'נגו עולה 100,000-200,000 רופי לאדם (25-55 ש"ח). דה שיידי שאק, פלוטון, ופלנט קרטל כולם בטווח הזה. זה יקר בהשוואה לווארונג מקומי אבל זול בהשוואה לסמיניאק.' },
  { q: 'מה הסגנון הקולינרי של צ׳נגו?', a: 'צ\'נגו היא הבירה הטבעונית-בריאה של באלי, עם דגש על ברנץ\', סופר-פוד, אוכל הזנה, קפה של ספציאליטי, ואוכל אורבני-מודרני. יש גם מסעדות ישראליות ומזרח-תיכוניות, ביץ\' קלאבים, וכמה פיין דיינינג.' },
  { q: 'האם צ׳נגו מתאימה למשפחות?', a: 'כן, צ\'נגו מתאימה גם למשפחות: מסעדות ברנץ\' ידידותיות לילדים, פינס ביץ\' קלאב עם בריכה ומגלשות למשפחות, ומסעדות פיצה וטבעוני מגוונות. האווירה צעירה אבל מארחת.' },
]
---

<RestaurantCategoryLayout
  pageTitle="מסעדות בצ׳נגו — המדריך המלא | יאללה באלי"
  pageDescription="מדריך מסעדות בצ׳נגו: טבעוני, ברנץ׳, ביץ׳ קלאבים, ישראלי/מזרח תיכוני. כולל שיידי שאק, סבבה, פינס ביץ׳ קלאב, פלוטון ועוד. מחירים והמלצות."
  h1="מסעדות בצ׳נגו"
  intro="צ׳נגו היא בירת האוכל הטבעוני, הברנץ׳ והדיגיטל נומאדים של באלי. מרחובות Batu Bolong וBerawa עד חופי אקו ובראווה, צ׳נגו מציעה את סצנת המסעדות הצמחוניות הכי עשירה באי, ביץ׳ קלאבים אייקוניים, ומגוון מסעדות ישראליות ומזרח-תיכוניות."
  items={items}
  faq={faq}
  categorySlug="canggu"
  breadcrumbLabel="צ׳נגו"
  schemaName="מסעדות בצ׳נגו"
  faqHeading="שאלות נפוצות — מסעדות בצ׳נגו"
/>
