---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(h =>
  (h.area || '').toLowerCase().includes('seminyak') ||
  (h.name_en || '').toLowerCase().includes('seminyak')
)

const pageTitle = 'מלונות בסמינייק באלי — המלצות ודירוגים | Yalla Bali'
const pageDescription = 'מלונות מומלצים בסמינייק, באלי. מלונות יוקרה, ריזורטים על החוף, חיי לילה וקניות ברחוב הכי תוסס בבאלי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות בסמינייק באלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות בסמינייק' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/ubud/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌿 אובוד</a>
      <a href="/hotels/canggu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏄 קאנגו</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🌅 סמינייק</span>
      <a href="/hotels/uluwatu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🪨 אולוואטו</a>
      <a href="/hotels/jimbaran/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🐟 ג׳ימברן</a>
      <a href="/hotels/nusa-dua/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌴 נוסה דואה</a>
      <a href="/hotels/sanur/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎣 סנור</a>
      <a href="/hotels/kuta/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ קוטה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות בסמינייק באלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        סמינייק הוא האזור היוקרתי והתוסס ביותר בבאלי — חוף מושלם, חנויות מעצבים, מסעדות שף וחיי לילה.
        מלונות בסמינייק באלי מציעים יוקרה אמיתית עם גישה ישירה לחוף ולכל מה שבאלי מציעה.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
            booking_url={item.booking_url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות בסמינייק כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות בסמינייק באלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מיוחד במלונות בסמינייק באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בסמינייק באלי ידועים ביוקרה, מיקום מרכזי ושירות ברמה בינלאומית. מלונות בסמינייק באלי מציעים גישה ישירה לחוף, בריכות אינסוף, ספא וקרבה לחנויות ומסעדות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה מלון בסמינייק באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון בסמינייק באלי עולה בין 60 ל-500 דולר ללילה. מלונות 5 כוכבים בסמינייק באלי נעים בין 200-600 דולר, ובוטיק מלונות בסמינייק זמינים מ-50 דולר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם סמינייק באלי מתאים למשפחות?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מלונות בסמינייק באלי מתאימים גם למשפחות. מלונות רבים בסמינייק באלי מציעים חדרים משפחתיים, מועדוני ילדים ובריכות ילדים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה יש לעשות ליד מלונות בסמינייק באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בסמינייק באלי קרובים לחוף סמינייק, חנויות מעצבים, מסעדות שף, beach clubs כמו Potato Head ו-Ku De Ta, ולמקדש טנה לוט.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">למה לבחור מלון בסמינייק באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון בסמינייק באלי מושלם למי שרוצה שילוב של חוף, קניות, אוכל וחיי לילה. סמינייק באלי הוא האזור הכי נוח ומרכזי עם הכל בהישג יד.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
