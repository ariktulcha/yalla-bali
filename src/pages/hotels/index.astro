---
import Layout from '../../components/Layout.astro'
import HotelCard from '../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'

const { data: items } = await supabaseAdmin
  .from('hotels')
  .select('name_he, name_en, slug, image, area, star_rating, price_range, excerpt, booking_url')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .order('star_rating', { ascending: false })

const hotels = items || []

const title = 'מלונות בבאלי — המדריך המלא | Yalla Bali'
const description = 'מדריך מלונות בבאלי: מלונות 5 כוכבים, מלונות חוף, מלונות משפחתיים ומלונות יוקרה. השוואת מחירים, דירוגים וביקורות.'

const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות בבאלי',
  description,
  numberOfItems: hotels.length,
  itemListElement: hotels.map((h, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: h.name_he,
    url: `https://yalla-bali.co.il/hotels/${h.slug}`,
  })),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'דף הבית', item: 'https://yalla-bali.co.il/' },
    { '@type': 'ListItem', position: 2, name: 'מלונות' },
  ],
}

const categoryLinks = [
  { label: '⭐ 5 כוכבים', href: '/hotels/5-stars/' },
  { label: '🏖️ חוף', href: '/hotels/beach/' },
  { label: '👨‍👩‍👧 משפחתי', href: '/hotels/family/' },
  { label: '💎 יוקרה', href: '/hotels/luxury/' },
]

const starFilters = [
  { label: 'הכל', filter: 'all' },
  { label: '⭐ 5 כוכבים', filter: '5' },
  { label: '⭐ 4 כוכבים', filter: '4' },
  { label: '⭐ 3 כוכבים', filter: '3' },
]
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="relative py-20 px-4 bg-gradient-to-b from-teal-500/10 to-transparent">
    <div class="max-w-6xl mx-auto text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">מלונות</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black mb-4">מלונות בבאלי</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        באלי מארחת חמישים מלונות 5-כוכבים בעולם, כולל בורג׳ אל ערב, אטלנטיס, וארמאני הוטל באלי.
        מלונות בבאלי מציעים חוף פרטי, בריכות אינסוף מחוממות, ספא עולמיים ושפים מהשורה הראשונה בחו״ל.
        בחר מלון בבאלי לפי המיקום (Downtown, Marina, Palm, Beach) וההעדפה שלך (משפחתי, רומנטי, יוקרה).
      </p>
      <p class="mt-4 text-teal-400 font-medium" id="hotel-count">{hotels.length} מלונות</p>
    </div>
  </section>

  <!-- Category links (SEO pages) -->
  <section class="sticky top-0 z-30 bg-[#0d0d0d]/95 backdrop-blur border-b border-white/5 px-4 py-3">
    <div class="max-w-6xl mx-auto flex gap-2 overflow-x-auto scrollbar-hide">
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black">הכל</span>
      {categoryLinks.map((cat) => (
        <a
          href={cat.href}
          class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap"
        >
          {cat.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Star filter pills (client-side) -->
  <section class="bg-[#0d0d0d] px-4 py-2">
    <div class="max-w-6xl mx-auto flex gap-2 overflow-x-auto scrollbar-hide">
      {starFilters.map((p) => (
        <button
          data-filter={p.filter}
          class:list={[
            'hotel-pill flex-none px-3 py-1 rounded-full text-xs font-medium transition-all whitespace-nowrap cursor-pointer',
            p.filter === 'all'
              ? 'bg-teal-500/20 text-teal-400 font-bold'
              : 'bg-white/5 text-white/40 hover:bg-white/10 hover:text-white',
          ]}
        >
          {p.label}
        </button>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pb-20 pt-8">
    {hotels.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="hotels-grid">
        {hotels.map((hotel) => (
          <div class="hotel-item" data-stars={hotel.star_rating?.toString() || ''}>
            <HotelCard {...hotel} />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-center text-white/40 py-12">לא נמצאו מלונות כרגע.</p>
    )}
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.hotel-pill')
    const items = document.querySelectorAll<HTMLElement>('.hotel-item')
    const countEl = document.getElementById('hotel-count')

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter || 'all'

        // Update active pill
        pills.forEach((p) => {
          p.classList.remove('bg-teal-500', 'text-black', 'font-bold')
          p.classList.add('bg-white/5', 'text-white/60')
        })
        pill.classList.remove('bg-white/5', 'text-white/60')
        pill.classList.add('bg-teal-500', 'text-black', 'font-bold')

        // Filter items
        let visible = 0
        items.forEach((item) => {
          const stars = item.dataset.stars || ''
          const show = filter === 'all' || stars === filter
          item.style.display = show ? '' : 'none'
          if (show) visible++
        })

        if (countEl) countEl.textContent = visible + ' מלונות'
      })
    })
  })
</script>
