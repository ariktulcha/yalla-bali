---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

// Luxury = 5-star hotels (all premium brands in Bali are 5-star)
const LUXURY_BRANDS = ['Four Seasons', 'Mandarin', 'Waldorf', 'Raffles', 'One&Only', 'ואן אנד אונלי', 'Kempinski', 'Park Hyatt', 'Bulgari', 'AYANA', 'Mulia', 'W Bali']
const items = (data || []).filter(h =>
  h.star_rating >= 5 ||
  LUXURY_BRANDS.some(b => (h.name_he || '').includes(b) || (h.name_en || '').includes(b))
)

const pageTitle = 'מלונות יוקרה בבאלי | Yalla Bali'
const pageDescription = 'מלונות היוקרה המובילים בבאלי. חוויות אירוח ברמה הגבוהה ביותר — סוויטות מפוארות, ספא עולמי ושירות אישי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות יוקרה בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות יוקרה' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Category pills -->
    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/5-stars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">⭐ 5 כוכבים</a>
      <a href="/hotels/beach/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ חוף</a>
      <a href="/hotels/family/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">👨‍👩‍👧 משפחתי</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">💎 יוקרה</span>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות יוקרה בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי מגדירה מחדש את מושג היוקרה. מלונות כמו AYANA, Mulia ו-Four Seasons
        מציעים חוויה שאין כמותה — סוויטות עם נוף פנורמי, ספא ברמה עולמית ושירות מושלם.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות יוקרה כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות יוקרה בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מלון היוקרה הכי טוב בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">AYANA הוא מלון יוקרה בבאלי המובחר, כולל ספא עולמי וחופים פרטיים. מלונות יוקרה בבאלי אחרים: Mulia, Four Seasons, W Bali. בחרו מלון יוקרה בבאלי לפי הסגנון שלכם.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה לילה במלון יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה בבאלי עולה מ-400 דולר ללילה. מלונות יוקרה בבאלי יכול להגיע ל-2,000+ דולר לסוויטה בעונת השיא. מלון יוקרה בבאלי בעל מחירים משתנים לפי העונה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה כולל מלון יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה בבאלי כולל: ספא, מסעדות, בריכות אינסוף, חוף פרטי. מלון יוקרה בבאלי מספק שירות באטלר וטרנספורט.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">אילו מלונות יוקרה בבאלי עם חוף פרטי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות יוקרה בבאלי על חוף: AYANA, Mulia, Four Seasons Jimbaran. מלון יוקרה בבאלי עם חוף פרטי מציע חוויה ים בלעדית.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזה משפחות טובות למלון יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה בבאלי מתאים למשפחות עשירות או לחתן וכלה. מלונות יוקרה בבאלי מרוויחים מעמדות מיוחדים לאירועים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">צריך להזמין מלון יוקרה בבאלי מראש?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מלון יוקרה בבאלי צריך הזמנה לפחות חודשיים. מלונות יוקרה בבאלי מתמלאים במהירות בעונה גבוהה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה סוגי סוויטות במלונות יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה בבאלי מציע: סוויטות מלכותיות, פנטהאוס, סוויטות עם מטבח. מלון יוקרה בבאלי עם סוויטות ממש מפוארות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מסעדות בבאלי במלון יוקרה?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון יוקרה בבאלי כולל מסעדות זכירי ברמה עולמית. מלון יוקרה בבאלי מציע מטבח צרפתי, איטלקי, ואסייתי אותנטי. כל מלון יוקרה בבאלי מופעל על ידי שפים מנוסים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה ייחודי בתופעל מלון יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות יוקרה בבאלי מציעים ספא באליני, שירות קונסיירג' 24/7, ודיינינג מלא עם שפים בינלאומיים. מלון יוקרה בבאלי מספק חוויה אישית מותאמת לכל אורח.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה ספא מציעה מלונות יוקרה בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות יוקרה בבאלי מציעים ספא עולמיים עם טיפולים פרימיום. ספא במלונות יוקרה בבאלי כולל עיסוי באליני מסורתי, טיפולי פנים וטיפולי גוף מעמיקים.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים עזרה בבחירת מלון יוקרה בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש מלון יוקרה בבאלי ✨')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
