---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

// Beach hotels = Seminyak, Jimbaran, Sanur, Canggu or "beach" in name/area
const BEACH_KEYWORDS = ["ביץ'", "beach", "חוף", "סמינייק", "seminyak", "ג'ימברן", "jimbaran", "סנור", "sanur", "קאנגו", "canggu", "ים"]
const items = (data || []).filter(h =>
  BEACH_KEYWORDS.some(kw =>
    (h.name_he || '').toLowerCase().includes(kw.toLowerCase()) ||
    (h.name_en || '').toLowerCase().includes(kw.toLowerCase()) ||
    (h.area || '').toLowerCase().includes(kw.toLowerCase())
  )
)

const pageTitle = 'מלונות חוף בבאלי | Yalla Bali'
const pageDescription = 'מלונות חוף מובילים בבאלי עם גישה ישירה לים. חופים פרטיים, בריכות אינסוף ונוף מדהים לים הערבי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות חוף בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות חוף' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Category pills -->
    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/5-stars/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">⭐ 5 כוכבים</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🏖️ חוף</span>
      <a href="/hotels/family/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">👨‍👩‍👧 משפחתי</a>
      <a href="/hotels/luxury/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">💎 יוקרה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות חוף בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי מציעה מלונות חוף מהיפים בעולם, עם חופים פרטיים, מים צלולים
        ונוף מרהיב לים ההודי. הנה המלונות המומלצים שלנו על קו החוף.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
            booking_url={item.booking_url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות חוף כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות חוף בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">באילו אזורים בבאלי יש מלונות חוף?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי נמצאים בעיקר בסמינייק, ג'ימברן, סנור וקאנגו. כל אזורי המלונות חוף בבאלי הללו הם פופולריים מאד עם חופים יפים ובריכות אינסוף.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם כל מלונות חוף בבאלי כוללים חוף פרטי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">רוב מלונות חוף 5 כוכבים בבאלי כוללים חוף פרטי. מלונות חוף בבאלי בדרגה נמוכה יותר קרובים לחופים ציבוריים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה העונה האידאלית למלון חוף בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי נעימים ביותר בנובמבר-אפריל כשהמזג אוויר אידאלי. בקיץ מלונות חוף בבאלי זולים יותר אבל חם עז.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה המחירים למלון חוף בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון חוף בבאלי עולה בין 80-400 דולר בעונה רגילה. מלונות חוף בבאלי יקרים יותר בחורף וזולים יותר בקיץ.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזה בריכות יש במלונות חוף בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי בדרך כלל כוללים בריכות אינסוף, בריכות שחייה מחוממות. מלון חוף בבאלי עשוי להיות בבריכה או בים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה משקקות מוצעות במלונות חוף בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי מציעים: ספא, מסעדות, ברים על הים. כל מלון חוף בבאלי חייב להציע נוחות היוקרה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">צריך להזמין מלון חוף בבאלי מראש?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מומלץ להזמין מלון חוף בבאלי מראש בעיקר בחורף. מלונות חוף בבאלי פופולריים מתמלאים במהירות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה המזג אוויר בבאלי לחוף?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי אידאליים בחורף (26-28 מעלות). בקיץ בבאלי (28-33 מעלות), מלונות חוף בבאלי עדיין יפים עם אקלים חם ויבש.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איזה מלונות חוף בבאלי הטובים ביותר?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף מובילים בבאלי כוללים את Four Seasons Jimbaran, AYANA, Mulia ו-W Bali. מלונות חוף בבאלי אלה מיוחדים בחוף פרטי ושירות פאר אקסלנס.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה פעילויות מימיות בחופי מלונות בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות חוף בבאלי מציעים: גלישה, צלילה, ג'ט סקי, קנו וסקי מימי. כל מלון חוף בבאלי מציע מערכות פעילויות מימיות שונות.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
