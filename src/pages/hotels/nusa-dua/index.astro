---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(h =>
  (h.area || '').toLowerCase().includes('nusa dua') ||
  (h.area || '').toLowerCase().includes('nusa-dua') ||
  (h.name_en || '').toLowerCase().includes('nusa dua')
)

const pageTitle = 'מלונות בנוסה דואה באלי — המלצות ודירוגים | Yalla Bali'
const pageDescription = 'מלונות מומלצים בנוסה דואה, באלי. ריזורטים 5 כוכבים, חופים פרטיים, אזור מוגן ושקט — המקום המושלם למשפחות וזוגות בבאלי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות בנוסה דואה באלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות בנוסה דואה' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/ubud/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌿 אובוד</a>
      <a href="/hotels/canggu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏄 קאנגו</a>
      <a href="/hotels/seminyak/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌅 סמינייק</a>
      <a href="/hotels/uluwatu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🪨 אולוואטו</a>
      <a href="/hotels/jimbaran/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🐟 ג׳ימברן</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🌴 נוסה דואה</span>
      <a href="/hotels/sanur/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎣 סנור</a>
      <a href="/hotels/kuta/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ קוטה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות בנוסה דואה באלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        נוסה דואה הוא האזור הכי אקסקלוסיבי בבאלי — ריזורטים יוקרתיים באזור שמור, חופים נקיים ומים רגועים.
        מלונות בנוסה דואה באלי מושלמים למשפחות, זוגות ולכל מי שמחפש חופשת פרימיום בבאלי.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
            booking_url={item.booking_url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות בנוסה דואה כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות בנוסה דואה באלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מיוחד במלונות בנוסה דואה באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בנוסה דואה באלי נמצאים באזור תיירותי שמור ומאובטח עם חופים נקיים ומים רגועים. מלונות בנוסה דואה באלי הם מהיוקרתיים ביותר באי, עם שירות 5 כוכבים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה מלון בנוסה דואה באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון בנוסה דואה באלי עולה בין 120 ל-700 דולר ללילה. ריזורטים כמו St. Regis ו-Mulia בנוסה דואה באלי הם מהיקרים והמפוארים ביותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם נוסה דואה באלי מתאים למשפחות?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">נוסה דואה באלי מושלם למשפחות. מלונות בנוסה דואה באלי מציעים מועדוני ילדים, בריכות ילדים, חוף רגוע וסביבה בטוחה. המים בנוסה דואה באלי רגועים ומתאימים לשחייה עם ילדים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה יש לעשות ליד מלונות בנוסה דואה באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בנוסה דואה באלי קרובים ל-Water Blow, מקדש Geger, שדרת הקניות Bali Collection, שמורת הצבים ולמגוון ספורט ימי. גולף בנוסה דואה באלי זמין גם.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איפה נוסה דואה באלי ביחס לשדה התעופה?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בנוסה דואה באלי נמצאים כ-20 דקות משדה התעופה. נוסה דואה באלי קרוב גם לג׳ימברן ואולוואטו, מה שמאפשר לשלב אזורים בחופשה אחת.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
