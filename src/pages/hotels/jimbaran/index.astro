---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(h =>
  (h.area || '').toLowerCase().includes('jimbaran') ||
  (h.name_en || '').toLowerCase().includes('jimbaran')
)

const pageTitle = 'מלונות בג׳ימברן באלי — המלצות ודירוגים | Yalla Bali'
const pageDescription = 'מלונות מומלצים בג׳ימברן, באלי. ריזורטים יוקרתיים עם חוף פרטי, מסעדות דגים על החוף ושקיעות מושלמות בג׳ימברן באלי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות בג׳ימברן באלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות בג׳ימברן' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/hotels/ubud/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌿 אובוד</a>
      <a href="/hotels/canggu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏄 קאנגו</a>
      <a href="/hotels/seminyak/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌅 סמינייק</a>
      <a href="/hotels/uluwatu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🪨 אולוואטו</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🐟 ג׳ימברן</span>
      <a href="/hotels/nusa-dua/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌴 נוסה דואה</a>
      <a href="/hotels/sanur/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎣 סנור</a>
      <a href="/hotels/kuta/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ קוטה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות בג׳ימברן באלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        ג׳ימברן ידוע בחוף הרחב והשקט שלו, מסעדות הדגים המפורסמות על החוף והריזורטים היוקרתיים.
        מלונות בג׳ימברן באלי מציעים חוף פרטי, ספא מפנק וארוחות שקיעה עם רגליים בחול.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
            booking_url={item.booking_url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות בג׳ימברן כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות בג׳ימברן באלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מיוחד במלונות בג׳ימברן באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בג׳ימברן באלי מציעים חוף פרטי רחב עם חול לבן, מסעדות seafood על החוף ואווירה שקטה ומשפחתית. ג׳ימברן באלי הוא האזור האידאלי לריזורטים יוקרתיים עם חוף.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה מלון בג׳ימברן באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון בג׳ימברן באלי עולה בין 100 ל-600 דולר ללילה. מלונות 5 כוכבים כמו AYANA ו-Four Seasons בג׳ימברן באלי נעים סביב 300-800 דולר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם ג׳ימברן באלי מתאים למשפחות?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">ג׳ימברן באלי מושלם למשפחות. מלונות בג׳ימברן באלי מציעים חוף רגוע בלי גלים חזקים, מועדוני ילדים ובריכות משפחתיות. החוף בג׳ימברן באלי בטוח לילדים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה יש לעשות ליד מלונות בג׳ימברן באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בג׳ימברן באלי קרובים לשוק הדגים של ג׳ימברן, מסעדות seafood על החוף, מקדש אולוואטו ו-GWK Cultural Park. ערבי seafood BBQ על חוף ג׳ימברן באלי הם חובה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איפה ג׳ימברן באלי ביחס לשדה התעופה?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות בג׳ימברן באלי נמצאים 10-15 דקות בלבד משדה התעופה הבינלאומי. ג׳ימברן באלי הוא מהאזורים הכי נוחים להגעה ישירות מהטיסה.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
