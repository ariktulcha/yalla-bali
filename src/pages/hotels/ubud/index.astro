---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import HotelCard from '../../../components/Cards/HotelCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('hotels')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(h =>
  (h.area || '').toLowerCase().includes('ubud') ||
  (h.name_en || '').toLowerCase().includes('ubud')
)

const pageTitle = 'מלונות באובוד באלי — המלצות ודירוגים | Yalla Bali'
const pageDescription = 'מלונות מומלצים באובוד, באלי. וילות יוקרתיות, ריזורטים מוקפים בטבע, ספא בלינזי ואווירה רוחנית בלב ג׳ונגל אובוד.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'מלונות באובוד באלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/hotels/${item.slug}`, 'https://ibalibali.com').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מלונות', href: '/hotels' },
  { label: 'מלונות באובוד' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/hotels/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🌿 אובוד</span>
      <a href="/hotels/canggu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏄 קאנגו</a>
      <a href="/hotels/seminyak/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌅 סמינייק</a>
      <a href="/hotels/uluwatu/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🪨 אולוואטו</a>
      <a href="/hotels/jimbaran/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🐟 ג׳ימברן</a>
      <a href="/hotels/nusa-dua/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🌴 נוסה דואה</a>
      <a href="/hotels/sanur/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🎣 סנור</a>
      <a href="/hotels/kuta/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🏖️ קוטה</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">מלונות באובוד באלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        אובוד הוא הלב הרוחני והתרבותי של באלי — שדות אורז ירוקים, מקדשים עתיקים וג׳ונגל טרופי.
        מלונות באובוד באלי מציעים וילות פרטיות עם בריכות אינסוף, ספא בלינזי ואווירה של שקט מוחלט.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <HotelCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            star_rating={item.star_rating}
            price_range={item.price_range}
            booking_url={item.booking_url}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו מלונות באובוד כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — מלונות באובוד באלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה מיוחד במלונות באובוד באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות באובוד באלי שוכנים בלב הג׳ונגל הטרופי, מוקפים בשדות אורז ירוקים ומציעים חוויית טבע ורוגע ייחודית. רבים מהמלונות באובוד באלי כוללים ספא בלינזי, שיעורי יוגה ובריכות אינסוף עם נוף לעמק.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה מלון באובוד באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלון באובוד באלי עולה בין 50 ל-500 דולר ללילה. וילות פרטיות באובוד באלי יכולות לעלות 200-800 דולר, בעוד גסטהאוסים פשוטים באובוד זמינים מ-30 דולר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש מלונות באובוד באלי קרובים למרכז?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, מלונות רבים באובוד באלי נמצאים בהליכה מהשוק והמרכז. מלונות באובוד באלי ליד Monkey Forest ו-Ubud Palace הם הפופולריים ביותר.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה העונה הטובה ביותר למלון באובוד באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">העונה האידאלית למלון באובוד באלי היא אפריל-אוקטובר (עונה יבשה). מלונות באובוד באלי נעימים גם בעונת הגשמים (נובמבר-מרץ) כי הטבע מלבלב.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">אילו פעילויות זמינות ליד מלונות באובוד באלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">מלונות באובוד באלי קרובים לטרסות האורז של טגלאלנג, יער הקופים, מקדש טירתה אמפול ואטרקציות תרבותיות רבות. שיעורי בישול בלינזי ויוגה זמינים ברוב המלונות באובוד באלי.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>
