---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { pickMetaDescription } from '../../lib/seo'
import { site, pageTitle as buildPageTitle } from '../../config/site'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: guides } = await supabaseAdmin
    .from('guides')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (guides ?? []).map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }))
}

const { guide } = Astro.props

const title = guide.title_he ?? guide.name_he ?? guide.title ?? guide.name
const titleEn = guide.title_en ?? guide.name_en
const category = guide.category ?? guide.metadata?.category
const readTime = guide.read_time ?? guide.metadata?.read_time
const author = guide.author ?? guide.metadata?.author ?? site.brand
const datePublished = guide.published_at ?? guide.created_at ?? guide.metadata?.date_published

// Strip leading H1 from markdown content — the page already renders an <h1> from the title.
// This prevents duplicate H1 tags which hurt SEO.
const stripLeadingH1 = (md: string) => md.replace(/^\s*#\s+[^\n]+\n+/, '')
const contentHtml = guide.full_content ? await marked(stripLeadingH1(guide.full_content)) : ''

// Related guides — category + keyword matching
const currentSlug = guide.slug
const currentCategory = guide.category ?? guide.metadata?.category
const keywords = currentSlug.split('-').filter((w: string) => w.length > 3)

const { data: allGuides } = await supabaseAdmin
  .from('guides')
  .select('slug, name_he, excerpt, image, category')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .neq('slug', currentSlug)
  .limit(56)

const scored = (allGuides ?? []).map((g: any) => {
  const keywordScore = keywords.filter((k: string) => g.slug.includes(k)).length
  const categoryBonus = (currentCategory && g.category === currentCategory) ? 3 : 0
  return { ...g, score: keywordScore + categoryBonus }
})
scored.sort((a: any, b: any) => b.score - a.score || Math.random() - 0.5)
const related = scored.slice(0, 3)

const pageTitle = guide.meta_title || buildPageTitle(title, 'guide')
const pageDescription = guide.meta_description || pickMetaDescription(guide, `מדריך מקיף ל${site.destinationName}`)

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: guide.description || guide.excerpt,
  image: guide.image || undefined,
  url: new URL(`/guides/${guide.slug}`, Astro.site).toString(),
  author: {
    '@type': 'Organization',
    name: typeof author === 'string' ? author : site.brand,
  },
  publisher: {
    '@type': 'Organization',
    name: site.brand,
    url: 'https://ibalibali.com',
  },
  ...(datePublished ? { datePublished: new Date(datePublished).toISOString() } : {}),
  ...(guide.updated_at ? { dateModified: new Date(guide.updated_at).toISOString() } : {}),
  inLanguage: 'he',
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides' },
  { label: title },
]

const dbFaq = Array.isArray(guide.faq) ? guide.faq : []
const faqItems = dbFaq.length > 0
  ? dbFaq.map((item: any) => ({ q: item.q, a: item.a }))
  : [
      {
        q: `האם המידע במדריך "${title}" על באלי עדכני?`,
        a: `כן, המדריך "${title}" מעודכן ל-${new Date().getFullYear()}. אנחנו מעדכנים את כל המדריכים שלנו על באלי באופן קבוע כדי שהמידע יישאר אמין ומדויק.`,
      },
      {
        q: `האם יש מידע נוסף על הנושא "${title}" באתר?`,
        a: `בוודאי! בנוסף ל"${title}", אתם יכולים לבקר בדף "מדריכים" כדי לראות את כל המאמרים שלנו על באלי, או לחפש בנושאים קשורים. יש לנו מאות עמודים של תוכן על באלי.`,
      },
      {
        q: `האם אפשר להדפיס את המדריך "${title}" לשימוש אישי?`,
        a: `אתם יכולים בחופשיות להעתיק ולהדפיס את "${title}" לשימוש אישי בטיול לבאלי. אנחנו רק מבקשים שתזכרו את ${site.brand} בעת שיתוף.`,
      },
      {
        q: `אהבתם את המדריך "${title}"? איך אפשר לתמוך ב${site.brand}?`,
        a: `תודה שאהבתם את "${title}"! הדרך הטובה ביותר לתמוך בנו היא לשתף את המדריך עם חברים שמתכננים טיול לבאלי, להשאיר ביקורת חיובית, או להשתמש בלינקי ההפניה שלנו כשאתם מזמינים טיולים או מלונות בבאלי. זה עוזר לנו רבות!`,
      },
    ]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://ibalibali.com/guides/${guide.slug}`}
  ogImage={guide.image}
  ogType="article"
  schema={articleSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    {guide.image && (
      <div class="aspect-[16/9] overflow-hidden rounded-2xl mb-8">
        <img
          src={guide.image}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h1>
      {titleEn && (
        <p class="text-lg text-white/50">{titleEn}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm text-white/60">
      {category && (
        <span class="text-sm px-3 py-1 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20">
          {category}
        </span>
      )}
      {readTime && (
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {readTime}
        </span>
      )}
      {datePublished && (
        <time datetime={new Date(datePublished).toISOString()} class="text-white/40">
          {new Date(datePublished).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {author && (
        <span class="text-white/40">
          מאת: {typeof author === 'string' ? author : site.brand}
        </span>
      )}
    </div>

    {guide.description && !guide.full_content && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">על המדריך — {title}</h2>
        <p class="text-white/80 leading-relaxed">{guide.description}</p>
      </div>
    )}

    {guide.excerpt && guide.full_content && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">תקציר המדריך — {title}</h2>
        <p class="text-lg text-white/80 leading-relaxed font-medium">{guide.excerpt}</p>
      </div>
    )}

    {contentHtml && (
      <div class="prose prose-invert prose-teal prose-lg max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-3">סיכום — {title}</h2>
      <p class="text-white/80 leading-relaxed">
        המדריך "{title}" נועד לספק לכם את כל המידע הדרוש בתכנון טיול לבאלי. עיינו במדריכים נוספים באתר כדי להעמיק עוד בנושאים שמעניינים אתכם.
      </p>
    </div>

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-3">למה "{title}" חשוב לטיול לבאלי</h2>
      <p class="text-white/80 leading-relaxed">
        "{title}" הוא אחד הנושאים שישראלים רבים שואלים עליהם לפני טיסה לבאלי. המדריך הזה מסכם את הידע העדכני ביותר בנושא ומנגיש אותו בעברית, כדי שתוכלו להתמקד בחוויה עצמה ולא בחיפוש מידע באנגלית או באינדונזית.
      </p>
    </div>

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-3">טיפים מעשיים מתוך "{title}"</h2>
      <p class="text-white/80 leading-relaxed">
        המידע ב"{title}" מבוסס על ניסיון בפועל של מטיילים ישראלים בבאלי ועל בדיקות שטח מעודכנות. אנחנו ב{site.brand} מעדכנים את "{title}" באופן קבוע בהתאם לשינויים במחירים, בחוקים ובעונות, כדי שהמידע יישאר אמין ומדויק ככל האפשר.
      </p>
    </div>

    <div class="mb-8">
      <FAQSection items={faqItems} entityName={`המדריך "${title}"`} />
    </div>

    <!-- Related Articles -->
    {related.length > 0 && (
      <section class="mt-16 pt-8 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-6">מאמרים נוספים הקשורים ל"{title}"</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((article: any) => (
            <a
              href={`/guides/${article.slug}`}
              class="group bg-[#1A1208] border border-teal-500/10 hover:border-teal-500/30 rounded-2xl overflow-hidden transition-all"
            >
              <div class="aspect-[16/9] overflow-hidden relative">
                {article.image ? (
                  <img
                    src={article.image}
                    alt={article.name_he}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-teal-500/20 to-teal-900/20 flex items-center justify-center">
                    <span class="text-4xl">📖</span>
                  </div>
                )}
                {article.category && (
                  <span class="absolute top-3 start-3 text-xs px-2.5 py-1 rounded-full bg-teal-500/90 text-black font-medium">
                    {article.category}
                  </span>
                )}
              </div>
              <div class="p-4">
                <h3 class="text-white font-semibold leading-tight group-hover:text-teal-400 transition-colors">
                  {article.name_he}
                </h3>
                {article.excerpt && (
                  <p class="text-white/60 text-sm mt-2 line-clamp-2">{article.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
