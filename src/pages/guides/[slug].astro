---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: guides } = await supabaseAdmin
    .from('guides')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (guides ?? []).map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }))
}

const { guide } = Astro.props

const title = guide.title_he ?? guide.name_he ?? guide.title ?? guide.name
const titleEn = guide.title_en ?? guide.name_en
const category = guide.category ?? guide.metadata?.category
const readTime = guide.read_time ?? guide.metadata?.read_time
const author = guide.author ?? guide.metadata?.author ?? 'Yalla Bali'
const datePublished = guide.published_at ?? guide.created_at ?? guide.metadata?.date_published

const contentHtml = guide.full_content ? await marked(guide.full_content) : ''

// Related guides — keyword-based slug matching
const currentSlug = guide.slug
const keywords = currentSlug.split('-').filter((w: string) => w.length > 3)

const { data: allGuides } = await supabaseAdmin
  .from('guides')
  .select('slug, name_he, excerpt_he, hero_image_url')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .neq('slug', currentSlug)
  .limit(56)

const scored = (allGuides ?? []).map((g: any) => ({
  ...g,
  score: keywords.filter((k: string) => g.slug.includes(k)).length,
}))
scored.sort((a: any, b: any) => b.score - a.score || Math.random() - 0.5)
const related = scored.slice(0, 3)

const pageTitle = `${title} | מדריכים לבאלי | Yalla Bali`
const rawDesc = guide.meta_description || guide.excerpt || guide.description || `${title} — מדריך מקיף לבאלי`
const pageDescription = rawDesc.length > 155 ? rawDesc.substring(0, 152) + '...' : rawDesc

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: guide.description || guide.excerpt,
  image: guide.image || undefined,
  url: new URL(`/guides/${guide.slug}`, Astro.site).toString(),
  author: {
    '@type': 'Organization',
    name: typeof author === 'string' ? author : 'Yalla Bali',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Yalla Bali',
    url: 'https://yalla-bali.co.il',
  },
  ...(datePublished ? { datePublished: new Date(datePublished).toISOString() } : {}),
  ...(guide.updated_at ? { dateModified: new Date(guide.updated_at).toISOString() } : {}),
  inLanguage: 'he',
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'מדריכים', href: '/guides' },
  { label: title },
]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://yalla-bali.co.il/guides/${guide.slug}`}
  ogImage={guide.image}
  ogType="article"
  schema={articleSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    {guide.image && (
      <div class="aspect-[16/9] overflow-hidden rounded-2xl mb-8">
        <img
          src={guide.image}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h1>
      {titleEn && (
        <p class="text-lg text-white/50">{titleEn}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm text-white/60">
      {category && (
        <span class="text-sm px-3 py-1 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20">
          {category}
        </span>
      )}
      {readTime && (
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {readTime}
        </span>
      )}
      {datePublished && (
        <time datetime={new Date(datePublished).toISOString()} class="text-white/40">
          {new Date(datePublished).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {author && (
        <span class="text-white/40">
          מאת: {typeof author === 'string' ? author : 'Yalla Bali'}
        </span>
      )}
    </div>

    {guide.description && !guide.full_content && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-white/80 leading-relaxed">{guide.description}</p>
      </div>
    )}

    {guide.excerpt && guide.full_content && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-lg text-white/80 leading-relaxed font-medium">{guide.excerpt}</p>
      </div>
    )}

    {contentHtml && (
      <div class="prose prose-invert prose-teal prose-lg max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <!-- WhatsApp CTA -->
    <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">אהבתם את המדריך? יש לכם שאלות על באלי? נשמח לעזור!</p>
      <a
        dir="rtl"
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתכנן טיול לבאלי ויש לי שאלות 🌴')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        דברו איתנו בווטסאפ
      </a>
    </div>

    <!-- Related Articles -->
    {related.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-800" dir="rtl">
        <h2 class="text-2xl font-bold text-white mb-6">📚 מאמרים קשורים</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((article: any) => (
            <a
              href={`/guides/${article.slug}`}
              class="group bg-gray-900 rounded-xl overflow-hidden hover:bg-gray-800 transition-colors"
            >
              {article.hero_image_url ? (
                <img
                  src={article.hero_image_url}
                  alt={article.name_he}
                  class="w-full h-40 object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-40 bg-gray-800 flex items-center justify-center">
                  <span class="text-4xl">🌍</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-tight group-hover:text-teal-400 transition-colors">
                  {article.name_he}
                </h3>
                {article.excerpt_he && (
                  <p class="text-gray-400 text-xs mt-1 line-clamp-2">{article.excerpt_he}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
