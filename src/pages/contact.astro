---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'צור קשר - יאללה באלי',
  description: 'צרו קשר עם יאללה באלי בווטסאפ או באימייל.',
  url: 'https://yalla-bali.co.il/contact',
  mainEntity: {
    '@type': 'Organization',
    name: 'Yalla Bali',
    url: 'https://yalla-bali.co.il',
    email: 'info@yalla-bali.co.il',
    contactPoint: { '@type': 'ContactPoint', contactType: 'customer service', availableLanguage: ['Hebrew', 'English', 'Arabic'] },
  },
}

const commonTopics = [
  { title: 'הזמנת טיול', desc: 'טיולים הרים, יערות, תרבות — הזמנה מהירה עם אישור מיידי' },
  { title: 'תכנון טיול', desc: 'עזרה בבניית מסלול, בחירת מלון, המלצות מותאמות אישית' },
  { title: 'שאלות על באלי', desc: 'ויזה, כשרות, בטיחות, תחבורה — כל שאלה' },
  { title: 'המלצות למסעדות', desc: 'כשר, לא כשר, יוקרתי, תקציבי — נמצא לכם' },
  { title: 'סיוע במהלך הטיול', desc: 'נתקעתם? צריכים עזרה? אנחנו זמינים גם במהלך הטיול' },
  { title: 'שיתופי פעולה', desc: 'עסקים, בלוגרים, אתרי תיירות — בואו נדבר' },
]
---

<Layout
  title="צור קשר - יאללה באלי"
  description="צרו קשר עם יאללה באלי בווטסאפ או באימייל. נשמח לעזור לכם לתכנן את הטיול המושלם לבאלי, להזמין טיולים, או לענות על כל שאלה."
  canonical="https://yalla-bali.co.il/contact"
>
  <SchemaOrg schema={contactSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">צרו <span class="text-teal-400">קשר</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">נשמח לעזור לכם לתכנן את הטיול המושלם לבאלי. שלחו הודעה בווטסאפ ונחזור אליכם תוך דקות.</p>
    </div>
  </section>

  <!-- WhatsApp Primary CTA -->
  <section class="max-w-4xl mx-auto px-4 -mt-8 relative z-20 mb-12">
    <a href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתעניין בטיול לבאלי')}`} target="_blank" rel="noopener noreferrer" dir="rtl" class="block bg-gradient-to-r from-green-600 to-green-500 hover:from-green-500 hover:to-green-400 rounded-2xl p-8 md:p-10 text-center transition-all shadow-lg shadow-green-600/20 group">
      <span class="text-5xl block mb-4 group-hover:scale-110 transition-transform">💬</span>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">שלחו הודעה בווטסאפ</h2>
      <p class="text-white/90 text-lg mb-4 max-w-md mx-auto">הדרך הכי מהירה לתשובות. שלחו הודעה ונחזור אליכם תוך דקות.</p>
      <div class="flex flex-wrap justify-center gap-4 text-white/80 text-sm">
        <span class="flex items-center gap-1.5">⏰ זמינים כל יום</span>
        <span class="flex items-center gap-1.5">📱 מענה מהיר</span>
        <span class="flex items-center gap-1.5">🌍 עברית, אנגלית, ערבית</span>
      </div>
    </a>
  </section>

  <!-- Contact Methods -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="grid md:grid-cols-2 gap-6">
      <a href="mailto:info@yalla-bali.co.il" class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 hover:border-teal-500/40 rounded-2xl p-6 text-center transition-all group">
        <span class="text-4xl block mb-3 group-hover:scale-110 transition-transform">📧</span>
        <h3 class="text-xl font-bold text-white mb-2">אימייל</h3>
        <p class="text-white/60 text-sm mb-3">לשאלות מפורטות, שיתופי פעולה ופניות עסקיות</p>
        <span class="text-teal-400 font-bold" dir="ltr">info@yalla-bali.co.il</span>
      </a>
      <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6 text-center">
        <span class="text-4xl block mb-3">⏰</span>
        <h3 class="text-xl font-bold text-white mb-2">זמני מענה</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between text-white/60"><span>וואטסאפ:</span><span class="text-green-400 font-bold">תוך דקות</span></div>
          <div class="flex justify-between text-white/60"><span>אימייל:</span><span class="text-teal-400 font-bold">עד 24 שעות</span></div>
          <div class="flex justify-between text-white/60"><span>שעות פעילות:</span><span class="text-white font-bold">כל יום, 08:00-23:00</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">או שלחו <span class="text-teal-400">הודעה</span></h2>
    <p class="text-white/60 text-center mb-8">מלאו את הטופס ונחזור אליכם בהקדם</p>
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <form name="contact" method="POST" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-white font-bold text-sm mb-2">שם מלא <span class="text-[#0D9488]">*</span></label>
            <input type="text" id="name" name="name" required placeholder="השם שלכם" class="w-full bg-[#0D0D0D] border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:border-teal-500/50 focus:outline-none focus:ring-1 focus:ring-teal-500/50 transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-white font-bold text-sm mb-2">אימייל <span class="text-[#0D9488]">*</span></label>
            <input type="email" id="email" name="email" required placeholder="your@email.com" dir="ltr" class="w-full bg-[#0D0D0D] border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:border-teal-500/50 focus:outline-none focus:ring-1 focus:ring-teal-500/50 transition-colors" />
          </div>
        </div>
        <div>
          <label for="phone" class="block text-white font-bold text-sm mb-2">טלפון (אופציונלי)</label>
          <input type="tel" id="phone" name="phone" placeholder="05X-XXXXXXX" dir="ltr" class="w-full bg-[#0D0D0D] border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:border-teal-500/50 focus:outline-none focus:ring-1 focus:ring-teal-500/50 transition-colors" />
        </div>
        <div>
          <label for="subject" class="block text-white font-bold text-sm mb-2">נושא <span class="text-[#0D9488]">*</span></label>
          <select id="subject" name="subject" required class="w-full bg-[#0D0D0D] border border-white/10 rounded-xl px-4 py-3 text-white focus:border-teal-500/50 focus:outline-none focus:ring-1 focus:ring-teal-500/50 transition-colors">
            <option value="">בחרו נושא</option>
            <option value="tour">הזמנת טיול בבאלי</option>
            <option value="trip-planning">עזרה בתכנון טיול</option>
            <option value="question">שאלה כללית על באלי</option>
            <option value="kosher">שאלה על כשרות</option>
            <option value="business">שיתוף פעולה עסקי</option>
            <option value="feedback">פידבק/הצעה</option>
            <option value="other">אחר</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-white font-bold text-sm mb-2">הודעה <span class="text-[#0D9488]">*</span></label>
          <textarea id="message" name="message" required rows="5" placeholder="ספרו לנו איך נוכל לעזור..." class="w-full bg-[#0D0D0D] border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:border-teal-500/50 focus:outline-none focus:ring-1 focus:ring-teal-500/50 transition-colors resize-none"></textarea>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <button type="submit" class="inline-flex items-center gap-2 bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-400 hover:to-teal-500 text-[#0D0D0D] px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-teal-500/25">
            📩 שלחו הודעה
          </button>
          <p class="text-white/40 text-sm">
            או פשוט שלחו הודעה ב<a href="https://wa.me/972528211665" target="_blank" rel="noopener noreferrer" class="text-green-400 hover:underline mx-1">וואטסאפ</a>— יותר מהיר!
          </p>
        </div>
      </form>
    </div>
  </section>

  <!-- Common Topics -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-white mb-6 text-center">פונים אלינו <span class="text-teal-400">בנושאים:</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {commonTopics.map((t) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-xl p-4">
          <h3 class="text-white font-bold mb-1">{t.title}</h3>
          <p class="text-white/50 text-sm">{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ Link -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-6 md:p-8 text-center">
      <h3 class="text-xl font-bold text-white mb-3">אולי התשובה כבר נמצאת אצלנו?</h3>
      <p class="text-white/60 mb-4">בדקו את דף השאלות הנפוצות — שם תמצאו תשובות מפורטות לשאלות נפוצות על טיול לבאלי</p>
      <a href="/faq" class="inline-flex items-center gap-2 bg-[#0D0D0D] border border-teal-500/30 hover:border-teal-500/50 text-teal-400 px-6 py-3 rounded-xl font-bold transition-all">שאלות ותשובות</a>
    </div>
  </section>
</Layout>
