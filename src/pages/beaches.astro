---
import Layout from '../components/Layout.astro'

const title = 'חופים בבאלי — 7 החופים הכי שווים לביקור | Yalla Bali'
const description = 'מדריך מפורט לחופים בבאלי: קוטה, סמינייק, קאנגו, נוסה דואה, ג\'ימברן, אולוואטו וסאנור. כל מה שצריך לדעת — גלישה, שקיעות, ריפים, ואיך מגיעים.'

const beaches = [
  {
    id: 'kuta',
    image: 'https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=1200&q=80&fit=crop',
    name: 'Kuta Beach',
    name_he: 'קוטה',
    area: 'דרום באלי',
    description: 'קוטה הוא החוף הכי מפורסם בבאלי — ולא בכדי. חוף ארוך ופתוח של כמה קילומטרים, עם גלים מושלמים לגלישה, חול כהה ורך, ושקיעות שצובעות את השמיים בכתום ואדום. זה המקום שכולם חושבים עליו כשאומרים "חוף בבאלי".\n\nהאווירה כאן תוססת ותיירותית: שורות של בתי קפה, בתי גלישה, מסאג\' על החוף, ורוכלים שמציעים כל דבר משרשרות ועד שייקים טריים. סנסט בקוטה הוא אחד הטקסים שחובה לעשות — מאות אנשים מתכנסים מדי ערב לראות את השמש שוקעת לתוך האוקיינוס ההודי.\n\nאם אתם גולשים מתחילים — זה המקום. יש כאן עשרות ספרי גלישה שמציעים שיעורים ראשונים, עם גלים קלים ומורים ידידותיים. וגם אם אתם לא גולשים, פשוט לשבת עם קוקו בידיים ולהביט בגלים זו חוויה בפני עצמה.',
    bestFor: 'גלישה למתחילים, שקיעות, תיירים ראשי פעם בבאלי',
    tips: 'שקיעה בקוטה היא חובה — הגיעו כחצי שעה לפני לתפוס מקום. שיעורי גלישה עולים 150,000–200,000 רופיה לשעה, כולל ציוד. הישמרו מגנבי כיסים בעיקר בצד הצפוני של החוף.',
    freeEntry: true,
    howToGetThere: 'מנגוראה ראי: 15 דקות ברכב. מ-Seminyak: 20 דקות הליכה לאורך החוף. Grab (האובר המקומי) עולה 30,000–50,000 רופיה מהמרכז.',
  },
  {
    id: 'seminyak',
    image: 'https://images.unsplash.com/photo-1559628233-100c798642d8?w=1200&q=80&fit=crop',
    name: 'Seminyak Beach',
    name_he: 'סמינייק',
    area: 'דרום באלי',
    description: 'סמינייק הוא קוטה הגדולה — רק עם יותר סטייל. חוף הים כאן פחות תיירותי ויותר טרנדי: כיסאות שיזוף שמוגשים עם cocktails, מסעדות על שפת הים עם תאורה אמביינטית, ו-beach clubs שמשמיעים מוזיקה כל הערב.\n\nשמות כמו Potato Head, Ku De Ta ו-Finns כבר הפכו לאייקונים של תרבות ה-beach club הבאלינזית. כאן תמצאו את ה-crowd הצעיר, יפה ומסוגנן, עם drinks ביד ורגליים בחול. המחירים קצת יותר גבוהים, אבל האווירה שווה כל שקל.\n\nהגלים בסמינייק מתאימים גם לגולשים מנוסים יותר, אבל החוף פחות "גלישה" ויותר "ויב". בשקיעה, הצבעים כאן מרהיבים במיוחד — אפשר לעמוד על שפת הים עם קוקטייל ולצפות בשמש נכנסת לים.',
    bestFor: 'beach clubs, צעירים, זוגות, ויב ערב',
    tips: 'הזמינו מקום ב-Potato Head מראש לסוף שבוע — נגמר מהר. Happy hour ברוב ה-beach clubs בין 16:00–18:00. חנויות האופנה מסביב שוות סיור — מגוון בגדי ים ייחודיים.',
    freeEntry: true,
    howToGetThere: 'מ-Kuta: 20 דקות הליכה צפונה לאורך החוף, או 10 דקות ברכב. Grab מהמרכז: 40,000–60,000 רופיה.',
  },
  {
    id: 'canggu',
    image: 'https://images.unsplash.com/photo-1530569673472-307dc017a82d?w=1200&q=80&fit=crop',
    name: 'Canggu Beach (Brawah)',
    name_he: 'קאנגו (בראווה)',
    area: 'מרכז-מערב באלי',
    description: 'קאנגו היא המרכז הבלתי מוכרז של ה-digital nomads ו-surfers בבאלי. שלא תתבלבלו — זה לא חוף תיירותי רגיל. זו קהילה שלמה עם קפה-בארים, co-working spaces, חנויות ויניל, ומסעדות שמגישות acai bowls לצד אוכל באלינזי אותנטי.\n\nחוף בראווה הוא הלב של קאנגו — חול כהה, גלים אגרסיביים ואתגריים, ומגרש גלישה שנחשב אחד הטובים בבאלי. הקהל כאן מגיע עם סרפבורד, חוזר עייף ומאושר, ויושב בשעות אחה"צ בתוך Lazy Cats Cafe או Old Man\'s עם ביר גאלה ביד.\n\nאם אתם מחפשים את הצד ה"מגניב" של באלי — החצי שפחות מופיע בגלויות ויותר ב-Instagram האישי של ה-freelancer האמריקאי שגר כאן שנה — קאנגו היא המקום.',
    bestFor: 'גולשים מנוסים, digital nomads, אוהבי כפרים, nomad vibes',
    tips: 'הגלים בקאנגו חזקים — לא מומלץ למתחילים. Old Man\'s הוא הבאר האיקוני — שווה גם אם לא שותים. השכרת אופנוע (50,000–80,000 רופיה ליום) הכי כלכלית להגיע לכאן.',
    freeEntry: true,
    howToGetThere: 'מ-Seminyak: 20 דקות צפונה ברכב. Grab: 50,000–70,000 רופיה ממרכז Kuta/Seminyak. אין תחבורה ציבורית — Grab או אופנוע.',
  },
  {
    id: 'nusadua',
    image: 'https://images.unsplash.com/photo-1552465011-b4e21bf6e79a?w=1200&q=80&fit=crop',
    name: 'Nusa Dua Beach',
    name_he: 'נוסה דואה',
    area: 'מזרח-דרום באלי',
    description: 'נוסה דואה הוא עולם אחר לגמרי מהחופים האחרים. מים בצבע תכלת עז ושקטים כמו אגם, חול לבן בהיר, ורמת ניקיון שנדירה בחופי אינדונזיה. האזור הזה הוא מובלעת יוקרה — מלוני five-star כמו St. Regis, Conrad ו-Mulia שולטים בקו החוף.\n\nהשניף הכי גדול של נוסה דואה הוא הריף — מחסום אלמוגים טבעי שמגן על הלגונה מגלים גדולים, מה שיוצר מים שקטים ובטוחים להשחייה. ילדים יכולים לשחק שעות מבלי שהורים יצטרכו לדאוג. זה גם גן עדן לצוללנים קלים — אפשר לראות דגים צבעוניים ישירות מהחוף.\n\nהחוף הציבורי בנוסה דואה (Geger Beach) נגיש לכולם ואין צורך להיות אורח במלון. אווירה שקטה, ים מרגיע, ונוף שגורם לשכוח מהעולם.',
    bestFor: 'משפחות עם ילדים, זוגות שמחפשים שקט, יוקרה וריף',
    tips: 'Geger Beach (החוף הציבורי) נגיש ללא עלות. גלישה עם שנורקל מומלצת — ציוד להשכרה על החוף ב-50,000 רופיה. הגיעו בבוקר לפני שהמלונות "ממלאים" את החוף.',
    freeEntry: true,
    howToGetThere: 'מ-Kuta: 30–40 דקות דרום-מזרח ברכב. Grab: 80,000–120,000 רופיה ממרכז Kuta. יש taxi מאורגן מהשדה — נוח למי שנוחת ומגיע ישר לנוסה דואה.',
  },
  {
    id: 'jimbaran',
    image: 'https://images.unsplash.com/photo-1518548419970-58e3b4079ab2?w=1200&q=80&fit=crop',
    name: 'Jimbaran Beach',
    name_he: 'ג\'ימברן',
    area: 'דרום-מערב באלי',
    description: 'ג\'ימברן הוא חוף של דייגים ואוכל — שתי אהבות שמשתלבות בצורה מושלמת. בבוקר תראו ספינות דיג עגונות על החוף, מרשתות ממוינות ויציאה לים. בערב, אותו חוף הופך לשורה ארוכה של מסעדות פירות ים ישר על החול, עם שולחנות ומנורות אמביינטיות.\n\nהסנסט בג\'ימברן הוא אחד הטקסים הכי רומנטיים שיש בבאלי. שולחן לשניים, רגליים על חול, גרפת שרימפס טרי ולובסטר שיצא מהים ממש היום — עם השמש שוקעת מאחורי פסגות ג\'אווה. לא פלא שזה הספוט הרשמי לאחלות נישואין.\n\nשימו לב שבגלל תעבורת הדיג, המים לא כמו ב-Nusa Dua — פחות תכלת, יותר חים. אבל זה בהחלט לא הסיבה שמגיעים לכאן. מגיעים לכאן לאכול ולצפות בשקיעה, ובשתי אלו ג\'ימברן לא מאכזב.',
    bestFor: 'ארוחת ערב רומנטית, זוגות, חובבי פירות ים, שקיעות',
    tips: 'הגיעו בשקיעה (17:30–18:30) לארוחת ערב על החוף. המחירים "תיירותיים" — תשאלו כמה עולה לפני שמזמינים. Kedonganan Fish Market בצפון הוא מקום אחר לחלוטין — שוק פירות ים מקומי, זול ואותנטי.',
    freeEntry: true,
    howToGetThere: 'מהשדה (DPS): 10 דקות בלבד — הקרוב ביותר! מ-Kuta: 15–20 דקות דרום ברכב. Grab: 40,000–60,000 רופיה.',
  },
  {
    id: 'uluwatu',
    image: 'https://images.unsplash.com/photo-1518544866330-95a2ab4a7a8c?w=1200&q=80&fit=crop',
    name: 'Uluwatu / Padang Padang',
    name_he: 'אולוואטו / פאדאנג פאדאנג',
    area: 'חצי האי בואקן (דרום)',
    description: 'אולוואטו היא לא חוף — היא ניסיון לחות גבולי. קליפים גבוהים שנופלים לים, גלים שנחשבים בין הגדולים בעולם לגלישה, ומקדש עתיק שיושב על שפת הצוק בדיוק מול השקיעה. זו באלי הדרמטית ביותר שתראו.\n\nהחוף של פאדאנג פאדאנג, כמה דקות נסיעה משם, נראה כאילו הוסתר בכוונה מהעולם — יורדים במדרגות חצובות בסלע, עוברים דרך פתח צר בצוק, ופתאום מגלים חוף זעיר ומופלא עם מים ירוקים-תכולים וצוקים מסביב. זה הספוט שמופיע בכל תמונות ה"best of Bali".\n\nלגולשים: Uluwatu, Bingin ו-Padang Padang הם שלושת המנגנות של חצי האי Bukit. גלי tube ריאלי מהטובים בעולם. לא מתחילים.',
    bestFor: 'גולשים מנוסים, צלמים, חוויות דרמטיות, Kecak Dance בשקיעה',
    tips: 'הכנסו למקדש Uluwatu לצפות ב-Kecak Dance עם השקיעה (18:00 בד"כ, 150,000 רופיה). שמרו על חפצים מהקופים — הם גנבים ממש. חוף פאדאנג פאדאנג עולה 20,000 רופיה כניסה.',
    freeEntry: false,
    howToGetThere: 'מ-Kuta: 45–60 דקות דרומה, דרך חצי האי Bukit. Grab אמין — 80,000–120,000 רופיה. מומלץ לשכור אופנוע לאזור כולו ולקפוץ בין Bingin, Uluwatu ו-Padang Padang.',
  },
  {
    id: 'sanur',
    image: 'https://images.unsplash.com/photo-1573790387438-4da905039392?w=1200&q=80&fit=crop',
    name: 'Sanur Beach',
    name_he: 'סאנור',
    area: 'מזרח דרום-באלי',
    description: 'סאנור הוא ה-antidote לקוטה. שקט, ירוק, מסודר — חוף שמושך משפחות, אנשים בגיל מבוגר יותר, ומי שרוצה להתנתק בלי לאבד נוחות. כאן אין beach clubs רועשים, אין רוכלים אגרסיביים, ואין תנועה כאוטית. רק שביל טיילות נעים לאורך הים, עם עצי קוקוס, ספסלים, ואנשים שמסתכלים על הים.\n\nהנכס הכי גדול של סאנור הוא הזריחה. האי ממוקם בצד המזרחי של באלי, ומה שאומר שהשמש עולה ישר מהים בבוקר — ספקטקל שאוהבי בוקר לא ישכחו בקלות. הריף המגן גם הוא כאן, ומה שיוצר מים שקטים מושלמים לשחייה.\n\nמסאנור נוסעים לנוסה פנידה ו-Nusa Lembongan — המעבורות קצרות ועוזבות כל כמה שעות. אם אתם מתכננים יום-טיול לאיים, סאנור הוא נקודת המוצא הנוחה ביותר.',
    bestFor: 'משפחות, family-friendly, זריחות, שקט, נקודת מוצא לנוסה פנידה',
    tips: 'הגיעו ב-6:00–7:00 לזריחה — מרהיב ושקט. המעבורת לנוסה פנידה יוצאת מהנמל בסאנור — הזמינו ביום שלפני. Promenade (שביל הטיילות) מצוין לריצת בוקר.',
    freeEntry: true,
    howToGetThere: 'מ-Kuta: 30–40 דקות מזרחה ברכב. Grab: 60,000–80,000 רופיה. מ-Ubud: 40–50 דקות דרומה.',
  },
]

const faqs = [
  {
    q: 'מה החוף הכי מתאים למשפחות עם ילדים?',
    a: 'נוסה דואה וסאנור הם המתאימים ביותר — מים שקטים, ריף מגן, ורמת ניקיון גבוהה. קוטה גם בסדר אבל הגלים יותר חזקים. הימנעו מ-Uluwatu וקאנגו עם ילדים קטנים.'
  },
  {
    q: 'מה החוף הכי טוב לגלישה?',
    a: 'למתחילים: קוטה (גלים קלים + ספרים). לגולשים בינוניים: קאנגו/בראווה. למנוסים: אולוואטו, Bingin, פאדאנג פאדאנג — גלים ריאליים ומאתגרים.'
  },
  {
    q: 'מתי הכי כדאי לבקר בחופי באלי?',
    a: 'עונת הקיץ הבאלינזית (מאי–ספטמבר) היא שיא — ים שקט, שמש, גלים מדהימים. בעונת הגשמים (אוקטובר–מרץ) החופים עדיין יפים אבל לפעמים יש גשמי-קצר בערב. בכל עונה שווה.'
  },
  {
    q: 'האם כניסה לחופים בבאלי עולה כסף?',
    a: 'רוב החופים חינמיים — קוטה, סמינייק, קאנגו, נוסה דואה (Geger Beach), ג\'ימברן, סאנור. פאדאנג פאדאנג גובה 20,000 רופיה. Beach clubs מדרישים מינימום הוצאה אבל לא חובה להיכנס אליהם.'
  },
  {
    q: 'מה הזמן הכי טוב לשקיעה בבאלי?',
    a: 'השקיעות הכי מפורסמות: קוטה וסמינייק (ים + שמיים), ג\'ימברן (עם פירות ים), אולוואטו (דרמטי על הצוקים). כולן בין 17:30–18:30 בהתאם לחודש.'
  },
]

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali', url: 'https://ibalibali.com' },
  mainEntityOfPage: 'https://ibalibali.com/beaches',
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-03-29',
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
}
---

<Layout {title} {description} canonical="https://ibalibali.com/beaches">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal-900/30 via-[#0A1A18]/80 to-[#0A1A18]"></div>
    <div style="background-image: url('https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=1920&q=70&fit=crop'); background-size: cover; background-position: center;" class="absolute inset-0 opacity-20"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <nav class="text-sm text-white/40 mb-6">
        <a href="/" class="hover:text-teal-400 transition-colors">דף הבית</a>
        <span class="mx-2">/</span>
        <span class="text-white/60">חופים</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-black text-white mb-6">חופים <span class="text-teal-400">בבאלי</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">
        מקוטה התוסס ועד אולוואטו הדרמטי — 7 החופים הכי שווים בבאלי. גלים לגלישה, שקיעות שאי אפשר לשכוח, ומים בצבע שלא ראיתם בשום מקום אחר.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm text-white/50">
        <span>🏄 7 חופים</span>
        <span>·</span>
        <span>🆓 6 חינמיים</span>
        <span>·</span>
        <span>🌊 אוקיינוס הודי</span>
        <span>·</span>
        <span>🌅 שקיעות אגדיות</span>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="max-w-6xl mx-auto px-4 -mt-6 relative z-20 mb-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {[
        { emoji: '🏄', title: 'גלישה', sub: 'מהטובה בעולם' },
        { emoji: '🌡️', title: 'מים חמים', sub: '26–29°C כל השנה' },
        { emoji: '🌅', title: 'שקיעות', sub: 'קוטה, סמינייק, אולוואטו' },
        { emoji: '🐠', title: 'ריפים', sub: 'נוסה דואה וסאנור' },
      ].map(s => (
        <div class="bg-[#0F2420] border border-teal-500/15 rounded-2xl p-4 text-center">
          <span class="text-2xl block mb-1">{s.emoji}</span>
          <p class="text-white font-bold text-sm">{s.title}</p>
          <p class="text-white/40 text-xs">{s.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Beaches -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-10 text-center">
      7 החופים <span class="text-teal-400">הכי שווים</span>
    </h2>

    <div class="space-y-10">
      {beaches.map((beach, i) => (
        <article class="bg-[#0F2420] border border-teal-500/10 rounded-3xl overflow-hidden hover:border-teal-500/25 transition-all">
          <!-- Image -->
          <div class="aspect-[21/8] md:aspect-[21/6] overflow-hidden">
            <img
              src={beach.image}
              alt={beach.name_he + ' — חוף בבאלי'}
              loading="lazy"
              decoding="async"
              width="1200"
              height="400"
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
            />
          </div>

          <div class="p-6 md:p-8">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
              <div>
                <div class="flex items-center gap-3 mb-2 flex-wrap">
                  <span class="bg-teal-500 text-black font-black text-xs px-2.5 py-1 rounded-full">#{i + 1}</span>
                  <h3 class="text-2xl font-black text-white">{beach.name_he}</h3>
                </div>
                <p class="text-teal-400/80 text-sm font-medium">{beach.name}</p>
                <p class="text-white/40 text-sm mt-1">📍 {beach.area}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class={`text-xs font-semibold px-3 py-1.5 rounded-full border ${beach.freeEntry ? 'bg-green-500/15 text-green-400 border-green-500/20' : 'bg-teal-500/15 text-teal-400 border-teal-500/20'}`}>
                  {beach.freeEntry ? '🆓 כניסה חינם' : '🎟️ כניסה קטנה'}
                </span>
              </div>
            </div>

            <!-- Description -->
            <div class="text-white/70 leading-relaxed mb-6 space-y-3">
              {beach.description.split('\n\n').map(para => (
                <p>{para}</p>
              ))}
            </div>

            <!-- Grid Info -->
            <div class="grid sm:grid-cols-2 gap-4 mb-5">
              <!-- Best For -->
              <div class="bg-white/3 rounded-xl p-4">
                <p class="text-teal-400 font-bold text-xs uppercase tracking-wide mb-2">מתאים ל</p>
                <p class="text-white/70 text-sm">{beach.bestFor}</p>
              </div>
              <!-- How to get there -->
              <div class="bg-white/3 rounded-xl p-4">
                <p class="text-teal-400 font-bold text-xs uppercase tracking-wide mb-2">🛵 הגעה</p>
                <p class="text-white/70 text-sm">{beach.howToGetThere}</p>
              </div>
            </div>

            <!-- Tip -->
            <div class="bg-teal-500/8 border border-teal-500/15 rounded-xl p-4">
              <p class="text-teal-400 font-bold text-sm mb-1">💡 הטיפ שלנו</p>
              <p class="text-white/65 text-sm leading-relaxed">{beach.tips}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- General Tips -->
  <section class="max-w-5xl mx-auto px-4 py-14 border-t border-white/5">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-10 text-center">
      כל מה שצריך לדעת <span class="text-teal-400">לפני</span> שהולכים
    </h2>
    <div class="grid md:grid-cols-2 gap-5">
      {[
        {
          title: '👙 כללי לבוש',
          text: 'בגד ים רגיל מותר בכל חופי באלי. כשעוזבים את שטח החוף לכיוון מקדש או כפר — חובה להתלבש. בגדי שכם חשופות ליד מקדש — לא מכובד. סרונג (בד כריכה) עולה כמה שקלים ויש בכל מקום.'
        },
        {
          title: '⚠️ בטיחות ים',
          text: 'הגלים בקוטה, קאנגו ואולוואטו חזקים — הזהרו מזרמים. שחו רק בחלקים מסומנים. בנוסה דואה וסאנור המים שקטים ובטוחים. מצילים פעילים בחופים הגדולים בשעות הבוקר-אחה"צ.'
        },
        {
          title: '🕐 זמנים מומלצים',
          text: 'בוקר מוקדם (6:00–9:00): שקט ויפהפה, מעט אנשים. שקיעה (17:00–18:30): אירוע חברתי בפני עצמו. הימנעו מ-11:00–15:00 בקיץ — שמש עזה במיוחד.'
        },
        {
          title: '🎒 מה לקחת',
          text: 'קרם הגנה SPF50+ (הים הטרופי לא מסלח), מים, כובע, סנדלים (חול שחור יכול להיות חם מאוד), ומגבת. לחופי סלע כמו Uluwatu — נעלי מים.'
        },
        {
          title: '🛵 הגעה לחופים',
          text: 'Grab (האובר המקומי) הכי נוח ובטוח. השכרת אופנוע (50,000–80,000 רופיה ליום) מאפשרת גמישות. מרכז Kuta/Seminyak — אפשר להגיע רגלי לחוף. אין תחבורה ציבורית נוחה לרוב החופים.'
        },
        {
          title: '🌡️ טמפרטורת הים',
          text: 'כל השנה: 26–29°C — מושלם. עונת הגשמים (נוב–מרץ): הגלים עשויים להיות גדולים יותר. עונת הקיץ (מאי–ספטמבר): שמיים נקיים, ים שקט, בוקר מושלם.'
        },
      ].map(tip => (
        <div class="bg-[#0F2420] border border-teal-500/10 rounded-2xl p-5">
          <h3 class="text-white font-bold text-base mb-2">{tip.title}</h3>
          <p class="text-white/60 text-sm leading-relaxed">{tip.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 py-10 border-t border-white/5">
    <h2 class="text-3xl font-black text-white mb-8 text-center">שאלות נפוצות על <span class="text-teal-400">חופי באלי</span></h2>
    <div class="space-y-4">
      {faqs.map(faq => (
        <details class="group bg-[#0F2420] border border-teal-500/10 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer text-white font-bold hover:text-teal-400 transition-colors list-none">
            <span>{faq.q}</span>
            <span class="text-teal-500 text-xl transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="px-5 pb-5 text-white/60 text-sm leading-relaxed border-t border-white/5 pt-4">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        חוף גם — ועוד הרבה <span class="text-teal-400">יותר?</span>
      </h2>
      <p class="text-white/60 text-lg mb-8 max-w-xl mx-auto">באלי היא הרבה יותר מחופים — מקדשים, אורז-טראסות, Ubud ועוד 🌿</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/attractions" class="bg-teal-500 hover:bg-teal-400 text-black px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-teal-500/25">
          כל האטרקציות בבאלי
        </a>
        <a href="/plan" class="bg-white/5 hover:bg-white/10 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all border border-white/10">
          תכנון טיול לבאלי
        </a>
      </div>
    </div>
  </section>
</Layout>
