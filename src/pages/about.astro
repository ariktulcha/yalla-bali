---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const services = [
  { icon: '📖', title: 'מדריכים מפורטים', description: 'מאות עמודים של תוכן מקורי בעברית: אטרקציות, מסעדות, מלונות, אזורים, חופים, שווקים ועוד. כל מדריך נכתב מניסיון אישי ומתעדכן באופן שוטף.' },
  { icon: '🧭', title: 'אטרקציות וטיולים', description: 'מידע מפורט על האטרקציות, הטיולים והפעילויות הטובות ביותר בבאלי — מטרק לפסגת הר הבאטור ועד טיולי יום לנוסה פניידה. כל ההמלצות בעברית.' },
  { icon: '📍', title: 'תכנון טיול', description: 'כלי תכנון טיול חכם שבונה לכם מסלול מותאם אישית לפי מספר ימים, סגנון טיול ותחומי עניין. כולל המלצות למסעדות, אטרקציות וזמני ביקור אופטימליים.' },
  { icon: '✉️', title: 'מענה במייל', description: 'שאלה? התלבטות? צריכים המלצה? שלחו לנו מייל ונחזור אליכם עם מידע, המלצות וטיפים — לפני, במהלך ואחרי הטיול.' },
]

const values = [
  { icon: '❤️', title: 'תשוקה לבאלי', description: 'אנחנו מכירים כל פינה בבאלי ואוהבים לשתף את הידע. כל המלצה מבוססת על ביקור אישי.' },
  { icon: '🛡️', title: 'אמינות ושקיפות', description: 'מחירים שקופים, ביקורות כנות, ואין תוכן ממומן סמוי. מה שאנחנו ממליצים — אנחנו באמת אוהבים.' },
  { icon: '👥', title: 'קהילה ישראלית', description: 'הכל בעברית, מותאם לתייר הישראלי. כשרות, שבת, מחירים בשקלים — אנחנו מבינים את הצרכים שלכם.' },
  { icon: '⭐', title: 'מצוינות', description: 'אנחנו שואפים להיות המדריך הכי טוב ומקיף לבאלי בעברית. תוכן מעודכן, מדויק ושימושי.' },
]

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'אודות יאללה באלי',
  description: 'יאללה באלי - המדריך המלא לבאלי בעברית.',
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali', url: 'https://ibalibali.com' },
  mainEntityOfPage: 'https://ibalibali.com/about',
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-03-01',
}
---

<Layout
  title="אודות יאללה באלי"
  description="יאללה באלי - המדריך המלא לבאלי בעברית. מי אנחנו, מה המשימה שלנו, ואיך אנחנו עוזרים לתיירים ישראלים לתכנן את הטיול המושלם לבאלי."
  canonical="https://ibalibali.com/about"
>
  <SchemaOrg schema={articleSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">אודות <span class="text-teal-400">יאללה באלי</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">המדריך המלא לבאלי בעברית. עוזרים לתיירים ישראלים לתכנן ולחוות את הטיול המושלם בבאלי.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl md:text-3xl font-bold text-teal-400 mb-6">הסיפור שלנו</h2>
      <div class="space-y-4 text-white/70 leading-relaxed">
        <p>
          יאללה באלי נולד ב-2024 מתוך אהבה עמוקה לבאלי וההבנה שחסר משהו מהותי: מדריך איכותי, מקיף ומעודכן בעברית.
          בשנים האחרונות, עשרות אלפי ישראלים טסים לבאלי כל שנה — המטיול הנפוץ ביותר מישראל לאסיה. אבל המידע בעברית היה פזור,
          לא מעודכן, מלא בשגיאות, ולא התאים לצרכים הייחודיים של הטיירים הישראלים (כשרות, שבת, תחבורה, בטיחות).
        </p>
        <p>
          החלטנו לשנות את זה. הקמנו את <strong class="text-white">המדריך הכי מקיף לבאלי בעברית</strong> — עם 130+ אטרקציות מפורטות,
          50+ מדריכים בנושאים שונים, וחוות דעות אמיתיות בעברית. כל תוכן, כל המלצה, כל טיפ — מבוסס על ביקור אישי ניסיון ישיר.
          אנחנו לא עותקים מויקיפדיה או טריפ אדווייזר — אנחנו כותבים מנסיון חי.
        </p>
        <p>
          בנוסף למדריכים, אנחנו מספקים <strong class="text-white">מידע מפורט על טיולים ואטרקציות בבאלי</strong> — מהטיולים הכי מבוקשים בהרים, טבע ותרבות
          ועד המלצות מקומיות אותנטיות. כל המידע בעברית, מעודכן ומדויק, ונכתב על ידי אנשים שמכירים את באלי כמו כיסם שלהם.
        </p>
        <p>
          המטרה שלנו <strong class="text-white">פשוטה וברורה</strong>: שכל ישראלי שמגיע לבאלי ייהנה מטיול מושלם — עם כל המידע שצריך,
          בשפה שלו, בעברית. ממש לפני הטיסה (ויזה, הכנה), במהלך הטיול (המלצות, טיולים, בעיות), ואפילו אחרי (זכרונות, חוות דעות).
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">130+</div>
        <div class="text-white/60 text-sm">אטרקציות מפורטות בבאלי</div>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">8</div>
        <div class="text-white/60 text-sm">אזורים בבאלי (מפות, טיפים)</div>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">50+</div>
        <div class="text-white/60 text-sm">מדריכים ומאמרים בעברית</div>
      </div>
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-xl p-6">
        <div class="text-4xl md:text-5xl font-black text-teal-400 mb-2 flex items-center justify-center gap-1">4.9 <svg class="w-6 h-6 fill-teal-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
        <div class="text-white/60 text-sm">דירוג מתיירים ישראלים</div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">מה אנחנו <span class="text-teal-400">מציעים</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">כל מה שצריך לטיול מושלם בבאלי — במקום אחד, בעברית</p>
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((s) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6 hover:border-teal-500/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-teal-500/10 border border-teal-500/20 rounded-xl flex items-center justify-center text-2xl">{s.icon}</div>
            <h3 class="text-xl font-bold text-white">{s.title}</h3>
          </div>
          <p class="text-white/60 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">הערכים <span class="text-teal-400">שלנו</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">הערכים שמנחים אותנו בכל דבר שאנחנו עושים</p>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
      {values.map((v) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-5 text-center hover:border-teal-500/30 transition-all">
          <span class="text-3xl block mb-3">{v.icon}</span>
          <h3 class="text-white font-bold mb-2">{v.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">צרו <span class="text-teal-400">קשר</span></h2>
    <div class="grid md:grid-cols-1 gap-6 max-w-md mx-auto">
      <a href="mailto:info@ibalibali.com" class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 hover:border-teal-500/40 rounded-2xl p-6 text-center transition-all group">
        <span class="text-4xl block mb-3 group-hover:scale-110 transition-transform">@</span>
        <h3 class="text-xl font-bold text-white mb-2">אימייל</h3>
        <p class="text-white/60 text-sm mb-3">לשאלות מפורטות, שיתופי פעולה ופניות עסקיות.</p>
        <span class="text-teal-400 font-bold" dir="ltr">info@ibalibali.com</span>
      </a>
    </div>
  </section>

  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-6">מוכנים <span class="text-teal-400">להתחיל?</span></h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto">גלו את כל מה שבאלי יכולה להציע — מדריכים, אטרקציות, וטיולים מודרכים</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/plan" class="bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-400 hover:to-teal-500 text-[#0D0D0D] px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-teal-500/25">תכננו את הטיול</a>
        <a href="/attractions" class="bg-gradient-to-r from-[#0D9488] to-[#D97706] text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-[#0D9488]/25">גלו אטרקציות</a>
      </div>
    </div>
  </section>
</Layout>
