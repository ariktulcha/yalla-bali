---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'

const services = [
  { icon: '📖', title: 'מדריכים מפורטים', description: 'מאות עמודים של תוכן מקורי בעברית: אטרקציות, מסעדות, מלונות, אזורים, חופים, שווקים ועוד. כל מדריך נכתב מניסיון אישי ומתעדכן באופן שוטף.' },
  { icon: '🧭', title: 'ספארי במדבר', description: 'אנחנו מארגנים ספארי במדבר באלי — מהחוויות הכי מבוקשות. ספארי ערב, בוקר, ו-VIP פרטי. הזמנה קלה בווטסאפ, מחירים שקופים, ושירות בעברית.' },
  { icon: '📍', title: 'תכנון טיול', description: 'כלי תכנון טיול חכם שבונה לכם מסלול מותאם אישית לפי מספר ימים, סגנון טיול ותחומי עניין. כולל המלצות למסעדות, אטרקציות וזמני ביקור אופטימליים.' },
  { icon: '📱', title: 'שירות אישי בווטסאפ', description: 'שאלה? בעיה? צריכים המלצה? שלחו לנו הודעה בווטסאפ ונחזור אליכם תוך דקות. אנחנו זמינים לכל שאלה — לפני, במהלך ואחרי הטיול.' },
]

const values = [
  { icon: '❤️', title: 'תשוקה לבאלי', description: 'אנחנו מכירים כל פינה בבאלי ואוהבים לשתף את הידע. כל המלצה מבוססת על ביקור אישי.' },
  { icon: '🛡️', title: 'אמינות ושקיפות', description: 'מחירים שקופים, ביקורות כנות, ואין תוכן ממומן סמוי. מה שאנחנו ממליצים — אנחנו באמת אוהבים.' },
  { icon: '👥', title: 'קהילה ישראלית', description: 'הכל בעברית, מותאם לתייר הישראלי. כשרות, שבת, מחירים בשקלים — אנחנו מבינים את הצרכים שלכם.' },
  { icon: '⭐', title: 'מצוינות', description: 'אנחנו שואפים להיות המדריך הכי טוב ומקיף לבאלי בעברית. תוכן מעודכן, מדויק ושימושי.' },
]

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'אודות יאללה באלי',
  description: 'יאללה באלי - המדריך המלא לבאלי בעברית.',
  author: { '@type': 'Organization', name: 'Yalla Bali' },
  publisher: { '@type': 'Organization', name: 'Yalla Bali', url: 'https://yalla-bali.co.il' },
  mainEntityOfPage: 'https://yalla-bali.co.il/about',
  inLanguage: 'he',
  datePublished: '2025-01-01',
  dateModified: '2026-03-01',
}
---

<Layout
  title="אודות יאללה באלי"
  description="יאללה באלי - המדריך המלא לבאלי בעברית. מי אנחנו, מה המשימה שלנו, ואיך אנחנו עוזרים לתיירים ישראלים לתכנן את הטיול המושלם לבאלי."
  canonical="https://yalla-bali.co.il/about"
>
  <SchemaOrg schema={articleSchema} />

  <section class="relative py-20 md:py-28 bg-gradient-to-b from-[#1A1208] to-[#0D0D0D]">
    <div class="absolute inset-0 opacity-10"><div class="absolute inset-0 bg-gradient-to-br from-teal-900/20 to-transparent"></div></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6">אודות <span class="text-teal-400">יאללה באלי</span></h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed">המדריך המלא לבאלי בעברית. עוזרים לתיירים ישראלים לתכנן ולחוות את הטיול המושלם בבאלי.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl md:text-3xl font-bold text-teal-400 mb-6">הסיפור שלנו</h2>
      <div class="space-y-4 text-white/70 leading-relaxed">
        <p>יאללה באלי נולד מתוך אהבה לבאלי וההבנה שחסר מדריך איכותי ומקיף בעברית. מאז הסכמי אברהם ב-2020, עשרות אלפי ישראלים טסים לבאלי כל שנה — אבל המידע בעברית היה פזור, לא מעודכן, ולפעמים לא מדויק.</p>
        <p>החלטנו לשנות את זה. הקמנו את המדריך הכי מקיף לבאלי בעברית, עם מאות עמודים של תוכן מקורי, מעודכן ואמין. כל מדריך, כל המלצה, כל טיפ — מבוסס על ביקור אישי וניסיון ישיר.</p>
        <p>בנוסף למדריכים, אנחנו מארגנים ספארי במדבר — אחת החוויות הכי מבוקשות בבאלי. הזמנה קלה, שירות בעברית, ומחירים הוגנים.</p>
        <p>המטרה שלנו פשוטה: <strong class="text-white">שכל ישראלי שמגיע לבאלי ייהנה מטיול מושלם</strong> — עם כל המידע שצריך, בשפה שלו, ועם תמיכה אישית בכל שלב.</p>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div><div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">130+</div><div class="text-white/60 text-sm">אטרקציות מפורטות</div></div>
      <div><div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">8</div><div class="text-white/60 text-sm">אזורים בבאלי</div></div>
      <div><div class="text-4xl md:text-5xl font-black text-teal-400 mb-2">50+</div><div class="text-white/60 text-sm">מדריכים ומאמרים</div></div>
      <div><div class="text-4xl md:text-5xl font-black text-teal-400 mb-2 flex items-center justify-center gap-1">4.9 <svg class="w-6 h-6 fill-teal-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div><div class="text-white/60 text-sm">דירוג מתיירים</div></div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-4 text-center">מה אנחנו <span class="text-teal-400">מציעים</span></h2>
    <p class="text-white/60 text-center mb-10 max-w-2xl mx-auto">כל מה שצריך לטיול מושלם בבאלי — במקום אחד, בעברית</p>
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((s) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-6 hover:border-teal-500/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-teal-500/10 border border-teal-500/20 rounded-xl flex items-center justify-center text-2xl">{s.icon}</div>
            <h3 class="text-xl font-bold text-white">{s.title}</h3>
          </div>
          <p class="text-white/60 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-10 text-center">הערכים <span class="text-teal-400">שלנו</span></h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
      {values.map((v) => (
        <div class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/10 rounded-2xl p-5 text-center">
          <span class="text-3xl block mb-3">{v.icon}</span>
          <h3 class="text-white font-bold mb-2">{v.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-3xl md:text-4xl font-black text-white mb-8 text-center">צרו <span class="text-teal-400">קשר</span></h2>
    <div class="grid md:grid-cols-2 gap-6">
      <a href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתעניין בטיול לבאלי')}`} target="_blank" rel="noopener noreferrer" class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-green-500/20 hover:border-green-500/40 rounded-2xl p-6 text-center transition-all group">
        <span class="text-4xl block mb-3 group-hover:scale-110 transition-transform">📱</span>
        <h3 class="text-xl font-bold text-white mb-2">וואטסאפ</h3>
        <p class="text-white/60 text-sm mb-3">הדרך הכי מהירה לתשובות. זמינים כל יום.</p>
        <span class="text-green-400 font-bold">שלחו הודעה</span>
      </a>
      <a href="mailto:info@yalla-bali.co.il" class="bg-gradient-to-br from-[#1A1208] to-[#0D0D0D] border border-teal-500/20 hover:border-teal-500/40 rounded-2xl p-6 text-center transition-all group">
        <span class="text-4xl block mb-3 group-hover:scale-110 transition-transform">@</span>
        <h3 class="text-xl font-bold text-white mb-2">אימייל</h3>
        <p class="text-white/60 text-sm mb-3">לשאלות מפורטות, שיתופי פעולה ופניות עסקיות.</p>
        <span class="text-teal-400 font-bold" dir="ltr">info@yalla-bali.co.il</span>
      </a>
    </div>
  </section>

  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-6">מוכנים <span class="text-teal-400">להתחיל?</span></h2>
      <p class="text-white/70 text-lg mb-8 max-w-xl mx-auto">גלו את כל מה שבאלי יכולה להציע — מדריכים, אטרקציות, וספארי במדבר</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/plan" class="bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-400 hover:to-teal-500 text-[#0D0D0D] px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-teal-500/25">תכננו את הטיול</a>
        <a href="/desert-safari" class="bg-gradient-to-r from-[#0D9488] to-[#D97706] text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-[#0D9488]/25">ספארי במדבר</a>
      </div>
    </div>
  </section>
</Layout>
