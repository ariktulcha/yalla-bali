---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import MapEmbed from '../../components/MapEmbed.astro'
import StreetViewEmbed from '../../components/StreetViewEmbed.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: areas } = await supabaseAdmin
    .from('areas')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (areas ?? []).map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }))
}

const { area } = Astro.props

const highlights = area.highlights ?? area.metadata?.highlights ?? []
const nearbyAttractions = area.metadata?.nearby_attractions ?? []

const contentHtml = area.full_content ? await marked(area.full_content) : ''

const pageTitle = `${area.name_he}${area.name_en ? ` — ${area.name_en}` : ''} | אזורים בבאלי | Yalla Bali`
const pageDescription = area.excerpt || area.description || `${area.name_he} — אזור בבאלי`

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: area.name_he,
  alternateName: area.name_en || undefined,
  description: area.description || area.excerpt,
  image: area.image || undefined,
  url: new URL(`/areas/${area.slug}`, Astro.site).toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Bali',
    addressCountry: 'ID',
  },
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורים', href: '/areas' },
  { label: area.name_he },
]

const faqItems = [
  {
    q: `מה האטרקציות הכי שוות ב${area.name_he}?`,
    a: `${area.name_he} היא עמוקה בטבע ותרבות. אתם יוכלו למצוא מנזרים עתיקים, טבע יפה, וחיים מקומיים אמיתיים. צרו איתנו קשר בווטסאפ ואנחנו נוכל להמליץ על אטרקציות ספציפיות בהתאם לעניינים שלכם.`,
  },
  {
    q: `מה הזמן הטוב לבקר ב${area.name_he}?`,
    a: `הזמן הטוב ביותר הוא בעונה היבשה (מאי עד ספטמבר). בתקופה זו הזמן יותר טוב ויש פחות גשם. אם אתם חובבי ים, אז יוני עד אוגוסט הוא אידיאלי.`,
  },
  {
    q: `כמה זמן כדאי לבלות ב${area.name_he}?`,
    a: `זה תלוי בקצב שלכם. אם אתם רוצים להשקיע זמן, 2-3 ימים בסביבה זו יתנו לכם חוויה עשירה ואמיתית. יום אחד מספיק לסיור מהיר, אך אפשר להנות בהרבה יותר זמן.`,
  },
  {
    q: `כיצד מגיעים ל${area.name_he}?`,
    a: `ניתן להגיע דרך Grab או מונית מקומית (בערך 30-60 דקות מנמל התעופה בהתאם לאזור). אנחנו ממליצים לסדר רכב עם נהג כדי שתוכלו להתמקד בנוף ובחוויה. אם אתם רוצים סיור מפונקח, צרו איתנו קשר בווטסאפ.`,
  },
]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://yalla-bali.co.il/areas/${area.slug}`}
  ogImage={area.image}
  ogType="article"
  schema={placeSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    {area.image && (
      <div class="aspect-[16/9] overflow-hidden rounded-2xl mb-8">
        <img
          src={area.image}
          alt={area.name_he}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <MapEmbed areaName={area.name_he} areaNameEn={area.name_en} zoom={13} height="450px" />

    <StreetViewEmbed areaName={area.name_he} areaNameEn={area.name_en} />

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{area.name_he}</h1>
      {area.name_en && (
        <p class="text-lg text-white/50">{area.name_en}</p>
      )}
    </header>

    {area.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <p class="text-white/80 leading-relaxed">{area.description}</p>
      </div>
    )}

    {highlights.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">נקודות עניין ב{area.name_he}</h2>
        <ul class="space-y-2">
          {highlights.map((item: string) => (
            <li class="flex items-start gap-2 text-white/70">
              <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0 mt-2"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    )}

    {nearbyAttractions.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">אטרקציות באזור {area.name_he}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {nearbyAttractions.map((attraction: string) => (
            <span class="inline-flex items-center gap-2 text-white/70 text-sm">
              <svg class="w-4 h-4 text-teal-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {attraction}
            </span>
          ))}
        </div>
      </div>
    )}

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="mb-8">
      <FAQSection items={faqItems} />
    </div>

    <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים לדעת עוד על {area.name_he} ואזורים נוספים בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתכנן טיול לבאלי ורוצה לשמוע על אזורים מומלצים 🌴')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        דברו איתנו בווטסאפ
      </a>
    </div>
  </div>
</Layout>
