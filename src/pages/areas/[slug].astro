---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { pickMetaDescription } from '../../lib/seo'
import { site, pageTitle as buildPageTitle } from '../../config/site'
import Layout from '../../components/Layout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import MapEmbed from '../../components/MapEmbed.astro'
import StreetViewEmbed from '../../components/StreetViewEmbed.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: areas } = await supabaseAdmin
    .from('areas')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (areas ?? []).map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }))
}

const { area } = Astro.props

const highlights = area.highlights ?? area.metadata?.highlights ?? []
const nearbyAttractions = area.metadata?.nearby_attractions ?? []
const bestFor = Array.isArray(area.best_for) ? area.best_for : []

const contentHtml = area.full_content ? await marked(area.full_content) : ''

const titlePrefix = `${area.name_he}${area.name_en ? ` — ${area.name_en}` : ''}`
const pageTitle = area.meta_title || buildPageTitle(titlePrefix, 'area')
const pageDescription = area.meta_description || pickMetaDescription(area, `אזור ב${site.destinationName}`)

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: area.name_he,
  alternateName: area.name_en || undefined,
  description: area.description || area.excerpt,
  image: area.image || undefined,
  url: new URL(`/areas/${area.slug}`, Astro.site).toString(),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Bali',
    addressCountry: 'ID',
  },
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורים', href: '/areas' },
  { label: area.name_he },
]

const dbFaq = Array.isArray(area.faq) ? area.faq : []
const faqItems = dbFaq.length > 0
  ? dbFaq.map((item: any) => ({ q: item.q, a: item.a }))
  : [
      {
        q: `מה האטרקציות הכי שוות ב${area.name_he} בבאלי?`,
        a: `${area.name_he} בבאלי היא עמוסה בטבע ותרבות. תוכלו למצוא מקדשים עתיקים, נופי טבע מרהיבים וחיים מקומיים אמיתיים. עיינו בדף האטרקציות באתר כדי לראות את כל ההמלצות לאזור ${area.name_he}.`,
      },
      {
        q: `מה הזמן הטוב ביותר לבקר ב${area.name_he} בבאלי?`,
        a: `הזמן הטוב ביותר לבקר ב${area.name_he} הוא בעונה היבשה של באלי (מאי עד ספטמבר). בתקופה זו האקלים נעים יותר ויש פחות גשם. אם אתם חובבי ים, אז יוני עד אוגוסט הוא אידיאלי לחופי באלי.`,
      },
      {
        q: `כמה זמן כדאי לבלות ב${area.name_he}?`,
        a: `זה תלוי בקצב שלכם בבאלי. אם אתם רוצים להעמיק, 2-3 ימים ב${area.name_he} יתנו לכם חוויה עשירה ואמיתית. יום אחד מספיק לסיור מהיר, אך אפשר להנות בהרבה יותר זמן באזור.`,
      },
      {
        q: `כיצד מגיעים ל${area.name_he} בבאלי?`,
        a: `ניתן להגיע ל${area.name_he} דרך Grab או מונית מקומית (בערך 30-60 דקות מנמל התעופה הבינלאומי של באלי בהתאם לאזור). מומלץ לסדר רכב עם נהג כדי שתוכלו להתמקד בנוף ובחוויה.`,
      },
    ]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://ibalibali.com/areas/${area.slug}`}
  ogImage={area.image}
  ogType="article"
  schema={placeSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    {area.image && (
      <div class="aspect-[16/9] overflow-hidden rounded-2xl mb-8">
        <img
          src={area.image}
          alt={area.name_he}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <MapEmbed areaName={area.name_he} areaNameEn={area.name_en} zoom={13} height="350px" />

    <StreetViewEmbed areaName={area.name_he} areaNameEn={area.name_en} />

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{area.name_he}</h1>
      {area.name_en && (
        <p class="text-lg text-white/50">{area.name_en}</p>
      )}
    </header>

    {area.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">על {area.name_he} בבאלי</h2>
        <p class="text-white/80 leading-relaxed">{area.description}</p>
      </div>
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">כיצד מגיעים ל{area.name_he}? 🚕</h2>
      <p class="text-white/80 leading-relaxed">
        ניתן להגיע ל{area.name_he} מנמל התעופה הבינלאומי של באלי (Ngurah Rai - DPS) באמצעות Grab, Gojek או רכב פרטי עם נהג. זמן הנסיעה משתנה לפי האזור, אך בדרך כלל נע בין 30 ל-90 דקות.
      </p>
    </div>

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">למי מתאים {area.name_he}?</h2>
      {area.vibe && (
        <p class="text-white/80 leading-relaxed mb-4">
          <span class="text-teal-300 font-bold">אווירה:</span> {area.vibe}
        </p>
      )}
      {bestFor.length > 0 ? (
        <div>
          <p class="text-white/80 mb-3">{area.name_he} מתאימה במיוחד ל:</p>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {bestFor.map((target: string) => (
              <li class="flex items-start gap-2 text-white/70 text-sm">
                <svg class="w-4 h-4 text-teal-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {target}
              </li>
            ))}
          </ul>
        </div>
      ) : (
        <p class="text-white/80 leading-relaxed">
          {area.name_he} בבאלי הוא יעד מצוין לתיירים שמחפשים שילוב של נופים, תרבות וחוויות אותנטיות. האזור מתאים לזוגות, משפחות ותיירים עצמאיים כאחד.
        </p>
      )}
    </div>

    {highlights.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">נקודות עניין ב{area.name_he}</h2>
        <ul class="space-y-2">
          {highlights.map((item: string) => (
            <li class="flex items-start gap-2 text-white/70">
              <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0 mt-2"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    )}

    {nearbyAttractions.length > 0 && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">אטרקציות באזור {area.name_he}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {nearbyAttractions.map((attraction: string) => (
            <span class="inline-flex items-center gap-2 text-white/70 text-sm">
              <svg class="w-4 h-4 text-teal-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {attraction}
            </span>
          ))}
        </div>
      </div>
    )}

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="mb-8">
      <FAQSection items={faqItems} entityName={area.name_he} />
    </div>

    <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים לדעת עוד על אזורים נוספים בבאלי?</p>
      <a
        href="/areas"
        class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-[#0D0D0D] font-bold px-6 py-3 rounded-full transition-colors"
      >
        🌴 לכל האזורים בבאלי
      </a>
    </div>
  </div>
</Layout>
