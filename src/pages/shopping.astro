    body: 'חנויות שצועקות "מחיר מקומי!" או "הכי זול בבאלי!" בדרך כלל יקרות יותר משווקים רגילים. המחיר האמיתי מגיע ממיקוח שקט, לא מצעקות. הפשוט מכלל: אם צריך לשכנע אתכם שזה זול — זה לא זול.',
  },
  {
    icon: '💳',
    title: 'עמלות כרטיס אשראי',
    body: 'חלק מהחנויות מוסיפות "credit card fee" של 3-5% ללא הודעה. שאלו מראש לפני שאתם מוציאים כרטיס. במקומות רבים עדיף להוציא מזומן מכספומט (עמלה קבועה של 25,000-50,000 IDR) מאשר לשלם בכרטיס עם עמלה.',
  },
  {
    icon: '🚚',
    title: 'משלוח "זול" שלא מגיע',
    body: 'מוכרי רהיטים מציעים משלוח לישראל במחיר אטרקטיבי, ואז מעלים את המחיר אחרי התשלום או שהמשלוח לא מגיע. בקשו הצעת מחיר בכתב כולל מע"מ ועמלות מכס, שלמו רק על DHL/FedEx מזוהה, ושמרו קבלות.',
  },
]

const faqs = [
  {
    q: 'איפה הכי זול לקנות מזכרות בבאלי?',
    a: 'השוק הזול ביותר בבאלי הוא Sukawati Art Market באזור גיאניאר — כאן קונים סיטונאים שמוכרים אחר כך בשאר השווקים. בואו בבוקר מוקדם (לפני 9:00), התכוננו למקוח אגרסיבי, והביאו מזומן. לרהיטים ועיצוב לבית — Tegallalang Handicraft Center הוא הכתובת.',
  },
  {
    q: 'כמה מזומן צריך לקחת לשווקים בבאלי?',
    a: 'לשווקים מסורתיים מומלץ לקחת 500,000-1,500,000 רופיה (כ-120-350 ש"ח) ליום קניות, במזומן ביד. השווקים לא מקבלים כרטיסי אשראי, וגם אם מקבלים — העמלה גבוהה. כספומטים פזורים בכל בעבאלי עם עמלה של 25,000-50,000 IDR להורדה.',
  },
  {
    q: 'האם אפשר לשלם באשראי בחנויות ובשווקים של באלי?',
    a: 'בקניונים המודרניים (Beachwalk, Discovery, Bali Collection, Seminyak Village) כמעט תמיד אפשר לשלם בכרטיס אשראי, לעיתים עם עמלה של 3%. בשווקים מסורתיים (סוקוואטי, אובוד) הכל במזומן בלבד. בחנויות בוטיק בקאנגו וסמינייק יש גם תשלום דיגיטלי דרך GoPay/OVO.',
  },
  {
    q: 'מה השעה הכי טובה לקניות בשווקי באלי?',
    a: 'הזמן האופטימלי לשווקים מסורתיים בבאלי הוא 08:00-10:00 בבוקר. באלינזים מאמינים ש"penglaris" — העסקה הראשונה של היום — מביאה מזל לשאר היום, ולכן הם גמישים יותר במחיר. בנוסף, החום עדיין סביר וההצבה טרייה. אחר הצהריים (15:00-17:00) זה זמן טוב שני כי מוכרים רוצים לסגור עסקאות לפני הסגירה.',
  },
  {
    q: 'איך מזהים תכשיטי כסף אמיתיים בבאלי?',
    a: 'חפשו חותמת 925 או "Sterling" חרוטה על הפריט — זה תקן בינלאומי לכסף 92.5%. ללא חותמת, זה כמעט בוודאות לא כסף אמיתי בבאלי. המקום הכי בטוח לקנות תכשיטי כסף הוא כפר Celuk שבאזור גיאניאר — כל הכפר הוא צורפים משפחתיים בדור חמישי. בשווקים רגילים: היזהרו מ"כסף" שנמכר בזול מדי.',
  },
  {
    q: 'האם כדאי לשלוח רהיטים מבאלי לישראל?',
    a: 'כדאי אם אתם קונים פריטים גדולים של ראטן, במבוק או עץ טיק — המחיר בבאלי נמוך ב-60-80% מישראל גם אחרי משלוח. ב-Tegallalang Handicraft יש חנויות שמתמחות במשלוחים בינלאומיים. בקשו הצעת מחיר בכתב הכוללת מע"מ, ביטוח ומכס ישראלי (12-17% ממחיר הפריט). חשוב לוודא שהעץ מגיע עם תעודת fumigation כדי לעבור מכס בישראל.',
  },
  {
    q: 'מה מקובל להביא כמתנה מבאלי?',
    a: 'מתנות פופולריות מבאלי: תיקי ראטן (לנשים), תכשיטי כסף מ-Celuk (מתנה אישית), סבונים וסקראבים טבעיים של Sensatia או Utama Spice (מתנה קטנה ואיכותית), קפה Kintamani טחון (לאוהבי קפה), חטיפי Pia Legong (מתנה חביבה במשרד), ופסלי גנש קטנים. לקנייה של מתנות רבות בבת אחת — שוק סוקוואטי הוא הכי משתלם.',
  },
  {
    q: 'איך מתמקחים בבאלי בלי להיות לא מנומסים?',
    a: 'המיקוח בבאלי הוא משחק חברי — חייכו תמיד, השתמשו ב"Selamat pagi" (בוקר טוב), והציעו 30-50% ממחיר הפתיחה. אם המוכר לא זז, התחילו לצאת בנימוס ("terima kasih" — תודה) — ב-90% מהמקרים יקראו לכם חזרה עם מחיר טוב יותר. אל תתמקחו בקול רם או בכעס, ואל תתמקחו בכלל במסעדות, מיני-מרקט, Grab/Gojek או קניונים.',
  },
  {
    q: 'כמה עולה כוס קפה Luwak אמיתי בבאלי?',
    a: 'כוס קפה Luwak אמיתי ואתי בבאלי עולה 50,000-80,000 רופיה (כ-12-19 ש"ח). חבילה של 100 גרם פולים עולה 200,000-400,000 רופיה. אם מציעים לכם Luwak בהרבה פחות מזה — כמעט בוודאות זה מזויף או מעורב. בקרו במטע שמציג את החיות חופשיות, ודרשו תעודה. ל-Luwak אותנטי: Satria Agrowisata ו-Bali Pulina.',
  },
  {
    q: 'האם יש חנויות בלי מיקוח בבאלי לקניות נוחות?',
    a: 'כן, במיוחד לאלה שלא רוצים להתמקח: Seminyak Village (קניון בוטיק), Beachwalk Mall Kuta, Discovery Mall, Mal Bali Galeria, Bali Collection Nusa Dua — כל הקניונים עם מחירי תווית קבועים. גם חנויות בוטיק רבות בקאנגו ובסמינייק (כגון Biasa, Magali Pascal, The Bali Craft) מוכרות במחיר קבוע. היתרון: A/C, איכות מובטחת וחזרות. החיסרון: מחיר גבוה יותר מהשווקים.',
  },
]
---

<Layout title={title} description={description} schema={shoppingSchema}>
  <!-- Hero -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal-900/30 to-transparent pointer-events-none" />
    <div class="mx-auto max-w-7xl px-4 sm:px-6 text-center">
      <p class="text-teal-400 font-semibold tracking-widest uppercase text-sm mb-3">קניות בבאלי · מדריך 2026</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-white mb-4">
        שווקים, בוטיקים, מיקוח <span class="text-teal-400">ומה לקנות בבאלי</span>
      </h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        מהשוק הסיטונאי בסוקוואטי ועד בוטיקי הסרפרים בקאנגו — המדריך המלא לקניות בבאלי כולל מיקוח, הונאות ושאלות נפוצות
      </p>
    </div>
  </section>

  <!-- Quick Area Guide -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-black text-white mb-2">📍 איפה לקנות מה בבאלי?</h2>
    <p class="text-white/60 mb-6">מדריך מהיר לפי אזורים — לכל אזור אופי קניות שונה</p>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {quickAreas.map(area => (
        <a
          href={`/areas/${area.slug}`}
          class="block bg-white/5 border border-white/10 rounded-xl p-4 hover:border-teal-500/40 hover:bg-teal-500/5 transition-colors"
        >
          <div class="text-3xl mb-2">{area.icon}</div>
          <div class="font-bold text-white text-sm mb-1">{area.name}</div>
          <div class="text-white/50 text-xs leading-relaxed">{area.bestFor}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- What to buy -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-black text-white mb-6">🛒 מה כדאי לקנות בבאלי?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {whatToBuy.map(item => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-teal-500/30 transition-colors">
          <div class="text-3xl mb-2">{item.emoji}</div>
          <div class="font-bold text-white text-sm mb-1">{item.item}</div>
          <div class="text-white/50 text-xs leading-relaxed">{item.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Markets & Malls -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <h2 class="text-2xl font-black text-white mb-8">🏪 שווקים ומרכזי קניות בבאלי</h2>
    <div class="space-y-8">
      {markets.map((market, i) => (
        <div class={`flex flex-col md:flex-row gap-6 bg-white/[0.03] border border-white/10 rounded-2xl overflow-hidden hover:border-teal-500/20 transition-colors ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="md:w-2/5 h-56 md:h-auto overflow-hidden">
            <img
              src={market.image}
              alt={market.nameHe}
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
          <div class="flex-1 p-6 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">{market.icon}</span>
              <span class="text-xs font-bold uppercase tracking-wider text-teal-400 bg-teal-500/10 px-2 py-0.5 rounded-full">{market.area_tag}</span>
            </div>
            <h3 class="text-xl font-black text-white mb-1">{market.nameHe}</h3>
            <p class="text-white/40 text-sm mb-3">{market.area} · {market.openHours}</p>
            <p class="text-white/70 text-sm leading-relaxed mb-4">{market.description}</p>
            <div class="flex flex-col gap-1.5">
              <div class="text-xs text-white/50">🎯 <span class="text-white/70">{market.bestFor}</span></div>
              <div class="text-xs text-teal-400">💡 {market.tips}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Bargaining Guide -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <div class="bg-gradient-to-br from-teal-900/20 to-teal-800/5 border border-teal-500/20 rounded-2xl p-8">
      <h2 class="text-2xl font-black text-white mb-2">⚖️ מיקוח בבאלי: המדריך המלא</h2>
      <p class="text-white/60 mb-8">6 הכללים שיחסכו לכם מאות דולרים לאורך הטיול</p>
      <div class="grid md:grid-cols-2 gap-4">
        {bargainingRules.map(rule => (
          <div class="flex gap-4 bg-white/[0.03] border border-white/10 rounded-xl p-5">
            <div class="shrink-0 w-10 h-10 rounded-full bg-teal-500/20 border border-teal-500/40 flex items-center justify-center text-teal-400 font-black">
              {rule.n}
            </div>
            <div>
              <h3 class="font-bold text-white text-base mb-1.5">{rule.title}</h3>
              <p class="text-white/60 text-sm leading-relaxed">{rule.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scam Warnings -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <div class="bg-red-950/20 border border-red-500/20 rounded-2xl p-8">
      <h2 class="text-2xl font-black text-white mb-2">⚠️ הונאות קניות בבאלי: להימנע בכל מחיר</h2>
      <p class="text-white/60 mb-8">6 ההונאות הנפוצות ביותר מול תיירים — ואיך לזהות אותן</p>
      <div class="grid md:grid-cols-2 gap-4">
        {scams.map(scam => (
          <div class="bg-white/[0.03] border border-red-500/10 rounded-xl p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">{scam.icon}</span>
              <h3 class="font-bold text-white text-base">{scam.title}</h3>
            </div>
            <p class="text-white/60 text-sm leading-relaxed" set:html={scam.body.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tips section -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <div class="bg-teal-500/10 border border-teal-500/20 rounded-2xl p-8">
      <h2 class="text-xl font-black text-white mb-6">💡 טיפים לקניות חכמות בבאלי</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm text-white/70 leading-relaxed">
        <div class="space-y-3">
          <p>💵 <strong class="text-white">מזומן שולט בשווקים</strong> — שווקים מסורתיים עובדים עם מזומן בלבד. קחו 500K-1.5M IDR ביום ומזומן קטן (10K, 20K) למיקוח.</p>
          <p>🏧 <strong class="text-white">כספומטים זולים יותר מכרטיס</strong> — משיכה מכספומט: עמלה קבועה 25-50K IDR. כרטיס אשראי בחנויות: עמלה של 3-5% על כל רכישה.</p>
          <p>📱 <strong class="text-white">GoPay ו-OVO לחנויות בוטיק</strong> — בקאנגו ובסמינייק הרבה חנויות מקבלות תשלום דיגיטלי. כדאי להתקין GoPay עם כרטיס זר.</p>
        </div>
        <div class="space-y-3">
          <p>🌡️ <strong class="text-white">בוקר מוקדם לשווקים</strong> — הטמפרטורה סבירה, הסחורה טרייה, והמוכרים גמישים במחיר בגלל "penglaris" (מזל של עסקה ראשונה).</p>
          <p>🧳 <strong class="text-white">שקלו תוספת משקל</strong> — פסלי עץ ורהיטי ראטן כבדים. בדקו מחיר משלוח לישראל מראש ב-Tegallalang לפני שקונים פריטים גדולים.</p>
          <p>🎁 <strong class="text-white">"Oleh-Oleh" — מתנות מבאלי</strong> — Pia Legong וחטיפי Kacang Disco הם מתנות מושלמות למשרד — קטנות, זולות, ואותנטיות.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20">
    <FAQSection items={faqs} entityName="קניות בבאלי" />
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 mb-20 text-center">
    <div class="bg-gradient-to-r from-teal-900/40 to-teal-800/20 border border-teal-500/20 rounded-2xl p-10">
      <h2 class="text-2xl font-black text-white mb-3">צריכים עזרה עם הקניות בבאלי?</h2>
      <p class="text-white/60 mb-6">מסלולים, המלצות חנויות, ויזה והזמנות — צרו קשר ונשמח לעזור</p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-black font-bold px-8 py-3 rounded-xl transition-colors"
      >
        ✉️ צרו קשר
      </a>
    </div>
  </section>
</Layout>
