---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import AttractionCard from '../../../components/Cards/AttractionCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('attractions')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const KIDS_KEYWORDS = ['ילד', 'ילדים', 'משפחה', 'פארק', 'אקווה', 'zoo', 'גן חיות', 'waterbom', 'כיף', 'bali safari']
const items = (data || []).filter(a =>
  a.family_friendly === true ||
  (a.category || '').includes('kids') || (a.category || '').includes('family') ||
  KIDS_KEYWORDS.some(kw =>
    (a.name_he || '').toLowerCase().includes(kw.toLowerCase()) ||
    (a.name_en || '').toLowerCase().includes(kw.toLowerCase()) ||
    (a.excerpt || '').toLowerCase().includes(kw.toLowerCase())
  )
)

const pageTitle = 'אטרקציות לילדים בבאלי | Yalla Bali'
const pageDescription = 'אטרקציות לילדים ולמשפחות בבאלי. פארקי שעשועים, פארקי מים, גן חיות ועוד — כל מה שצריך לטיול משפחתי מוצלח.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'אטרקציות לילדים בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/attractions/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: 'לילדים' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/attractions/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <a href="/attractions/free/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">🆓 חינם</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">👧 לילדים</span>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">אטרקציות לילדים בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי היא גן עדן לילדים — פארקי שעשועים ענקיים, פארקי מים, אקווריומים,
        גן חיות ועוד אינספור פעילויות שיהפכו את הטיול המשפחתי לבלתי נשכח.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <AttractionCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            price={item.price}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו אטרקציות לילדים כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — אטרקציות לילדים בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה האטרקציות הכי טובות לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">האטרקציות המובילות לילדים כוללות: Waterbom Bali (פארק מים), Bali Zoo, Bali Safari & Marine Park, Tegallalang Monkey Forest, Ubud Swing, Monkey Forest Sanctuary.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מאיזה גיל מתאימות האטרקציות?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">יש אטרקציות לכל גיל — מגיל שנה ועד נוער. פארקי מים מתאימים מגיל 3, פארקי שעשועים מגיל 4-5, ואטרקציות אקסטרים מגיל 12 ומעלה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם יש אטרקציות ממוזגות לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, חלק מהאטרקציות בבאלי ממוזגות — כולל Bali Zoo gift shop וקפיטריות בfamilyResorts. אבל רוב הפעילויות בבאלי חיצוניות. כנס לבריכה בק‍שופ בימי חום.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה פארקי מים לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי כוללות פארקי מים: Waterbom Bali (פארק המים הראשי בבאלי), מלונות resort עם בריכות גדולות וחופים פרטיים. אטרקציות לילדים בבאלי עם מגלשות מים ובריכות מעניקות הצלה מחום הקיץ.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה פעילויות חוצה בבאלי לילדים?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי כוללות פעילויות חוצה: רכיבה על סוסים בטגללאלנג, טיולים בקופים, Ubud Swing (נדנדה בטבע), Mountain biking טיולים. אטרקציות לילדים בבאלי הללו מציעים הרפתקה וחוויה בטבע.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הגנים לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי כוללות גנים ופארקים: Tegallalang Rice Terraces (תצפית), Orchid Garden (גן סחלבים), Bali Zoo (גן חיות), Monkey Forest Sanctuary. אטרקציות לילדים בבאלי עם חיות דומות מרתקות ילדים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הגיל הטוב ביותר לאטרקציות לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי מתאימות לכל גיל: עד גיל 3 — חופים וגנים רחוקים, גיל 3-7 — Waterbom וטיולים קלים, גיל 7-12 — Zoo וMonkey Forest, גיל 12 ומעלה — טיולים הרים ואופני הרים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">כמה עולה אטרקציות לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי בעלות: Waterbom מ-15-20 דולר, Bali Zoo מ-20-25 דולר, Bali Safari & Marine Park מ-30-40 דולר. אטרקציות לילדים בבאלי זולות יחסית לעולם — רוב תחתות בין 10-50 דולר לנפש.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה טיפים לביקור באטרקציות לילדים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות לילדים בבאלי — טיפים: הגיעו מוקדם כדי להימנע עומס, הביאו מים וזקיצים (מחמנ שמש חזק), התאקדמו בחורף (נובמבר-מרץ) לטרמפרטורה קלה. הימנעו קיץ (יוני-ספטמבר) כשחם ורטוב.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">מתכננים טיול עם ילדים לבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מתכנן טיול עם ילדים לבאלי 👨‍👩‍👧‍👦')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
