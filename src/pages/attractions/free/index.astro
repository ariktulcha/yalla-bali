---
import Layout from '../../../components/Layout.astro'
import SchemaOrg from '../../../components/SchemaOrg.astro'
import Breadcrumb from '../../../components/Breadcrumb.astro'
import AttractionCard from '../../../components/Cards/AttractionCard.astro'
import { supabaseAdmin, DESTINATION_ID } from '../../../lib/supabase'

const { data } = await supabaseAdmin
  .from('attractions')
  .select('*')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)

const items = (data || []).filter(a => a.is_free === true || a.price_range === 'חינם' || a.price_range === 'free')

const pageTitle = 'אטרקציות חינם בבאלי | Yalla Bali'
const pageDescription = 'אטרקציות חינם בבאלי שאפשר ליהנות מהן ללא תשלום. חופים, גנים, מזרקות, שווקים ועוד — חוויות בחינם בבאלי.'

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'אטרקציות חינם בבאלי',
  description: pageDescription,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name_he,
    url: new URL(`/attractions/${item.slug}`, 'https://yalla-bali.co.il').toString(),
  })),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: 'חינם' },
]
---

<Layout title={pageTitle} description={pageDescription}>
  <SchemaOrg schema={itemListSchema} />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <nav class="flex gap-2 overflow-x-auto scrollbar-hide mb-8 pb-1">
      <a href="/attractions/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">הכל</a>
      <span class="flex-none px-4 py-1.5 rounded-full text-sm font-bold bg-teal-500 text-black whitespace-nowrap">🆓 חינם</span>
      <a href="/attractions/kids/" class="flex-none px-4 py-1.5 rounded-full text-sm font-medium bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-all whitespace-nowrap">👧 לילדים</a>
    </nav>

    <header class="mb-10 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">אטרקציות חינם בבאלי</h1>
      <p class="text-white/60 max-w-2xl mx-auto leading-relaxed">
        באלי לא חייבת להיות יקרה. יש המון אטרקציות חינמיות מדהימות —
        מחופים יפהפיים ועד שווקים מסורתיים, טבע בוקר וטיולים בטבע.
      </p>
    </header>

    {items.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map(item => (
          <AttractionCard
            name_he={item.name_he}
            name_en={item.name_en}
            slug={item.slug}
            image={item.image}
            area={item.area}
            price={item.price}
            rating={item.rating}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/40 text-lg">לא נמצאו אטרקציות חינם כרגע. חזרו בקרוב!</p>
      </div>
    )}

    <section class="mt-16 bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 md:p-8">
      <h2 class="text-2xl font-bold text-teal-400 mb-6">שאלות נפוצות — אטרקציות חינם בבאלי</h2>
      <div class="space-y-4">
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה אפשר לעשות בבאלי בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">באלי מציעה הרבה חוויות חינם: חופים ציבוריים, טיולי טבע בטגללאלנג, טיול בקוף אופיסים, בקר בטמפלים קטנים, שווקים מסורתיים, שקיעות במקומות יפים, הליכה בכפרים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">האם החופים בבאלי בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">כן, רוב החופים הציבוריים בבאלי הם בחינם — כולל סמינייק ביץ', קאנגו ביץ' וסנור ביץ'. חופים פרטיים של מלונות דורשים תשלום או תשלום כניסה.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה שקיעות טובות בבאלי בחינם?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">שקיעות יפות בבאלי ניתן לראות בחינם בחופים כמו Tanah Lot Beach (הערה: בעלות דומה בכניסה לטמפל), Seminyak Sunset Beach, וUluwatu Cliffs. הצפייה בשקיעה הוא חוויה מהיפות בבאלי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה השווקים המסורתיים בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">שווקים מסורתיים בבאלי כוללים: Ubud Art Market (חינם להסתכל), Gianyar Market, ו-Sanur Fish Market. סיור באטרקציות חינם בבאלי הוא חוויה תרבותית עמוקה של חיי מקומיים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה טיולי טבע חינם בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם בבאלי כוללות טיולי טבע: טגללאלנג (חינם להסתכל), ריצ'ספדס (רויאל וקי טיול בחינם בסביבת הכפר), טיולים בגנים מקומיים. טיולים בבאלי מציעים עיזים ירוקים ונופים דרמטיים.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה טמפלים חינם בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם בבאלי כוללות טמפלים מסורתיים: Goa Gajah (Elephant Cave) — בעלות נמוכה, Tirta Empul Temple, וטמפלים קטנים בכפרים. אטרקציות חינם בבאלי תרבותיות מעניקות הבנה של ההיסטוריה ההינדית של באלי.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה אירועים חינם בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם בבאלי כוללות אירועים תרבותיים במשך השנה. ריקוד מסורתי Kecak ביערות בחינם, טקסים מקומיים, וטיולים בקופים בחינם בטגללאלנג. אירועים בבאלי מקדמים חוויה תרבותית אמיתית.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">מה הזמן הטוב ביותר לבקר באטרקציות חינם בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם בבאלי טובות במיוחד בחורף (נובמבר-מרץ) כשהמזג אוויר נעים. אטרקציות חינם בבאלי בקיץ חמות מאוד אך פחות עמוסות.</p>
        </details>
        <details class="group border-b border-teal-500/10 pb-4">
          <summary class="cursor-pointer text-white font-medium group-open:text-teal-400 transition-colors">איך להגיע לאטרקציות חינם בבאלי?</summary>
          <p class="mt-2 text-white/60 leading-relaxed">אטרקציות חינם בבאלי נגישות בתחבורה ציבורית, מוניות (Grab/Gojek), אופני תלת-אופן (scooter rental), או אופניים. Grab ו-Gojek זול מאוד בבאלי — רוב הנסיעות מעלות פחות מ-2 דולר.</p>
        </details>
      </div>
    </section>

    <div class="mt-10 bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center">
      <p class="text-white/80 mb-4">רוצים לדעת עוד על אטרקציות חינם בבאלי?</p>
      <a
        href={`https://wa.me/972528211665?text=${encodeURIComponent('היי, אני מחפש אטרקציות חינם בבאלי 🎡')}`}
        target="_blank"
        rel="noopener noreferrer"
        dir="rtl"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold px-6 py-3 rounded-full hover:bg-[#1ebe5d] transition-colors"
      >
        דברו איתנו בווטסאפ
      </a>
    </div>
  </main>
</Layout>
