---
import { supabaseAdmin, DESTINATION_ID } from '../../lib/supabase'
import { pickMetaDescription } from '../../lib/seo'
import { site, pageTitle as buildPageTitle } from '../../config/site'
import Layout from '../../components/Layout.astro'
import PhotoGallery from '../../components/PhotoGallery.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import FAQSection from '../../components/FAQSection.astro'
import { marked } from 'marked'

export async function getStaticPaths() {
  const { data: attractions } = await supabaseAdmin
    .from('attractions')
    .select('*')
    .eq('destination_id', DESTINATION_ID)
    .eq('published', true)

  return (attractions ?? []).map((attraction) => ({
    params: { slug: attraction.slug },
    props: { attraction },
  }))
}

const { attraction } = Astro.props

const price = attraction.price ?? attraction.metadata?.price
const rating = attraction.rating ?? attraction.metadata?.rating
const reviewCount = attraction.review_count ?? attraction.metadata?.review_count ?? 10
const duration = attraction.duration ?? attraction.metadata?.duration
const address = attraction.address ?? attraction.metadata?.address
const openingHours = attraction.opening_hours ?? attraction.metadata?.opening_hours

const contentHtml = attraction.full_content ? await marked(attraction.full_content) : ''

const titlePrefix = `${attraction.name_he}${attraction.name_en ? ` — ${attraction.name_en}` : ''}`
const pageTitle = attraction.meta_title || buildPageTitle(titlePrefix, 'attraction')
const pageDescription = attraction.meta_description || pickMetaDescription(attraction, `אטרקציה ב${site.destinationName}`)

const attractionSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: attraction.name_he,
  alternateName: attraction.name_en || undefined,
  description: attraction.description || attraction.excerpt,
  image: attraction.image
    ? attraction.image.startsWith('http')
      ? attraction.image
      : new URL(attraction.image, Astro.site).toString()
    : undefined,
  url: new URL(`/attractions/${attraction.slug}`, Astro.site).toString(),
  ...(address ? { address: { '@type': 'PostalAddress', streetAddress: address } } : {}),
  ...(rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: rating, ratingCount: reviewCount, bestRating: 5 } } : {}),
}

const breadcrumbItems = [
  { label: 'דף הבית', href: '/' },
  { label: 'אטרקציות', href: '/attractions' },
  { label: attraction.name_he },
]

// Distance & pricing estimates by area
const areaDistancePricing: Record<string, { distance: string; grabPrice: string }> = {
  'סמינייק': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'seminyak': { distance: '15-20 ק"מ', grabPrice: '₪60-90' },
  'קאנגו': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'canggu': { distance: '15-18 ק"מ', grabPrice: '₪60-85' },
  'אובוד': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ubud': { distance: '25-30 ק"מ', grabPrice: '₪90-130' },
  'ג\'ימברן': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'jimbaran': { distance: '10-15 ק"מ', grabPrice: '₪50-75' },
  'אולוואטו': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'uluwatu': { distance: '18-22 ק"מ', grabPrice: '₪70-100' },
  'נוסה דואה': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'nusa-dua': { distance: '12-17 ק"מ', grabPrice: '₪55-80' },
  'סנור': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'sanur': { distance: '30-35 ק"מ', grabPrice: '₪110-150' },
  'קוטה': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
  'kuta': { distance: '13-16 ק"מ', grabPrice: '₪55-75' },
}

const areaKey = (attraction.area || '').toLowerCase()
const distancePricing = areaDistancePricing[areaKey] || { distance: '20-25 ק"מ', grabPrice: '₪70-100' }

// Related attractions in same area
const { data: areaAttractions } = await supabaseAdmin
  .from('attractions')
  .select('slug, name_he, description, image')
  .eq('destination_id', DESTINATION_ID)
  .eq('published', true)
  .eq('area', attraction.area)
  .neq('slug', attraction.slug)
  .limit(3)

const relatedAttractions = areaAttractions ?? []

const dbFaq = Array.isArray(attraction.faq) ? attraction.faq : []
const faqItems = dbFaq.length > 0
  ? dbFaq.map((item: any) => ({ q: item.q, a: item.a }))
  : [
      {
        q: `כמה עולה כרטיס ל${attraction.name_he} בבאלי?`,
        a: `${price ? `המחיר ל${attraction.name_he} הוא בערך ${price}.` : `המחיר ל${attraction.name_he} משתנה בהתאם לסוג הכרטיס שתבחרו.`} אתם יכולים לקנות כרטיסים ישירות דרך Tiqets או אתרי הזמנות אחרים. מומלץ להשוות מחירים בכמה אתרים.`,
      },
      {
        q: `כמה זמן מומלץ לבלות ב${attraction.name_he}?`,
        a: `${duration ? `בדרך כלל מומלץ לבלות כ-${duration} ב${attraction.name_he}.` : `זה תלוי במה אתם רוצים לעשות ב${attraction.name_he}.`} אם אתם רוצים ליהנות מכל האטרקציות, תכננו יותר זמן. אם יש לכם זמן מוגבל בבאלי, אתם עדיין תוכלו ליהנות מהנקודות ההיילייט.`,
      },
      {
        q: `האם ${attraction.name_he} מתאימה לילדים?`,
        a: `כן, ${attraction.name_he} היא אטרקציה משפחתית מצוינת בבאלי. ילדים מכל הגילאים יוכלו ליהנות מהאתר. בדקו אם יש הגבלות גיל לפעילויות מסוימות, וודאו שילדיכם לובשים בגדים ונעליים נוחות.`,
      },
      {
        q: `מה הזמן הטוב ביותר לבקר ב${attraction.name_he} בבאלי?`,
        a: `הזמן הטוב ביותר לבקר ב${attraction.name_he} בדרך כלל הוא בבוקר מוקדם (7-8 בבוקר) או לאחר 15:00. בזמנים אלה כמות המבקרים קטנה יותר, ומזג האוויר נעים יותר. כדי להימנע מגשם, בחרו בעונה היבשה של באלי (מאי עד ספטמבר).`,
      },
    ]
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://ibalibali.com/attractions/${attraction.slug}`}
  ogImage={attraction.image}
  ogType="article"
  schema={attractionSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mb-8">
      <PhotoGallery
        mainImage={attraction.image}
        galleryUrls={attraction.gallery_urls || []}
        name={attraction.name_he}
      />
    </div>

    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{attraction.name_he}</h1>
      {attraction.name_en && (
        <p class="text-lg text-white/50">{attraction.name_en}</p>
      )}
    </header>

    <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
      {attraction.area && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {attraction.area}
        </span>
      )}
      {price && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {price}
        </span>
      )}
      {rating && (
        <span class="inline-flex items-center gap-1 text-teal-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {rating.toFixed?.(1) ?? rating}
        </span>
      )}
      {duration && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {duration}
        </span>
      )}
      {openingHours && (
        <span class="inline-flex items-center gap-1.5 text-white/70">
          <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          {openingHours}
        </span>
      )}
    </div>

    {attraction.description && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-3">על {attraction.name_he} בבאלי</h2>
        <p class="text-white/80 leading-relaxed">{attraction.description}</p>
      </div>
    )}

    {(price || duration || openingHours) && (
      <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-teal-400 mb-4">פרטים שימושיים — {attraction.name_he}</h2>
        <ul class="space-y-2 text-white/80">
          {price && <li><span class="text-teal-400 font-medium">מחיר:</span> {price}</li>}
          {duration && <li><span class="text-teal-400 font-medium">משך מומלץ:</span> {duration}</li>}
          {openingHours && <li><span class="text-teal-400 font-medium">שעות פתיחה:</span> {openingHours}</li>}
          {attraction.area && <li><span class="text-teal-400 font-medium">אזור בבאלי:</span> {attraction.area}</li>}
        </ul>
      </div>
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-4">כיצד מגיעים ל{attraction.name_he}? 🚕</h2>
      <div class="space-y-4 text-white/70">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
          <div>
            <p class="font-medium text-white">מנמל התעופה Ngurah Rai (DPS)</p>
            <p class="text-sm">מרחק משוער: <span class="text-white">{distancePricing.distance}</span></p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="font-medium text-white">Grab/Gojek Taxi</p>
            <p class="text-sm">משוער: <span class="text-white">{distancePricing.grabPrice}</span> להובלה מהנמל</p>
            <p class="text-xs text-white/50 mt-1">* המחירים הם משוער בלבד. בדקו את היישום עבור תמחור חיוני.</p>
          </div>
        </div>
        {(address || attraction.area) && (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-teal-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 003 16.382V5.618a1 1 0 011.447-.894L9 7.5m0 0l6.553-3.276A1 1 0 0117 5.618v10.764a1 1 0 01-1.447.894L9 7.5m0 0L3 10m6-6v6m6-6v6"/></svg>
            <div>
              <p class="font-medium text-white">Maps</p>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent((address || attraction.area || attraction.name_he) + ', Bali')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-teal-400 hover:text-teal-300 text-sm transition-colors"
              >
                פתחו ב-Google Maps ↗
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    {contentHtml && (
      <div class="prose prose-invert prose-teal max-w-none mb-8 [&_h2]:text-teal-400 [&_h2]:text-2xl [&_h2]:font-black [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:border-r-4 [&_h2]:border-teal-500 [&_h2]:pr-3 [&_h3]:text-teal-300 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:mt-6 [&_h3]:mb-2 [&_a]:text-teal-400 [&_strong]:text-white" set:html={contentHtml} />
    )}

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-3">טיפים לביקור ב{attraction.name_he}</h2>
      <ul class="space-y-2 text-white/80">
        <li>• הגיעו ל{attraction.name_he} מוקדם בבוקר כדי להימנע מצפיפות ולצלם תמונות יפות.</li>
        <li>• לבשו בגדים וכובע מתאים לאקלים הטרופי של באלי, והביאו מים.</li>
        <li>• הכינו מראש את הכסף למכירת הכרטיסים ל{attraction.name_he}.</li>
        <li>• הכבוד לכללי המקום {attraction.name_he} — בבאלי מקובל לכבד את המסורת המקומית.</li>
      </ul>
    </div>

    <div class="bg-[#1A1208] border border-teal-500/10 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-teal-400 mb-3">למה כדאי לבקר ב{attraction.name_he}</h2>
      <p class="text-white/80 leading-relaxed">
        {attraction.name_he} היא אחת האטרקציות המומלצות בבאלי. הביקור ב{attraction.name_he} יעניק לכם חוויה אותנטית של התרבות, הטבע והנופים של האי. שלבו את {attraction.name_he} כחלק מהמסלול שלכם בבאלי לחוויה בלתי נשכחת.
      </p>
    </div>

    <div class="mb-8">
      <FAQSection items={faqItems} entityName={attraction.name_he} />
    </div>

    {relatedAttractions.length > 0 && (
      <section class="mt-16 pt-8 border-t border-gray-800" dir="rtl">
        <h2 class="text-2xl font-bold text-white mb-6">🏛️ אטרקציות בסביבת {attraction.name_he}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedAttractions.map((item: any) => (
            <a
              href={`/attractions/${item.slug}`}
              class="group bg-gray-900 rounded-xl overflow-hidden hover:bg-gray-800 transition-colors"
            >
              {item.image ? (
                <img
                  src={item.image}
                  alt={item.name_he}
                  class="w-full h-40 object-cover group-hover:scale-105 transition-transform"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-40 bg-gray-800 flex items-center justify-center">
                  <span class="text-4xl">🏛️</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="text-white font-semibold text-sm leading-tight group-hover:text-teal-400 transition-colors">
                  {item.name_he}
                </h3>
                {item.description && (
                  <p class="text-gray-400 text-xs mt-1 line-clamp-2">{item.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {attraction.booking_url && (
      <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-6 text-center mt-16">
        <p class="text-white/80 mb-2 font-semibold">מוכנים לבקר ב{attraction.name_he}?</p>
        <p class="text-white/50 text-sm mb-5">קנו כרטיסים ישירות דרך Tiqets — מחירים שקופים, ביטול גמיש</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href={attraction.booking_url}
            target="_blank"
            rel="noopener noreferrer sponsored"
            dir="rtl"
            class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-black font-bold px-6 py-3 rounded-full transition-colors text-base"
          >
            🎟️ קנו כרטיסים — Tiqets
          </a>
        </div>
      </div>
    )}
  </div>
</Layout>
