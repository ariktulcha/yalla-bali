---
import Layout from '../components/Layout.astro'
---

<Layout
  title="הדף לא נמצא — 404 | Yalla Bali"
  description="הדף שחיפשתם בנושא טיול לבאלי לא נמצא באתר Yalla Bali. חזרו לעמוד הבית, גלו את האטרקציות, מלונות ומסעדות שלנו, או צרו קשר במייל לעזרה בתכנון."
>
  <div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="max-w-2xl mx-auto text-center">
      <!-- 404 Number -->
      <div class="mb-8">
        <h1 class="text-7xl sm:text-8xl md:text-[10rem] font-black text-transparent bg-clip-text bg-gradient-to-br from-teal-500 to-teal-400">
          404
        </h1>
      </div>

      <!-- Heading -->
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white mb-4">הדף לא נמצא</h2>

      <!-- Subtext -->
      <p class="text-lg sm:text-xl text-white/70 mb-8 max-w-xl mx-auto leading-relaxed">
        נראה שהתעיתם... אבל באלי מחכה לכם! 🌴
      </p>

      <!-- Navigation Links -->
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <a
          href="/"
          class="bg-teal-500 hover:bg-teal-600 text-[#0D0D0D] font-bold py-3 px-6 rounded-lg transition-all"
        >
          🏠 חזרה לעמוד הבית
        </a>
        <a
          href="/tours"
          class="bg-teal-500/20 hover:bg-teal-500/30 text-teal-400 font-bold py-3 px-6 rounded-lg border border-teal-500/40 transition-all"
        >
          🌴 טיולים בבאלי
        </a>
        <a
          href="/attractions"
          class="bg-teal-500/20 hover:bg-teal-500/30 text-teal-400 font-bold py-3 px-6 rounded-lg border border-teal-500/40 transition-all"
        >
          🎢 אטרקציות
        </a>
        <a
          href="/hotels"
          class="bg-teal-500/20 hover:bg-teal-500/30 text-teal-400 font-bold py-3 px-6 rounded-lg border border-teal-500/40 transition-all"
        >
          🏨 מלונות
        </a>
      </div>

      <!-- Contact CTA -->
      <div class="bg-[#1A1208] border border-teal-500/20 rounded-2xl p-8">
        <p class="text-white/80 mb-4">צריכים עזרה בתכנון הטיול?</p>
        <a
          href="/contact"
          dir="rtl"
          class="inline-flex items-center gap-2 bg-teal-500 hover:bg-teal-400 text-[#0D0D0D] font-bold px-8 py-3 rounded-full transition-all"
        >
          ✉️ צרו איתנו קשר
        </a>
      </div>
    </div>
  </div>
</Layout>
