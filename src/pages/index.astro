      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center p-8 rounded-2xl bg-[#1A1208] border border-amber-500/10">
          <span class="text-4xl mb-4 block">🇮🇱</span>
          <h3 class="text-xl font-bold text-white mb-2">הכל בעברית</h3>
          <p class="text-white/50 text-sm">מדריכים, המלצות ומידע מפורט — כתוב לישראלים, על ידי ישראלים שמכירים את באלי</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-[#1A1208] border border-amber-500/10">
          <span class="text-4xl mb-4 block">🗺️</span>
          <h3 class="text-xl font-bold text-white mb-2">מידע מעודכן ומדויק</h3>
          <p class="text-white/50 text-sm">מחירים, שעות פתיחה, כתובות וטיפים מעשיים — הכל מאומת ומעודכן ל-2026</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-[#1A1208] border border-amber-500/10">
          <span class="text-4xl mb-4 block">💬</span>
          <h3 class="text-xl font-bold text-white mb-2">מענה במייל</h3>
          <p class="text-white/50 text-sm">שאלות? התלבטויות? שלחו לנו הודעה ונעזור עם מידע, המלצות וטיפים</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        מה <span class="text-amber-400">אומרים עלינו</span>
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-[#1A1208] rounded-2xl p-6 border border-amber-500/10">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <p class="text-white/70 mb-4 leading-relaxed">&ldquo;{t.text}&rdquo;</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-white font-bold">{t.name}</p>
              <p class="text-white/30 text-sm">{t.city}</p>
            </div>
            <div class="text-left">
              <p class="text-amber-400 text-sm font-medium">{t.tour}</p>
              <p class="text-white/20 text-xs">{t.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-gradient-to-b from-[#0D0D0D] to-[#1A1208]/30 py-16 md:py-24">
