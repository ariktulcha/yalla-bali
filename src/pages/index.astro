      </div>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/40 text-sm">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
