---
import Layout from '../components/Layout.astro'
import SchemaOrg from '../components/SchemaOrg.astro'
import { supabaseAdmin, DESTINATION_ID } from '../lib/supabase'

const { data: attractions } = await supabaseAdmin.from('attractions').select('name_he, slug, image, rating, price, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(6)
const { data: tours } = await supabaseAdmin.from('tours').select('name, slug, image, base_price, rating, review_count, duration_minutes, short_description, includes').eq('destination_id', DESTINATION_ID).eq('published', true)
const { data: hotels } = await supabaseAdmin.from('hotels').select('name_he, slug, image, rating, area').eq('destination_id', DESTINATION_ID).eq('published', true).limit(4)
const { data: areas } = await supabaseAdmin.from('areas').select('name_he, slug, image, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(6)
const { data: guides } = await supabaseAdmin.from('guides').select('name_he, slug, image, excerpt').eq('destination_id', DESTINATION_ID).eq('published', true).limit(3)

const featuredAttractions = attractions ?? []
const featuredTours = tours ?? []
const featuredHotels = hotels ?? []
const featuredAreas = areas ?? []
const featuredGuides = guides ?? []

const categories = [
  { label: 'אטרקציות', icon: '🏛️', href: '/attractions', desc: 'מקדשים, טרסות אורז וג׳ונגל' },
  { label: 'מלונות', icon: '🏨', href: '/hotels', desc: 'וילות, ריזורטים ובוטיקים' },
  { label: 'מסעדות', icon: '🍽️', href: '/restaurants', desc: 'אוכל מקומי ובינלאומי' },
  { label: 'חיי לילה', icon: '🌙', href: '/nightlife', desc: 'בארים, מועדונים וביץ׳ קלאבס' },
  { label: 'חופים', icon: '🏖️', href: '/beaches', desc: 'חופים לגלישה ושחייה' },
  { label: 'אזורים', icon: '🗺️', href: '/areas', desc: 'אובוד, קאנגו, סמיניאק ועוד' },
]

const testimonials = [
  {
    text: 'הגענו לבאלי ל-10 ימים עם כל המשפחה — 3 ילדים כולל תינוק. המסלול שקיבלנו היה מדויק לגיל הילדים, וקאנגו הייתה חוויה שהילדים לא יפסיקו לדבר עליה.',
    name: 'תמר ואביב פרידמן',
    city: 'כפר סבא',
    tour: 'טיול משפחתי 10 ימים',
    date: 'פברואר 2026',
  },
  {
    text: 'הגענו לבאלי ל-7 ימים ולא ידענו מאיפה להתחיל. השתמשנו במדריכים של יאללה באלי כדי לבנות מסלול מותאם. הסיור לנוסה פניידה שהמליצו עליו היה הייט-לייט של הטיול.',
    name: 'נדב כ.',
    city: 'חיפה',
    tour: 'תכנון טיול 7 ימים',
    date: 'ינואר 2026',
  },
  {
    text: 'המדריך באובוד היה פנומנלי, והריטריט היוגה שמצאנו דרכם שינה לנו את החיים. יאללה באלי = שירות ברמה שלא מצאתי בשום מקום.',
    name: 'רותם ש.',
    city: 'תל אביב',
    tour: 'ריטריט אובוד',
    date: 'מרץ 2026',
  },
]

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Yalla Bali - יאללה באלי',
  url: 'https://ibalibali.com',
  description: 'המדריך המלא לבאלי בעברית — אטרקציות, מלונות, מסעדות, אזורים וטיפים לטיול',
  inLanguage: 'he',
}

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Yalla Bali',
  url: 'https://ibalibali.com',
  description: 'המדריך הישראלי לבאלי',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    availableLanguage: ['Hebrew', 'English'],
  },
}
---

<Layout
  title="יאללה באלי — המדריך המלא לבאלי בעברית 2026"
  description="המדריך הישראלי המלא לבאלי. אטרקציות, מלונות, מסעדות, חופים, אזורים, חיי לילה ומדריכים מפורטים. הכל בעברית, עם מחירים וטיפים מקומיים."
  canonical="https://ibalibali.com"
>
  <SchemaOrg schema={[websiteSchema, organizationSchema]} />

  <!-- HERO -->
  <section class="relative min-h-[80vh] md:min-h-[90vh] flex items-center justify-center overflow-hidden">
    <picture>
      <source srcset="/images/heroes/hero-bali.webp" type="image/webp" />
      <img
        src="/images/heroes/hero-bali.webp"
        alt="באלי — מקדש אולון דאנו ברטאן על אגם ברטאן"
        class="absolute inset-0 w-full h-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-[#0D0D0D]"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.1]">
        המדריך המלא <span class="text-amber-400">לבאלי</span> בעברית
      </h1>

      <p class="text-xl md:text-2xl text-white/80 font-medium mb-4">
        ג׳ונגל, חופים, מקדשים, אוכל וחיי לילה — הכל במקום אחד
      </p>

      <p class="text-lg text-white/50 mb-10 max-w-2xl mx-auto">
        אטרקציות, מלונות, מסעדות, אזורים ומדריכים מפורטים. כל מה שצריך לטיול מושלם בבאלי.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/plan" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-black px-10 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-amber-500/25">
          תכננו את הטיול לבאלי
        </a>
        <a href="/visa" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold transition-all border border-white/20">
          מדריך ויזה לישראלים
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/30" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- QUICK STATS -->
  <section class="border-y border-amber-500/10 bg-[#1A1208]/50 py-8">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredAttractions.length}+</div>
          <div class="text-white/50 text-sm mt-1">אטרקציות</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredHotels.length}+</div>
          <div class="text-white/50 text-sm mt-1">מלונות מומלצים</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredTours.length}</div>
          <div class="text-white/50 text-sm mt-1">חבילות טיולים</div>
        </div>
        <div>
          <div class="text-3xl font-black text-amber-400">{featuredAreas.length}+</div>
          <div class="text-white/50 text-sm mt-1">אזורים לגלות</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        מה <span class="text-amber-400">לעשות בבאלי</span>
      </h2>
      <p class="text-white/40 max-w-2xl mx-auto">כל מה שהאי הקסום הזה יכול להציע — ממקדשים עתיקים ועד מסיבות חוף</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {categories.map((cat) => (
        <a href={cat.href} class="group relative p-6 rounded-2xl bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1 text-center">
          <span class="text-4xl mb-3 block">{cat.icon}</span>
          <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors mb-1">{cat.label}</h3>
          <p class="text-white/40 text-xs">{cat.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- VISA INFO BANNER -->
  <section class="bg-amber-500/5 border-y border-amber-500/15 py-8">
    <div class="max-w-4xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-center sm:text-right">
        <p class="text-white font-bold text-lg">ישראלים צריכים ויזה לבאלי</p>
        <p class="text-white/50 text-sm mt-1">תהליך של 5–8 שבועות שכולל ספונסר אינדונזי. קראו את המדריך המלא שלנו.</p>
      </div>
      <a href="/visa" class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-black px-6 py-3 rounded-xl font-bold text-sm transition-all shrink-0">
        מדריך ויזה מלא
        <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </section>

  <!-- TOURS -->
  {featuredTours.length > 0 && (
    <section class="py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
              טיולים <span class="text-amber-400">וסיורים בבאלי</span>
            </h2>
            <p class="text-white/40">גלישה, ג׳ונגל, מקדשים ועוד — בחרו את החוויה שלכם</p>
          </div>
          <a href="/tours" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
            כל הטיולים
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTours.map((tour: any) => (
            <a href={`/tours/${tour.slug}`} class="group rounded-2xl overflow-hidden bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1 flex flex-col">
              <div class="relative h-48 overflow-hidden">
                {tour.image ? (
                  <img src={tour.image} alt={tour.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-amber-900/20 via-[#1A1208] to-[#0D0D0D] flex items-center justify-center">
                    <span class="text-6xl opacity-30">🌴</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                {tour.base_price && (
                  <div class="absolute top-3 left-3 bg-amber-500 text-black px-3 py-1 rounded-lg text-sm font-bold">
                    החל מ-₪{tour.base_price}
                  </div>
                )}
              </div>

              <div class="p-6 flex flex-col flex-1">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors mb-2">{tour.name}</h3>
                <div class="flex items-center gap-3 text-sm text-white/50 mb-3">
                  {tour.rating && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 text-amber-400 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {tour.rating}
                    </span>
                  )}
                  {tour.duration_minutes && <span>{Math.round(tour.duration_minutes / 60)} שעות</span>}
                  {tour.review_count && <span>{tour.review_count} ביקורות</span>}
                </div>
                <p class="text-white/60 text-sm flex-1 line-clamp-2">{tour.short_description}</p>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-8 md:hidden">
          <a href="/tours" class="inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold transition-colors">
            כל הטיולים
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- AREAS -->
  {featuredAreas.length > 0 && (
    <section class="bg-[#1A1208]/30 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
              אזורים <span class="text-amber-400">מובילים בבאלי</span>
            </h2>
            <p class="text-white/40">כל אזור בבאלי הוא עולם בפני עצמו — גלו מה מתאים לכם</p>
          </div>
          <a href="/areas" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
            כל האזורים
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredAreas.map((area: any) => (
            <a href={`/areas/${area.slug}`} class="group relative rounded-2xl overflow-hidden h-52 flex items-end">
              {area.image ? (
                <img src={area.image} alt={area.name_he} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-amber-900/30 to-[#0D0D0D]"></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="relative p-5 w-full">
                <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors">{area.name_he}</h3>
                {area.excerpt && <p class="text-white/60 text-sm mt-1 line-clamp-1">{area.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FEATURED ATTRACTIONS -->
  {featuredAttractions.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
            אטרקציות <span class="text-amber-400">מובילות בבאלי</span>
          </h2>
          <p class="text-white/40">מקדשים, טרסות אורז, מפלים ועוד</p>
        </div>
        <a href="/attractions" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
          כל האטרקציות
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredAttractions.map((attraction: any) => (
          <a href={`/attractions/${attraction.slug}`} class="group rounded-2xl overflow-hidden bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1">
            <div class="relative h-44 overflow-hidden">
              {attraction.image ? (
                <img src={attraction.image} alt={attraction.name_he} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-amber-900/20 to-[#0D0D0D] flex items-center justify-center">
                  <span class="text-5xl opacity-30">🏛️</span>
                </div>
              )}
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors mb-2">{attraction.name_he}</h3>
              <div class="flex items-center justify-between text-sm">
                {attraction.rating && (
                  <span class="flex items-center gap-1 text-amber-400">
                    <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {attraction.rating}
                  </span>
                )}
                {attraction.price && <span class="text-white/40 text-xs">{attraction.price}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-8 md:hidden">
        <a href="/attractions" class="inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold transition-colors">
          כל האטרקציות
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </section>
  )}

  <!-- HOTELS PREVIEW -->
  {featuredHotels.length > 0 && (
    <section class="bg-[#1A1208]/30 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
              מלונות <span class="text-amber-400">מומלצים בבאלי</span>
            </h2>
            <p class="text-white/40">וילות פרטיות, ריזורטים מפנקים ומלונות בוטיק</p>
          </div>
          <a href="/hotels" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
            כל המלונות
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredHotels.map((hotel: any) => (
            <a href={`/hotels/${hotel.slug}`} class="group rounded-2xl overflow-hidden bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1">
              <div class="relative h-40 overflow-hidden">
                {hotel.image ? (
                  <img src={hotel.image} alt={hotel.name_he} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-amber-900/20 to-[#0D0D0D] flex items-center justify-center">
                    <span class="text-5xl opacity-30">🏨</span>
                  </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="text-base font-bold text-white group-hover:text-amber-400 transition-colors mb-1">{hotel.name_he}</h3>
                <div class="flex items-center justify-between text-sm">
                  {hotel.rating && (
                    <span class="flex items-center gap-1 text-amber-400">
                      <svg class="w-3.5 h-3.5 fill-amber-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {hotel.rating}
                    </span>
                  )}
                  {hotel.area && <span class="text-white/40 text-xs">{hotel.area}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- GUIDES PREVIEW -->
  {featuredGuides.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-2">
            מדריכים <span class="text-amber-400">לבאלי</span>
          </h2>
          <p class="text-white/40">מדריכים מפורטים לכל מה שצריך לדעת</p>
        </div>
        <a href="/guides" class="hidden md:inline-flex items-center gap-1 text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
          כל המדריכים
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {featuredGuides.map((guide: any) => (
          <a href={`/guides/${guide.slug}`} class="group rounded-2xl overflow-hidden bg-[#1A1208] border border-amber-500/10 hover:border-amber-500/30 transition-all duration-300 hover:-translate-y-1 flex flex-col">
            <div class="relative h-40 overflow-hidden">
              {guide.image ? (
                <img src={guide.image} alt={guide.name_he} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-amber-900/20 to-[#0D0D0D] flex items-center justify-center">
                  <span class="text-5xl opacity-30">📖</span>
                </div>
              )}
            </div>
            <div class="p-5 flex-1 flex flex-col">
              <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors mb-2">{guide.name_he}</h3>
              {guide.excerpt && <p class="text-white/60 text-sm line-clamp-2">{guide.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- WHY US -->
  <section class="bg-[#1A1208]/30 py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
