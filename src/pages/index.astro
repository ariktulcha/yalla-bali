        </a>
        <a href="/contact"
           class="inline-flex items-center justify-center gap-2 bg-[#1A1208] hover:bg-[#2A1F18] border border-amber-500/30 hover:border-amber-500/50 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all">
