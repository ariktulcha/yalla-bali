# Supabase (server-side; never expose SERVICE_KEY to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Destination identifier — filters Supabase rows per site
DESTINATION_ID=bali

# Google Analytics 4 measurement ID
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps JS API key (used by MapEmbed / StreetViewEmbed components)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Places API (New) key — used by scripts/fetch-gallery.mjs to fetch hotel/restaurant photos
GOOGLE_PLACES_KEY=your-google-places-key

# Booking.com affiliate ID — appended as aid= to booking.com links
BOOKING_AFFILIATE_ID=your-booking-affiliate-id
